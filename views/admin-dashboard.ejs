                                <input type="color" id="cp_footerLinkHover" class="color-swatch" value="#ffffff">
                                <input type="text" id="cp_footerLinkHover_hex" class="form-control mono-input" value="#ffffff" placeholder="#ffffff">
                            </div>
                            <small class="text-muted">Color hover de los links del footer</small>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Vista previa del footer</label>
                            <div id="footerPreviewCard" style="border-radius:12px;padding:16px;background:#2d3748;">
                                <div id="fpHeading" style="color:#fff;font-weight:700;font-size:0.95rem;margin-bottom:8px;">Título sección</div>
                                <div id="fpText" style="color:#cbd5e0;font-size:0.85rem;margin-bottom:8px;">Descripción de la tienda</div>
                                <a href="#" id="fpLink" onclick="return false;" style="color:#cbd5e0;font-size:0.85rem;text-decoration:none;">Enlace del footer</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ══════════════ REDES SOCIALES (iconos) ══════════════ -->
                <div class="chart-card mb-4">
                    <h5><i class="fas fa-share-alt" style="color:var(--primary)"></i> Íconos de Redes Sociales</h5>
                    <p class="text-muted mb-3" style="font-size:0.9rem;">
                        Elegí si los botones usan los colores originales de cada red o un color personalizado tuyo.
                    </p>
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Estilo de íconos</label>
                            <div class="d-flex gap-4 align-items-center flex-wrap">
                                <label class="d-flex align-items-center gap-2" style="cursor:pointer;font-weight:500;">
                                    <input type="radio" name="footerIconMode" id="footerIconBrand" value="brand" checked onchange="updateFooterIconPreview()">
                                    <i class="fab fa-instagram" style="color:#e1306c;"></i>
                                    Colores originales de cada red
                                </label>
                                <label class="d-flex align-items-center gap-2" style="cursor:pointer;font-weight:500;">
                                    <input type="radio" name="footerIconMode" id="footerIconCustom" value="custom" onchange="updateFooterIconPreview()">
                                    <i class="fas fa-palette" style="color:var(--primary);"></i>
                                    Color personalizado (gradiente)
                                </label>
                            </div>
                            <small class="text-muted mt-1 d-block">Con "originales": Facebook azul, Instagram degradado, WhatsApp verde, etc.</small>
                        </div>

                        <div id="footerIconCustomFields" style="display:none;" class="col-md-12">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Color ícono 1 (inicio gradiente)</label>
                                    <div class="d-flex gap-2 align-items-center">
                                        <input type="color" id="cp_footerIconBg1" class="color-swatch" value="#667eea">
                                        <input type="text" id="cp_footerIconBg1_hex" class="form-control mono-input" value="#667eea" placeholder="#667eea">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Color ícono 2 (fin gradiente)</label>
                                    <div class="d-flex gap-2 align-items-center">
                                        <input type="color" id="cp_footerIconBg2" class="color-swatch" value="#764ba2">
                                        <input type="text" id="cp_footerIconBg2_hex" class="form-control mono-input" value="#764ba2" placeholder="#764ba2">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Vista previa de íconos</label>
                            <div class="d-flex gap-2 align-items-center flex-wrap" id="socialIconPreviewRow">
                                <!-- previews rendered by JS -->
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <div class="d-flex gap-3 flex-wrap align-items-center">
                    <button class="btn-primary-custom" onclick="guardarColores()" style="padding:12px 36px;font-size:1rem;">
                        <i class="fas fa-save"></i> Guardar Todos los Colores
                    </button>
                    <button class="btn btn-outline-secondary" onclick="resetColores()" style="padding:12px 24px;border-radius:50px;">
                        <i class="fas fa-undo"></i> Restaurar predeterminados
                    </button>
                    <span id="colorSaveMsg" style="display:none;color:var(--success);font-weight:600;">
                        <i class="fas fa-check-circle"></i> ¡Colores guardados! Se ven en la tienda.
                    </span>
                </div>
            </div>

            <!-- CONFIGURACIÓN DE PEDIDOS -->
            <div class="tab-pane" id="tab-pedidos-config">
                <div class="products-header">
                    <div>
                        <h3><i class="fas fa-cog"></i> Configuración de Pedidos</h3>
                        <p class="mb-0">Definí cómo opera tu negocio y qué cargos adicionales aplicar</p>
                    </div>
                </div>

                <!-- MODO DE OPERACIÓN -->
                <div class="chart-card mb-4">
                    <h5><i class="fas fa-store" style="color:var(--primary)"></i> Modo de Operación</h5>
                    <p class="text-muted mb-4" style="font-size:0.9rem;">Elegí cómo reciben los pedidos tus clientes. Esto cambia las opciones que verán al hacer checkout.</p>
                    <div class="row g-3" id="modoOperacionGroup">
                        <div class="col-md-4">
                            <label class="modo-card" id="modo-delivery" onclick="selectModo('delivery')">
                                <div class="modo-icon"><i class="fas fa-motorcycle"></i></div>
                                <div class="modo-title">Solo Delivery</div>
                                <div class="modo-desc">Todos los pedidos son enviados al domicilio del cliente. El cliente ingresa su dirección al finalizar la compra.</div>
                                <div class="modo-check"><i class="fas fa-check-circle"></i></div>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="modo-card" id="modo-retiro" onclick="selectModo('retiro')">
                                <div class="modo-icon"><i class="fas fa-store"></i></div>
                                <div class="modo-title">Solo Retiro en Local</div>
                                <div class="modo-desc">Los clientes pasan a retirar su pedido en el local. No se pide dirección ni se cobra envío.</div>
                                <div class="modo-check"><i class="fas fa-check-circle"></i></div>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="modo-card" id="modo-hibrido" onclick="selectModo('hibrido')">
                                <div class="modo-icon"><i class="fas fa-random"></i></div>
                                <div class="modo-title">Híbrido</div>
                                <div class="modo-desc">El cliente elige si quiere delivery o retiro en local al momento de finalizar la compra.</div>
                                <div class="modo-check"><i class="fas fa-check-circle"></i></div>
                            </label>
                        </div>
                    </div>
                    <input type="hidden" id="modoOperacion" value="hibrido">
                </div>

                <!-- DIRECCIÓN DEL LOCAL -->
                <div class="chart-card mb-4" id="cardDireccionLocal">
                    <h5><i class="fas fa-map-marker-alt" style="color:var(--primary)"></i> Dirección del Local</h5>
                    <p class="text-muted mb-3" style="font-size:0.9rem;">Esta dirección se mostrará al cliente cuando elija retiro en local.</p>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Dirección del negocio</label>
                            <input type="text" class="form-control" id="direccionLocal" placeholder="Ej: Av. Rivadavia 1234, CABA">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Horario de atención</label>
                            <input type="text" class="form-control" id="horarioLocal" placeholder="Ej: Lun-Vie 9-18hs">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Indicaciones adicionales</label>
                            <input type="text" class="form-control" id="indicacionesLocal" placeholder="Ej: Tocar timbre, piso 2, preguntar por recepción">
                        </div>
                    </div>
                </div>

                <!-- TARIFAS ADICIONALES -->
                <div class="chart-card mb-4">
                    <h5><i class="fas fa-tags" style="color:var(--primary)"></i> Tarifas y Cargos Adicionales</h5>
                    <p class="text-muted mb-3" style="font-size:0.9rem;">Configurá los cargos que se suman al total del pedido. Solo se aplicarán si están activos.</p>

                    <!-- COSTO DE ENVÍO -->
                    <div class="tarifa-item" id="tarifaEnvio">
                        <div class="tarifa-header">
                            <div class="tarifa-left">
                                <div class="tarifa-icon" style="background:linear-gradient(135deg,#667eea,#764ba2)"><i class="fas fa-truck"></i></div>
                                <div>
                                    <div class="tarifa-title">Costo de Envío</div>
                                    <div class="tarifa-subtitle">Se suma al total cuando el cliente elige delivery</div>
                                </div>
                            </div>
                            <div class="tarifa-toggle-wrap">
                                <label class="toggle-switch">
                                    <input type="checkbox" id="envioActivo" onchange="toggleTarifaBody('envioBody', this.checked)">
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                        </div>
                        <div class="tarifa-body" id="envioBody" style="display:none;">
                            <div class="row g-3 mt-1">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Tipo de costo</label>
                                    <select class="form-select" id="envioTipo" onchange="updateEnvioPreview()">
                                        <option value="fijo">Monto fijo</option>
                                        <option value="porcentaje">Porcentaje del total</option>
                                        <option value="gratis_desde">Gratis desde un monto</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold" id="envioValorLabel">Monto ($)</label>
                                    <input type="number" class="form-control" id="envioValor" min="0" step="0.01" placeholder="0.00" oninput="updateEnvioPreview()">
                                </div>
                                <div class="col-md-4" id="envioGratisDesdeWrap" style="display:none;">
                                    <label class="form-label fw-bold">Gratis desde ($)</label>
                                    <input type="number" class="form-control" id="envioGratisDesde" min="0" step="0.01" placeholder="Ej: 5000" oninput="updateEnvioPreview()">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Etiqueta visible</label>
                                    <input type="text" class="form-control" id="envioLabel" value="Costo de envío" placeholder="Ej: Envío a domicilio">
                                </div>
                                <div class="col-12">
                                    <div class="tarifa-preview" id="envioPreview">
                                        <i class="fas fa-eye"></i> Vista previa: <strong id="envioPreviewText">Costo de envío: $0.00</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- IMPUESTOS -->
                    <div class="tarifa-item" id="tarifaImpuesto">
                        <div class="tarifa-header">
                            <div class="tarifa-left">
                                <div class="tarifa-icon" style="background:linear-gradient(135deg,#f59e0b,#d97706)"><i class="fas fa-file-invoice-dollar"></i></div>
                                <div>
                                    <div class="tarifa-title">Impuestos / IVA</div>
                                    <div class="tarifa-subtitle">Cargo fiscal que se agrega al subtotal</div>
                                </div>
                            </div>
                            <div class="tarifa-toggle-wrap">
                                <label class="toggle-switch">
                                    <input type="checkbox" id="impuestoActivo" onchange="toggleTarifaBody('impuestoBody', this.checked)">
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                        </div>
                        <div class="tarifa-body" id="impuestoBody" style="display:none;">
                            <div class="row g-3 mt-1">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Porcentaje (%)</label>
                                    <input type="number" class="form-control" id="impuestoPorcentaje" min="0" max="100" step="0.01" placeholder="Ej: 21">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Etiqueta visible</label>
                                    <input type="text" class="form-control" id="impuestoLabel" value="IVA" placeholder="Ej: IVA (21%)">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Incluido en precio</label>
                                    <select class="form-select" id="impuestoIncluido">
                                        <option value="no">No (se suma al total)</option>
                                        <option value="si">Sí (ya incluido, solo mostrar)</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- CARGO EXTRA PERSONALIZADO -->
                    <div class="tarifa-item" id="tarifaExtra">
                        <div class="tarifa-header">
                            <div class="tarifa-left">
                                <div class="tarifa-icon" style="background:linear-gradient(135deg,#10b981,#059669)"><i class="fas fa-plus-circle"></i></div>
                                <div>
                                    <div class="tarifa-title">Cargo Extra Personalizado</div>
                                    <div class="tarifa-subtitle">Cualquier otro cargo: servicio, embalaje, recargo tarjeta, etc.</div>
                                </div>
                            </div>
                            <div class="tarifa-toggle-wrap">
                                <label class="toggle-switch">
                                    <input type="checkbox" id="extraActivo" onchange="toggleTarifaBody('extraBody', this.checked)">
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                        </div>
                        <div class="tarifa-body" id="extraBody" style="display:none;">
                            <div class="row g-3 mt-1">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Nombre del cargo</label>
                                    <input type="text" class="form-control" id="extraNombre" placeholder="Ej: Embalaje especial">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Tipo</label>
                                    <select class="form-select" id="extraTipo">
                                        <option value="fijo">Monto fijo ($)</option>
                                        <option value="porcentaje">Porcentaje (%)</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Valor</label>
                                    <input type="number" class="form-control" id="extraValor" min="0" step="0.01" placeholder="0.00">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RESUMEN VISTA PREVIA -->
                <div class="chart-card mb-4">
                    <h5><i class="fas fa-receipt" style="color:var(--primary)"></i> Vista Previa del Checkout</h5>
                    <p class="text-muted mb-3" style="font-size:0.9rem;">Así verá el cliente el resumen de su pedido con los cargos activos.</p>
                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            <div style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);border-radius:16px;padding:24px;color:white;">
                                <h5 style="margin-bottom:16px;"><i class="fas fa-receipt"></i> Resumen del Pedido</h5>
                                <div style="display:flex;justify-content:space-between;margin-bottom:8px;opacity:0.9;"><span>Subtotal productos</span><strong>$1.500,00</strong></div>
                                <div id="prevEnvioRow" style="display:none;justify-content:space-between;margin-bottom:8px;opacity:0.9;"><span id="prevEnvioLabel">Envío</span><strong id="prevEnvioMonto">$0,00</strong></div>
                                <div id="prevImpRow" style="display:none;justify-content:space-between;margin-bottom:8px;opacity:0.9;"><span id="prevImpLabel">IVA</span><strong id="prevImpMonto">$0,00</strong></div>
                                <div id="prevExtraRow" style="display:none;justify-content:space-between;margin-bottom:8px;opacity:0.9;"><span id="prevExtraLabel">Cargo extra</span><strong id="prevExtraMonto">$0,00</strong></div>
                                <hr style="border-color:rgba(255,255,255,0.3);margin:12px 0;">
                                <div style="display:flex;justify-content:space-between;font-size:1.2rem;"><span>Total</span><strong id="prevTotal">$1.500,00</strong></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- BOTÓN GUARDAR AL PIE -->
                <div class="d-flex gap-3 flex-wrap align-items-center justify-content-end mt-2 mb-4">
                    <span id="pedidosSaveMsg" style="display:none;color:var(--success);font-weight:600;">
                        <i class="fas fa-check-circle"></i> ¡Configuración guardada!
                    </span>
                    <button class="btn-primary-custom" onclick="guardarConfigPedidos()" style="padding:14px 36px;font-size:1rem;">
                        <i class="fas fa-save"></i> Guardar Configuración
                    </button>
                </div>

            </div>

        </div>
    </div>

    <!-- ==================== MODALES ==================== -->
    
    <!-- Modal para AGREGAR producto -->
    <div class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-plus-circle"></i> Agregar Nuevo Producto</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="addProductForm" enctype="multipart/form-data" action="/admin/productos/create" method="POST">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Nombre del Producto *</label>
                            <input type="text" class="form-control" name="nombre" id="add_nombre" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Descripción</label>
                            <textarea class="form-control" name="descripcion" id="add_descripcion" rows="3"></textarea>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Precio *</label>
                                <input type="number" step="0.01" class="form-control" name="precio" id="add_precio" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Precio de Oferta</label>
                                <input type="number" step="0.01" class="form-control" name="precio_oferta" id="add_precio_oferta" placeholder="Opcional">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Stock *</label>
                                <input type="number" class="form-control" name="stock" id="add_stock" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Imagen del Producto *</label>
                            <div class="upload-area" onclick="document.getElementById('add_imagenFile').click()">
                                <i class="fas fa-cloud-upload-alt"></i>
                                <p class="mb-0">Haz clic para seleccionar una imagen</p>
                                <small class="text-muted">Formatos: JPG, PNG, GIF (Máx. 5MB)</small>
                            </div>
                            <input type="file" class="d-none" id="add_imagenFile" name="imagenFile" accept="image/*" onchange="previewAddImage(this)">
                            <div class="image-preview-container"><img id="add_imagePreview" class="image-preview" alt="Vista previa"></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Categoría *</label>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="categoria-group" id="add_categoriaGroup">
                                        <% if (categorias && categorias.length > 0) { %>
                                            <% categorias.forEach(cat => { %>
                                                <div class="categoria-badge" data-categoria="<%= cat.categoria %>"><%= cat.categoria %></div>
                                            <% }) %>
                                        <% } %>
                                        <div class="categoria-badge" data-categoria="Otros">Otros</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control" name="categoria" id="add_categoria" placeholder="O escribe una categoría personalizada">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn-submit-product">Agregar Producto</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <!-- Modal para EDITAR producto -->
    <div class="modal fade" id="editProductModal" tabindex="-1" aria-labelledby="editProductModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-edit"></i> Editar Producto</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="editProductForm" enctype="multipart/form-data" action="/admin/productos/update" method="POST">
                    <div class="modal-body">
                        <input type="hidden" name="id" id="edit_id">
                        <div class="mb-3"><label class="form-label">Nombre del Producto *</label><input type="text" class="form-control" name="nombre" id="edit_nombre" required></div>
                        <div class="mb-3"><label class="form-label">Descripción</label><textarea class="form-control" name="descripcion" id="edit_descripcion" rows="3"></textarea></div>
                        <div class="row mb-3">
                            <div class="col-md-4"><label class="form-label">Precio *</label><input type="number" step="0.01" class="form-control" name="precio" id="edit_precio" required></div>
                            <div class="col-md-4"><label class="form-label">Precio de Oferta</label><input type="number" step="0.01" class="form-control" name="precio_oferta" id="edit_precio_oferta" placeholder="Opcional"></div>
                            <div class="col-md-4"><label class="form-label">Stock *</label><input type="number" class="form-control" name="stock" id="edit_stock" required></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Imagen Actual</label>
                            <div class="text-center mb-2"><img id="edit_currentImage" src="" class="current-image" alt="Imagen actual"></div>
                            <label class="form-label">Cambiar Imagen (opcional)</label>
                            <div class="upload-area" onclick="document.getElementById('edit_imagenFile').click()">
                                <i class="fas fa-cloud-upload-alt"></i>
                                <p class="mb-0">Haz clic para seleccionar una nueva imagen</p>
                                <small class="text-muted">Formatos: JPG, PNG, GIF (Máx. 5MB)</small>
                            </div>
                            <input type="file" class="d-none" id="edit_imagenFile" name="imagenFile" accept="image/*" onchange="previewEditImage(this)">
                            <div class="image-preview-container"><img id="edit_imagePreview" class="image-preview" alt="Nueva vista previa"></div>
                            <input type="hidden" name="imagen" id="edit_imagen">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Categoría *</label>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="categoria-group" id="edit_categoriaGroup">
                                        <% if (categorias && categorias.length > 0) { %>
                                            <% categorias.forEach(cat => { %>
                                                <div class="categoria-badge" data-categoria="<%= cat.categoria %>"><%= cat.categoria %></div>
                                            <% }) %>
                                        <% } %>
                                        <div class="categoria-badge" data-categoria="Otros">Otros</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control" name="categoria" id="edit_categoria" placeholder="O escribe una categoría personalizada">
                                </div>
                            </div>
                        </div>
                    </div>
