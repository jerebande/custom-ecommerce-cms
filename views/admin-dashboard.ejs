            const catDefault = document.getElementById('categoryPreviewDefault');
            if (catDefault) {
                catDefault.style.background = categoryBg;
                catDefault.style.borderColor = categoryBorder;
                catDefault.style.color = categoryText;
            }
            const catSelected = document.getElementById('categoryPreviewSelected');
            if (catSelected) {
                catSelected.style.background = gc;
                catSelected.style.color = '#ffffff';
                catSelected.style.borderColor = 'transparent';
            }
            const panelPreview = document.getElementById('panelPreviewCard');
            if (panelPreview) {
                panelPreview.style.background = gpanel;
                panelPreview.style.borderColor = panelBorder;
            }

            // Vista por secciones reales (consistencia)
            ['sectionPreviewHome', 'sectionPreviewProducts', 'sectionPreviewOrders'].forEach(id => {
                const wrap = document.getElementById(id);
                if (!wrap) return;
                wrap.style.borderColor = panelBorder;
                const header = wrap.querySelector('.sp-header');
                const body = wrap.querySelector('.sp-body');
                if (header) header.style.background = gs;
                if (body) body.style.background = gpanel;
            });
            const sectionChip = document.querySelector('#sectionPreviewHome .sp-chip');
            if (sectionChip) {
                sectionChip.style.background = categoryBg;
                sectionChip.style.borderColor = categoryBorder;
                sectionChip.style.color = categoryText;
            }
            const sectionBtn = document.querySelector('#sectionPreviewProducts .sp-btn');
            if (sectionBtn) {
                sectionBtn.style.background = gb;
                sectionBtn.style.color = bt;
            }

            // Vista previa general
            const gNav = document.getElementById('globalPreviewNavbar');
            if (gNav) gNav.style.background = useGrad ? gp : nbg;
            const gLogo = document.getElementById('globalPreviewLogo');
            if (gLogo) gLogo.style.color = useGrad ? '#fff' : logo;
            const gLink = document.getElementById('globalPreviewNavLink');
            if (gLink) gLink.style.color = useGrad ? 'rgba(255,255,255,0.92)' : nl;
            const gHero = document.getElementById('globalPreviewHero');
            if (gHero) gHero.style.background = gs;
            const gBtn = document.getElementById('globalPreviewButton');
            if (gBtn) { gBtn.style.background = gb; gBtn.style.color = bt; }
            const gCat = document.getElementById('globalPreviewCategory');
            if (gCat) {
                gCat.style.background = gc;
                gCat.style.color = '#fff';
                gCat.style.borderColor = 'transparent';
            }
            const gCard = document.getElementById('globalPreviewCard');
            if (gCard) {
                gCard.style.background = gpanel;
                gCard.style.borderColor = panelBorder;
            }

            // Footer preview
            updateFooterPreview();
            updateFooterIconPreview();

            // Banner text preview
            const bannerT = getHex('bannerTitleColor') || COLOR_DEFAULTS.bannerTitleColor;
            const bannerS = getHex('bannerSubtitleColor') || COLOR_DEFAULTS.bannerSubtitleColor;
            const bannerPrev = document.getElementById('bannerTextPreview');
            if (bannerPrev) bannerPrev.style.background = gs;
            const bannerTP = document.getElementById('bannerTitlePreview');
            if (bannerTP) bannerTP.style.color = bannerT;
            const bannerSP = document.getElementById('bannerSubtitlePreview');
            if (bannerSP) bannerSP.style.color = bannerS;
        }

        function syncColorField(field) {
            const picker = document.getElementById('cp_' + field);
            const hex    = document.getElementById('cp_' + field + '_hex');
            if (!picker || !hex) return;
            picker.addEventListener('input', () => { hex.value = picker.value; updateAllPreviews(); });
            hex.addEventListener('input', () => {
                const v = hex.value.trim();
                if (/^#[0-9a-fA-F]{6}$/.test(v)) { picker.value = v; updateAllPreviews(); }
            });
        }

        async function cargarColoresGuardados() {
            try {
                const res = await fetch('/admin/api/colores-config');
                if (!res.ok) return;
                const data = await res.json();
                const c = data.colores || {};
                COLOR_HEX_FIELDS.forEach(f => setHex(f, c[f] || COLOR_DEFAULTS[f]));
                // Radio buttons
                const usesGrad = (c.navbarUsesGradient === 'true' || c.navbarUsesGradient === true);
                if (document.getElementById('navbarStyleGradient')) {
                    document.getElementById('navbarStyleGradient').checked = usesGrad;
                    document.getElementById('navbarStyleSolid').checked = !usesGrad;
                }
                document.getElementById('sectionMode1').checked = (c.sectionColorMode || COLOR_DEFAULTS.sectionColorMode) === '1';
                document.getElementById('sectionMode2').checked = (c.sectionColorMode || COLOR_DEFAULTS.sectionColorMode) === '2';
                document.getElementById('sectionMode3').checked = (c.sectionColorMode || COLOR_DEFAULTS.sectionColorMode) === '3';
                document.getElementById('textMode1').checked = (c.textColorMode || COLOR_DEFAULTS.textColorMode) === '1';
                document.getElementById('textMode2').checked = (c.textColorMode || COLOR_DEFAULTS.textColorMode) === '2';
                document.getElementById('textMode3').checked = (c.textColorMode || COLOR_DEFAULTS.textColorMode) === '3';
                document.getElementById('buttonMode1').checked = (c.btnColorMode || COLOR_DEFAULTS.btnColorMode) === '1';
                document.getElementById('buttonMode2').checked = (c.btnColorMode || COLOR_DEFAULTS.btnColorMode) === '2';
                document.getElementById('buttonMode3').checked = (c.btnColorMode || COLOR_DEFAULTS.btnColorMode) === '3';
                document.getElementById('categoryMode1').checked = (c.categoryColorMode || COLOR_DEFAULTS.categoryColorMode) === '1';
                document.getElementById('categoryMode2').checked = (c.categoryColorMode || COLOR_DEFAULTS.categoryColorMode) === '2';
                document.getElementById('categoryMode3').checked = (c.categoryColorMode || COLOR_DEFAULTS.categoryColorMode) === '3';
                document.getElementById('panelMode1').checked = (c.panelColorMode || COLOR_DEFAULTS.panelColorMode) === '1';
                document.getElementById('panelMode2').checked = (c.panelColorMode || COLOR_DEFAULTS.panelColorMode) === '2';
                document.getElementById('panelMode3').checked = (c.panelColorMode || COLOR_DEFAULTS.panelColorMode) === '3';
                // Footer icon mode
                const fim = c.footerIconMode || COLOR_DEFAULTS.footerIconMode;
                if (document.getElementById('footerIconBrand')) {
                    document.getElementById('footerIconBrand').checked = fim === 'brand';
                    document.getElementById('footerIconCustom').checked = fim === 'custom';
                    document.getElementById('footerIconCustomFields').style.display = fim === 'custom' ? '' : 'none';
                }
                updateAllPreviews();
            } catch(e) { console.warn('Sin config de colores, usando defaults'); updateAllPreviews(); }
        }

        // ══════════════ FOOTER PREVIEWS ══════════════
        function updateFooterPreview() {
            const fbg  = getHex('footerBg')        || COLOR_DEFAULTS.footerBg;
            const ftxt = getHex('footerText')       || COLOR_DEFAULTS.footerText;
            const fh   = getHex('footerHeading')    || COLOR_DEFAULTS.footerHeading;
            const fl   = getHex('footerLink')       || COLOR_DEFAULTS.footerLink;

            const card = document.getElementById('footerPreviewCard');
            if (card) card.style.background = fbg;
            const heading = document.getElementById('fpHeading');
            if (heading) heading.style.color = fh;
            const text = document.getElementById('fpText');
            if (text) text.style.color = ftxt;
            const link = document.getElementById('fpLink');
            if (link) link.style.color = fl;
        }

        function updateFooterIconPreview() {
            const isBrand = document.getElementById('footerIconBrand')?.checked;
            const customFields = document.getElementById('footerIconCustomFields');
            if (customFields) customFields.style.display = isBrand ? 'none' : '';

            const BRAND = {
                facebook:  '#1877F2',
                instagram: 'linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888)',
                whatsapp:  '#25D366',
                twitter:   '#1DA1F2',
                youtube:   '#FF0000',
                linkedin:  '#0A66C2',
                tiktok:    '#010101'
            };
            const ICONS = {
                facebook: 'fab fa-facebook-f',
                instagram: 'fab fa-instagram',
                whatsapp: 'fab fa-whatsapp',
                twitter: 'fab fa-twitter',
                youtube: 'fab fa-youtube',
                linkedin: 'fab fa-linkedin-in',
                tiktok: 'fab fa-tiktok'
            };
            const ic1 = getHex('footerIconBg1') || COLOR_DEFAULTS.footerIconBg1;
            const ic2 = getHex('footerIconBg2') || COLOR_DEFAULTS.footerIconBg2;
            const customBg = 'linear-gradient(135deg,' + ic1 + ' 0%,' + ic2 + ' 100%)';

            const row = document.getElementById('socialIconPreviewRow');
            if (!row) return;
            row.innerHTML = Object.entries(ICONS).map(([net, cls]) => {
                const bg = isBrand ? BRAND[net] : customBg;
                const border = net === 'tiktok' && isBrand ? 'border:1px solid #444;' : '';
                return `<div style="width:40px;height:40px;border-radius:50%;background:${bg};display:inline-flex;align-items:center;justify-content:center;${border}" title="${net}">
                    <i class="${cls}" style="color:white;font-size:16px;"></i>
                </div>`;
            }).join('');
        }

        // syncear inputs de color de íconos footer con preview
        ['footerIconBg1','footerIconBg2'].forEach(f => {
            document.addEventListener('input', e => {
                if (e.target.id === 'cp_' + f || e.target.id === 'cp_' + f + '_hex') {
                    updateFooterIconPreview();
                }
            });
        });
        ['footerBg','footerText','footerHeading','footerLink','footerLinkHover'].forEach(f => {
            document.addEventListener('input', e => {
                if (e.target.id === 'cp_' + f || e.target.id === 'cp_' + f + '_hex') {
                    updateFooterPreview();
                }
            });
        });

        async function guardarColores() {
            const colores = {};
            COLOR_HEX_FIELDS.forEach(f => { colores[f] = getHex(f) || COLOR_DEFAULTS[f]; });
            colores.navbarUsesGradient = isGradientNav() ? 'true' : 'false';
            colores.sectionColorMode = getModeValue('sectionColorMode', COLOR_DEFAULTS.sectionColorMode);
            colores.textColorMode = getModeValue('textColorMode', COLOR_DEFAULTS.textColorMode);
            colores.btnColorMode = getModeValue('buttonColorMode', COLOR_DEFAULTS.btnColorMode);
            colores.categoryColorMode = getModeValue('categoryColorMode', COLOR_DEFAULTS.categoryColorMode);
            colores.panelColorMode = getModeValue('panelColorMode', COLOR_DEFAULTS.panelColorMode);
            colores.footerIconMode = getModeValue('footerIconMode', COLOR_DEFAULTS.footerIconMode);
            try {
                const res = await fetch('/admin/api/colores-config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ colores })
                });
                const data = await res.json();
                if (data.success) {
                    const msg = document.getElementById('colorSaveMsg');
                    if (msg) { msg.style.display = 'inline'; setTimeout(() => msg.style.display = 'none', 4000); }
                    mostrarNotificacion('success', '¡Colores guardados! Los cambios ya se ven en la tienda.');
                } else {
                    mostrarNotificacion('error', data.error || 'Error al guardar colores');
                }
            } catch(e) { mostrarNotificacion('error', 'Error de conexión'); }
        }

        function resetColores() {
            if (!confirm('¿Restaurar todos los colores a los valores predeterminados?')) return;
            COLOR_HEX_FIELDS.forEach(f => setHex(f, COLOR_DEFAULTS[f]));
            if (document.getElementById('navbarStyleSolid')) {
                document.getElementById('navbarStyleSolid').checked = true;
                document.getElementById('navbarStyleGradient').checked = false;
            }
            document.getElementById('sectionMode2').checked = true;
            document.getElementById('textMode1').checked = true;
            document.getElementById('buttonMode2').checked = true;
            document.getElementById('categoryMode2').checked = true;
            document.getElementById('panelMode1').checked = true;
            if (document.getElementById('footerIconBrand')) {
                document.getElementById('footerIconBrand').checked = true;
                document.getElementById('footerIconCustom').checked = false;
                document.getElementById('footerIconCustomFields').style.display = 'none';
            }
            updateAllPreviews();
        }

        // Inicializar sincronizadores y cargar colores guardados
        document.addEventListener('DOMContentLoaded', () => {
            COLOR_HEX_FIELDS.forEach(syncColorField);
            cargarColoresGuardados();
        });

        mostrarTab('dashboard');

        // ==================== CONFIGURACIÓN PEDIDOS ====================
        let pedidosConfig = {};

        function selectModo(modo) {
            document.querySelectorAll('.modo-card').forEach(c => c.classList.remove('selected'));
            document.getElementById('modo-' + modo)?.classList.add('selected');
            document.getElementById('modoOperacion').value = modo;
            // Show/hide dirección local card
            const showLocal = modo === 'retiro' || modo === 'hibrido';
            const card = document.getElementById('cardDireccionLocal');
            if (card) card.style.display = showLocal ? '' : 'none';
        }

        function toggleTarifaBody(bodyId, show) {
            const el = document.getElementById(bodyId);
            if (el) el.style.display = show ? 'block' : 'none';
            updateCheckoutPreview();
        }

        function updateEnvioPreview() {
            const tipo = document.getElementById('envioTipo')?.value;
            const valor = parseFloat(document.getElementById('envioValor')?.value) || 0;
            const label = document.getElementById('envioLabel')?.value || 'Envío';
            const gratisDesdeWrap = document.getElementById('envioGratisDesdeWrap');
            const valorLabel = document.getElementById('envioValorLabel');
            if (tipo === 'gratis_desde') {
                if (gratisDesdeWrap) gratisDesdeWrap.style.display = '';
                if (valorLabel) valorLabel.textContent = 'Monto base ($)';
            } else {
                if (gratisDesdeWrap) gratisDesdeWrap.style.display = 'none';
                if (valorLabel) valorLabel.textContent = tipo === 'porcentaje' ? 'Porcentaje (%)' : 'Monto ($)';
            }
            const txt = tipo === 'porcentaje' ? `${label}: ${valor}% del total` : tipo === 'gratis_desde' ? `${label}: $${valor.toFixed(2)} (gratis desde $${parseFloat(document.getElementById('envioGratisDesde')?.value)||0})` : `${label}: $${valor.toFixed(2)}`;
            const preview = document.getElementById('envioPreviewText');
            if (preview) preview.textContent = txt;
            updateCheckoutPreview();
        }

        function updateCheckoutPreview() {
            const subtotal = 1500;
            let total = subtotal;

            // Envío
            const envioOn = document.getElementById('envioActivo')?.checked;
            const prevEnvioRow = document.getElementById('prevEnvioRow');
            if (envioOn && prevEnvioRow) {
                prevEnvioRow.style.display = 'flex';
                const tipo = document.getElementById('envioTipo')?.value;
                const valor = parseFloat(document.getElementById('envioValor')?.value) || 0;
                const label = document.getElementById('envioLabel')?.value || 'Envío';
                document.getElementById('prevEnvioLabel').textContent = label;
                const monto = tipo === 'porcentaje' ? subtotal * valor / 100 : valor;
                document.getElementById('prevEnvioMonto').textContent = '$' + monto.toLocaleString('es-AR', {minimumFractionDigits:2});
                total += monto;
            } else if (prevEnvioRow) { prevEnvioRow.style.display = 'none'; }

            // Impuesto
            const impOn = document.getElementById('impuestoActivo')?.checked;
            const prevImpRow = document.getElementById('prevImpRow');
            if (impOn && prevImpRow) {
                prevImpRow.style.display = 'flex';
                const pct = parseFloat(document.getElementById('impuestoPorcentaje')?.value) || 0;
                const label = document.getElementById('impuestoLabel')?.value || 'IVA';
                const incluido = document.getElementById('impuestoIncluido')?.value === 'si';
                document.getElementById('prevImpLabel').textContent = label + (incluido ? ' (incluido)' : '');
                const monto = incluido ? 0 : subtotal * pct / 100;
                document.getElementById('prevImpMonto').textContent = incluido ? 'Incluido' : '$' + monto.toLocaleString('es-AR', {minimumFractionDigits:2});
                total += monto;
            } else if (prevImpRow) { prevImpRow.style.display = 'none'; }

            // Extra
            const extraOn = document.getElementById('extraActivo')?.checked;
            const prevExtraRow = document.getElementById('prevExtraRow');
            if (extraOn && prevExtraRow) {
                prevExtraRow.style.display = 'flex';
                const nombre = document.getElementById('extraNombre')?.value || 'Cargo extra';
                const tipo = document.getElementById('extraTipo')?.value;
                const valor = parseFloat(document.getElementById('extraValor')?.value) || 0;
                document.getElementById('prevExtraLabel').textContent = nombre;
                const monto = tipo === 'porcentaje' ? subtotal * valor / 100 : valor;
                document.getElementById('prevExtraMonto').textContent = '$' + monto.toLocaleString('es-AR', {minimumFractionDigits:2});
                total += monto;
            } else if (prevExtraRow) { prevExtraRow.style.display = 'none'; }

            const prevTotal = document.getElementById('prevTotal');
            if (prevTotal) prevTotal.textContent = '$' + total.toLocaleString('es-AR', {minimumFractionDigits:2});
        }

        // Listen to all tarifa inputs for live preview
        ['impuestoPorcentaje','impuestoLabel','impuestoIncluido','extraNombre','extraTipo','extraValor'].forEach(id => {
            document.getElementById(id)?.addEventListener('input', updateCheckoutPreview);
            document.getElementById(id)?.addEventListener('change', updateCheckoutPreview);
        });
        document.getElementById('envioTipo')?.addEventListener('change', updateEnvioPreview);

