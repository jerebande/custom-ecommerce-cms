        async function cargarConfigPedidos() {
            try {
                const res = await fetch('/admin/api/pedidos-config');
                const data = await res.json();
                if (data.success && data.config) {
                    const c = data.config;
                    selectModo(c.modoOperacion || 'hibrido');
                    if (document.getElementById('direccionLocal')) document.getElementById('direccionLocal').value = c.direccionLocal || '';
                    if (document.getElementById('horarioLocal')) document.getElementById('horarioLocal').value = c.horarioLocal || '';
                    if (document.getElementById('indicacionesLocal')) document.getElementById('indicacionesLocal').value = c.indicacionesLocal || '';
                    const t = c.tarifas || {};
                    if (t.envio) {
                        if (document.getElementById('envioActivo')) { document.getElementById('envioActivo').checked = t.envio.activo; toggleTarifaBody('envioBody', t.envio.activo); }
                        if (document.getElementById('envioTipo')) document.getElementById('envioTipo').value = t.envio.tipo || 'fijo';
                        if (document.getElementById('envioValor')) document.getElementById('envioValor').value = t.envio.valor || 0;
                        if (document.getElementById('envioGratisDesde')) document.getElementById('envioGratisDesde').value = t.envio.gratisDesde || 0;
                        if (document.getElementById('envioLabel')) document.getElementById('envioLabel').value = t.envio.label || 'Costo de envío';
                        updateEnvioPreview();
                    }
                    if (t.impuesto) {
                        if (document.getElementById('impuestoActivo')) { document.getElementById('impuestoActivo').checked = t.impuesto.activo; toggleTarifaBody('impuestoBody', t.impuesto.activo); }
                        if (document.getElementById('impuestoPorcentaje')) document.getElementById('impuestoPorcentaje').value = t.impuesto.porcentaje || 0;
                        if (document.getElementById('impuestoLabel')) document.getElementById('impuestoLabel').value = t.impuesto.label || 'IVA';
                        if (document.getElementById('impuestoIncluido')) document.getElementById('impuestoIncluido').value = t.impuesto.incluido ? 'si' : 'no';
                    }
                    if (t.extra) {
                        if (document.getElementById('extraActivo')) { document.getElementById('extraActivo').checked = t.extra.activo; toggleTarifaBody('extraBody', t.extra.activo); }
                        if (document.getElementById('extraNombre')) document.getElementById('extraNombre').value = t.extra.nombre || '';
                        if (document.getElementById('extraTipo')) document.getElementById('extraTipo').value = t.extra.tipo || 'fijo';
                        if (document.getElementById('extraValor')) document.getElementById('extraValor').value = t.extra.valor || 0;
                    }
                    updateCheckoutPreview();
                }
            } catch(e) { console.warn('Sin config de pedidos guardada'); selectModo('hibrido'); }
        }

        document.addEventListener('DOMContentLoaded', () => { cargarConfigPedidos(); });
    </script>
    
    <!-- Incluir el archivo de paginación y filtros -->
    <script src="/js/admin-pagination.js"></script>
</body>
</html>