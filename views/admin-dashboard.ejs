    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Función de formateo para JavaScript (cliente)
        function formatNumberClient(num) {
            if (num === undefined || num === null || isNaN(num)) return '$0';
            const number = parseFloat(num);
            if (number >= 1000000) {
                return '$' + (number / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
            }
            if (number >= 10000) {
                // Show without decimals to keep it compact
                return '$' + Math.round(number).toLocaleString('es-AR');
            }
            return '$' + number.toLocaleString('es-AR', {
                minimumFractionDigits: 0,
                maximumFractionDigits: 2
            });
        }

        // Auto-shrink stats numbers that overflow their container
        function fitStatsNumbers() {
            document.querySelectorAll('.stats-number').forEach(el => {
                el.style.fontSize = '';
                let size = parseFloat(getComputedStyle(el).fontSize);
                while (el.scrollWidth > el.offsetWidth && size > 12) {
                    size -= 1;
                    el.style.fontSize = size + 'px';
                }
            });
        }
        window.addEventListener('load', fitStatsNumbers);
        window.addEventListener('resize', fitStatsNumbers);

        let productoAEliminar = null;
        let productosData = <%- JSON.stringify(productos || []) %>;
        const usuariosData = <%- JSON.stringify(usuarios || []) %>;
        const todosLosPedidos = <%- JSON.stringify(pedidos || []) %>;
        const ventasData = <%- JSON.stringify(ventas || []) %>;
        
        let ventasChartLine = null;
        let ventasChartBar = null;
        let ventasDiariasChart = null;

        document.addEventListener('DOMContentLoaded', function() {
            inicializarGraficos();
        });
        
        function inicializarGraficos() {
            const ventasDataSorted = [...ventasData].sort((a, b) => a.dia.localeCompare(b.dia));
            
            const ctxLine = document.getElementById('ventasChartLine');
            if (ctxLine && ventasDataSorted && ventasDataSorted.length > 0) {
                if (ventasChartLine) ventasChartLine.destroy();
                ventasChartLine = new Chart(ctxLine, {
                    type: 'line',
                    data: {
                        labels: ventasDataSorted.map(v => new Date(v.dia).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' })),
                        datasets: [{
                            label: 'Ventas ($)',
                            data: ventasDataSorted.map(v => parseFloat(v.ventas) || 0),
                            borderColor: '#667eea',
                            backgroundColor: 'rgba(102,126,234,0.1)',
                            borderWidth: 3,
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: true, aspectRatio: 2.5 }
                });
            }
            
            const ctxBar = document.getElementById('ventasChartBar');
            if (ctxBar && ventasDataSorted && ventasDataSorted.length > 0) {
                if (ventasChartBar) ventasChartBar.destroy();
                ventasChartBar = new Chart(ctxBar, {
                    type: 'bar',
                    data: {
                        labels: ventasDataSorted.map(v => new Date(v.dia).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' })),
                        datasets: [{
                            label: 'Ventas ($)',
                            data: ventasDataSorted.map(v => parseFloat(v.ventas) || 0),
                            backgroundColor: 'rgba(102,126,234,0.7)',
                            borderRadius: 8
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: true, aspectRatio: 2.5 }
                });
            }
        }

        // ==================== FUNCIONES DE VENTAS ====================
        function filtrarPedidosPorDias(dias) {
            const hoy = new Date();
            hoy.setHours(23,59,59,999);
            const desde = new Date();
            desde.setDate(desde.getDate() - dias + 1);
            desde.setHours(0,0,0,0);
            return todosLosPedidos.filter(p => {
                const f = new Date(p.fecha);
                return f >= desde && f <= hoy;
            });
        }

        function filtrarPedidosPorFecha(fechaStr) {
            return todosLosPedidos.filter(p => {
                const f = new Date(p.fecha);
                const y = f.getFullYear();
                const m = String(f.getMonth()+1).padStart(2,'0');
                const d = String(f.getDate()).padStart(2,'0');
                return `${y}-${m}-${d}` === fechaStr;
            });
        }

        function agruparPedidosPorDia(lista) {
            const mapa = {};
            lista.forEach(p => {
                const key = new Date(p.fecha).toISOString().split('T')[0];
                if (!mapa[key]) mapa[key] = { dia: key, total_pedidos: 0, ventas: 0 };
                mapa[key].total_pedidos++;
                mapa[key].ventas += parseFloat(p.total) || 0;
            });
            return Object.values(mapa).sort((a,b) => a.dia.localeCompare(b.dia));
        }

        function agruparPedidosPorHora(lista) {
            const mapa = {};
            for (let h = 0; h < 24; h++) mapa[h] = { hora: h, total_pedidos: 0, ventas: 0 };
            lista.forEach(p => {
                const h = new Date(p.fecha).getHours();
                mapa[h].total_pedidos++;
                mapa[h].ventas += parseFloat(p.total) || 0;
            });
            return Object.values(mapa);
        }

        function actualizarVistasVentas(pedidosFiltrados, tituloLabel, modoHora = false) {
            const totalVentas = pedidosFiltrados.reduce((s,p) => s + (parseFloat(p.total)||0), 0);
            const totalPedidos = pedidosFiltrados.length;
            const entregados = pedidosFiltrados.filter(p => p.estado === 'entregado').length;
            const promedio = totalPedidos > 0 ? totalVentas / totalPedidos : 0;
            
            document.getElementById('ventasFiltradas').innerHTML = formatNumberClient(totalVentas);
            document.getElementById('pedidosFiltrados').textContent = totalPedidos;
            document.getElementById('promedioFiltrado').innerHTML = formatNumberClient(promedio);
            document.getElementById('entregadosFiltrados').textContent = entregados;
            document.getElementById('labelVentasFiltradas').textContent = 'Ventas ' + tituloLabel;
            document.getElementById('tituloGraficoVentas').innerHTML = '<i class="fas fa-chart-bar"></i> Ventas - ' + tituloLabel;
            document.getElementById('tituloTablaVentas').innerHTML = '<i class="fas fa-table"></i> Detalle - ' + tituloLabel;
            
            const agrupados = modoHora ? agruparPedidosPorHora(pedidosFiltrados) : agruparPedidosPorDia(pedidosFiltrados);
            const chartLabels = modoHora ? agrupados.map(v => `${String(v.hora).padStart(2,'0')}:00`) : agrupados.map(v => new Date(v.dia + 'T12:00:00').toLocaleDateString('es-ES', { weekday: 'short', day:'2-digit', month:'short' }));
            const chartVentas = agrupados.map(v => parseFloat(v.ventas) || 0);
            const chartPedidos = agrupados.map(v => v.total_pedidos || 0);
            
            const wrapper = document.getElementById('ventasChartWrapper');
            if (wrapper) wrapper.className = modoHora ? 'chart-container-hora' : 'chart-container';
            wrapper.innerHTML = '<canvas id="ventasDiariasChart"></canvas>';
            
            const ctx = document.getElementById('ventasDiariasChart');
            if (ctx && agrupados.length > 0) {
                ventasDiariasChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: chartLabels,
                        datasets: [
                            { label: 'Ventas ($)', data: chartVentas, backgroundColor: modoHora ? 'rgba(102,126,234,0.7)' : 'rgba(16,185,129,0.7)', yAxisID: 'y' },
                            { label: 'Pedidos', data: chartPedidos, type: 'line', borderColor: '#f59e0b', borderWidth: 3, fill: false, yAxisID: 'y1' }
                        ]
                    },
                    options: modoHora ? { responsive: false, maintainAspectRatio: false, scales: { y: { beginAtZero: true }, y1: { beginAtZero: true, position: 'right' } } } 
                                   : { responsive: true, maintainAspectRatio: true, aspectRatio: 2.5 }
                });
            }
            
            const tbody = document.getElementById('tablaVentasBody');
            if (tbody && agrupados.length > 0) {
                tbody.innerHTML = [...agrupados].reverse().map(v => {
                    const fecha = modoHora ? `${String(v.hora).padStart(2,'0')}:00 - ${String(v.hora+1).padStart(2,'0')}:00` : new Date(v.dia + 'T12:00:00').toLocaleDateString('es-ES');
                    return `<tr><td>${fecha}</td><td>${v.total_pedidos} pedido(s)</td><td class="sales-total">${formatNumberClient(v.ventas)}</td></tr>`;
                }).join('');
            } else if (tbody) {
                tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">Sin datos</td></tr>';
            }
        }

        document.querySelectorAll('#periodoFiltros .btn-periodo').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('#periodoFiltros .btn-periodo').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                document.getElementById('fechaEspecifica').value = '';
                document.getElementById('btnLimpiarFecha').style.display = 'none';
                const dias = parseInt(this.getAttribute('data-dias'));
                actualizarVistasVentas(filtrarPedidosPorDias(dias), this.textContent, dias === 1);
            });
        });
        
        document.getElementById('btnFechaEspecifica')?.addEventListener('click', function() {
            const fecha = document.getElementById('fechaEspecifica').value;
            if (!fecha) return;
            document.querySelectorAll('#periodoFiltros .btn-periodo').forEach(b => b.classList.remove('active'));
            document.getElementById('btnLimpiarFecha').style.display = '';
            actualizarVistasVentas(filtrarPedidosPorFecha(fecha), fecha, true);
        });
        
        document.getElementById('btnLimpiarFecha')?.addEventListener('click', function() {
            document.getElementById('fechaEspecifica').value = '';
            this.style.display = 'none';
            const btn7 = document.querySelector('#periodoFiltros .btn-periodo[data-dias="7"]');
            if (btn7) btn7.click();
        });

        // ==================== FUNCIONES DE NAVEGACIÓN ====================
        function mostrarTab(tabId) {
            document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.remove('active'));
            const tabPane = document.getElementById(`tab-${tabId}`);
            if (tabPane) tabPane.classList.add('active');
            
            document.querySelectorAll('.sidebar .nav-link-custom').forEach(link => link.classList.remove('active'));
            const tabLink = document.querySelector(`.sidebar .nav-link-custom[data-tab="${tabId}"]`);
            if (tabLink) tabLink.classList.add('active');
            
            if (window.innerWidth <= 768) {
                document.getElementById('sidebar').classList.remove('active');
                document.getElementById('overlay').classList.remove('active');
            }
            
            if (tabId === 'ventas') setTimeout(() => actualizarVistasVentas(filtrarPedidosPorDias(7), 'Últimos 7 días', false), 50);
        }
        
        document.querySelectorAll('.sidebar .nav-link-custom[data-tab]').forEach(link => {
            link.addEventListener('click', (e) => {
                const targetTab = link.getAttribute('data-tab');
                if (!targetTab) return;
                e.preventDefault();
                mostrarTab(targetTab);
            });
        });
        
        // ==================== FUNCIONES DE PEDIDOS ====================
        window.cambiarEstadoAJAX = async function(selectElement) {
            const pedidoId = selectElement.getAttribute('data-pedido-id');
            const nuevoEstado = selectElement.value;
            const estadoAnterior = selectElement.getAttribute('data-current-status');
            
            if (!confirm(`¿Cambiar estado del pedido #${pedidoId}?`)) {
                selectElement.value = estadoAnterior;
                return;
            }
            selectElement.disabled = true;
            try {
                const formData = new URLSearchParams();
                formData.append('id', pedidoId);
                formData.append('estado', nuevoEstado);
                const response = await fetch('/admin/pedido/estado/ajax', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: formData });
                const data = await response.json();
                if (data.success) {
                    selectElement.setAttribute('data-current-status', nuevoEstado);
                    mostrarNotificacion('success', `Pedido #${pedidoId} actualizado`);
                    if (data.stats) {
                        document.getElementById('totalPedidos').textContent = data.stats.totalPedidos;
                        document.getElementById('ventasTotales').innerHTML = formatNumberClient(data.stats.ventasTotales);
                        document.getElementById('pedidosPendientes').textContent = data.stats.pedidosPendientes;
                        document.getElementById('pedidosEntregados').textContent = data.stats.pedidosEntregados;
                    }
                } else {
                    selectElement.value = estadoAnterior;
                    mostrarNotificacion('error', data.error || 'Error');
                }
            } catch(e) { selectElement.value = estadoAnterior; mostrarNotificacion('error', 'Error de conexión'); }
            finally { selectElement.disabled = false; }
        };
        
        function mostrarNotificacion(tipo, mensaje) {
            const toast = document.createElement('div');
            toast.className = `toast-notification alert alert-${tipo === 'success' ? 'success' : 'danger'}`;
            toast.innerHTML = `<strong>${tipo === 'success' ? '✓ Éxito' : '✗ Error'}</strong><br>${mensaje}<button type="button" class="btn-close float-end" onclick="this.parentElement.remove()"></button>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
        
        // ==================== FUNCIONES DE PRODUCTOS ====================
        window.editarProductoPorId = function(id) {
            const producto = productosData.find(p => p.id == id);
            if (producto) {
                document.getElementById('edit_id').value = producto.id;
                document.getElementById('edit_nombre').value = producto.nombre;
                document.getElementById('edit_descripcion').value = producto.descripcion || '';
                document.getElementById('edit_precio').value = producto.precio;
                document.getElementById('edit_precio_oferta').value = producto.precio_oferta || '';
                document.getElementById('edit_stock').value = producto.stock;
                document.getElementById('edit_categoria').value = producto.categoria;
                document.getElementById('edit_imagen').value = producto.imagen || '';
                document.getElementById('edit_currentImage').src = producto.imagen || '/uploads/default-product.png';
                document.getElementById('edit_imagePreview').style.display = 'none';
                document.getElementById('edit_imagenFile').value = '';
                new bootstrap.Modal(document.getElementById('editProductModal')).show();
            }
        };
        
        window.confirmDeleteProduct = function(id) {
            productoAEliminar = id;
            new bootstrap.Modal(document.getElementById('deleteConfirmModal')).show();
        };
        
        document.getElementById('confirmDeleteBtn')?.addEventListener('click', async function() {
            if (productoAEliminar) {
                try {
                    const response = await fetch(`/admin/productos/delete/${productoAEliminar}`, { method: 'DELETE' });
                    const data = await response.json();
                    if (data.success) {
                        mostrarNotificacion('success', 'Producto eliminado');
                        location.reload();
                    } else mostrarNotificacion('error', data.error);
                } catch(e) { mostrarNotificacion('error', 'Error'); }
                productoAEliminar = null;
            }
        });
        
        window.openAddProductModal = function() {
            document.getElementById('add_nombre').value = '';
            document.getElementById('add_descripcion').value = '';
            document.getElementById('add_precio').value = '';
            document.getElementById('add_stock').value = '';
            document.getElementById('add_categoria').value = '';
            document.getElementById('add_precio_oferta').value = '';
            document.getElementById('add_imagenFile').value = '';
            document.getElementById('add_imagePreview').style.display = 'none';
            new bootstrap.Modal(document.getElementById('addProductModal')).show();
        };
        
        window.previewAddImage = function(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { document.getElementById('add_imagePreview').src = e.target.result; document.getElementById('add_imagePreview').style.display = 'block'; };
                reader.readAsDataURL(input.files[0]);
            }
        };
        
        window.previewEditImage = function(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { document.getElementById('edit_imagePreview').src = e.target.result; document.getElementById('edit_imagePreview').style.display = 'block'; };
                reader.readAsDataURL(input.files[0]);
            }
        };
        
        window.filterProductosTab = function() {
            const search = document.getElementById('searchInputProductos').value.toLowerCase();
            const category = document.getElementById('categoryFilterProductos').value;
            document.querySelectorAll('#productosCardsContainer .data-card').forEach(card => {
                const nombre = (card.getAttribute('data-nombre') || '').toLowerCase();
                const cat = card.getAttribute('data-categoria') || '';
                card.style.display = (nombre.includes(search) && (category === 'todos' || cat === category)) ? '' : 'none';
            });
        };
        
        // ==================== FUNCIONES DE USUARIOS ====================
        window.editarUsuarioPorId = function(id) {
            const usuario = usuariosData.find(u => u.id == id);
            if (usuario) {
                document.getElementById('editUsuarioId').value = usuario.id;
                document.getElementById('editUsuarioNombre').value = usuario.nombre;
                document.getElementById('editUsuarioEmail').value = usuario.email;
                document.getElementById('editUsuarioRol').value = usuario.rol;
                new bootstrap.Modal(document.getElementById('modalEditarUsuario')).show();
            }
        };
        
        window.guardarUsuarioRol = async function() {
            const id = document.getElementById('editUsuarioId').value;
            const rol = document.getElementById('editUsuarioRol').value;
            try {
                const response = await fetch('/admin/usuarios/update-rol', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, rol }) });
                const data = await response.json();
                if (data.success) { mostrarNotificacion('success', 'Rol actualizado'); setTimeout(() => location.reload(), 1000); }
                else mostrarNotificacion('error', data.error);
            } catch(e) { mostrarNotificacion('error', 'Error'); }
        };
        
        // Mobile menu
        document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('overlay').classList.toggle('active');
        });
        document.getElementById('overlay')?.addEventListener('click', () => {
            document.getElementById('sidebar').classList.remove('active');
            document.getElementById('overlay').classList.remove('active');
        });
        

        // ==================== FUNCIONES DE COLORES ====================
        const COLOR_DEFAULTS = {
            primary: '#667eea',
            secondary: '#764ba2',
            bodyBg: '#f5f7fb',
            textColor: '#2d3748',
            navbarBg: '#ffffff',
            navbarUsesGradient: 'false',
            logoTextColor: '#667eea',
            navLinkColor: '#2d3748',
            navLinkHover: '#ffffff',
            btnBg1: '#667eea',
            btnBg2: '#764ba2',
            btnBg3: '#4f46e5',
            btnTextColor: '#ffffff',
            iconColor: '#667eea',
            iconColor2: '#764ba2',
            categoryBg: '#f7fafc',
            categoryBorder: '#e2e8f0',
            categoryText: '#2d3748',
            categoryColorMode: '2',
            categorySelected1: '#667eea',
            categorySelected2: '#764ba2',
            categorySelected3: '#4f46e5',
            panelColorMode: '1',
            panelColor1: '#ffffff',
            panelColor2: '#f8fafc',
            panelColor3: '#eef2ff',
            panelBorder: '#e2e8f0',
            sectionColorMode: '2',
            sectionColor1: '#667eea',
            sectionColor2: '#764ba2',
            sectionColor3: '#4f46e5',
            textColorMode: '1',
            textColor1: '#2d3748',
            textColor2: '#667eea',
            textColor3: '#764ba2',
            btnColorMode: '2',
            /* ── Footer ── */
            footerBg: '#2d3748',
            footerText: '#cbd5e0',
            footerHeading: '#ffffff',
            footerLink: '#cbd5e0',
            footerLinkHover: '#ffffff',
            footerIconMode: 'brand',
            footerIconBg1: '#667eea',
            footerIconBg2: '#764ba2',
            /* ── Banner text ── */
            bannerTitleColor: '#ffffff',
            bannerSubtitleColor: '#ffffff'
        };

        // Campos que tienen picker + hex (excluir los radio buttons)
        const COLOR_HEX_FIELDS = [
            'primary','secondary','bodyBg','textColor',
            'navbarBg','logoTextColor','navLinkColor','navLinkHover',
            'btnBg1','btnBg2','btnBg3','btnTextColor',
            'iconColor','iconColor2',
            'sectionColor1','sectionColor2','sectionColor3',
            'textColor1','textColor2','textColor3',
            'categoryBg','categoryBorder','categoryText',
            'categorySelected1','categorySelected2','categorySelected3',
            'panelColor1','panelColor2','panelColor3','panelBorder',
            /* Footer */
            'footerBg','footerText','footerHeading','footerLink','footerLinkHover',
            'footerIconBg1','footerIconBg2',
            /* Banner text */
            'bannerTitleColor','bannerSubtitleColor'
        ];

        function getHex(field) {
            return (document.getElementById('cp_' + field + '_hex')?.value || '').trim();
        }
        function setHex(field, val) {
            const p = document.getElementById('cp_' + field);
            const h = document.getElementById('cp_' + field + '_hex');
            if (p) p.value = val;
            if (h) h.value = val;
        }
        function isGradientNav() {
            return document.getElementById('navbarStyleGradient')?.checked === true;
        }
        function getModeValue(name, fallback) {
            return document.querySelector(`input[name="${name}"]:checked`)?.value || fallback;
        }
        function buildColorByMode(mode, c1, c2, c3) {
            if (mode === '1') return c1;
            if (mode === '3') return `linear-gradient(135deg,${c1} 0%,${c2} 50%,${c3} 100%)`;
            return `linear-gradient(135deg,${c1} 0%,${c2} 100%)`;
        }

        function applyNavHover(el) {
            const p1 = getHex('primary') || COLOR_DEFAULTS.primary;
            const p2 = getHex('secondary') || COLOR_DEFAULTS.secondary;
            const hoverText = getHex('navLinkHover') || COLOR_DEFAULTS.navLinkHover;
            el.style.background = 'linear-gradient(135deg,' + p1 + ' 0%,' + p2 + ' 100%)';
            el.style.color = hoverText;
        }
        function removeNavHover(el) {
            el.style.background = 'transparent';
            el.style.color = getHex('navLinkColor') || COLOR_DEFAULTS.navLinkColor;
        }

        function updateAllPreviews() {
            const p1  = getHex('primary')       || COLOR_DEFAULTS.primary;
            const p2  = getHex('secondary')     || COLOR_DEFAULTS.secondary;
            const nbg = getHex('navbarBg')      || COLOR_DEFAULTS.navbarBg;
            const logo= getHex('logoTextColor') || COLOR_DEFAULTS.logoTextColor;
            const nl  = getHex('navLinkColor')  || COLOR_DEFAULTS.navLinkColor;
            const b1  = getHex('btnBg1')        || COLOR_DEFAULTS.btnBg1;
            const b2  = getHex('btnBg2')        || COLOR_DEFAULTS.btnBg2;
            const b3  = getHex('btnBg3')        || COLOR_DEFAULTS.btnBg3;
            const bt  = getHex('btnTextColor')  || COLOR_DEFAULTS.btnTextColor;
            const ic1 = getHex('iconColor')     || COLOR_DEFAULTS.iconColor;
            const ic2 = getHex('iconColor2')    || COLOR_DEFAULTS.iconColor2;
            const useGrad = isGradientNav();
            const sectionMode = getModeValue('sectionColorMode', COLOR_DEFAULTS.sectionColorMode);
            const sectionC1 = getHex('sectionColor1') || COLOR_DEFAULTS.sectionColor1;
            const sectionC2 = getHex('sectionColor2') || COLOR_DEFAULTS.sectionColor2;
            const sectionC3 = getHex('sectionColor3') || COLOR_DEFAULTS.sectionColor3;
            const textMode = getModeValue('textColorMode', COLOR_DEFAULTS.textColorMode);
            const textC1 = getHex('textColor1') || COLOR_DEFAULTS.textColor1;
            const textC2 = getHex('textColor2') || COLOR_DEFAULTS.textColor2;
            const textC3 = getHex('textColor3') || COLOR_DEFAULTS.textColor3;
            const btnMode = getModeValue('buttonColorMode', COLOR_DEFAULTS.btnColorMode);
            const categoryMode = getModeValue('categoryColorMode', COLOR_DEFAULTS.categoryColorMode);
            const categoryBg = getHex('categoryBg') || COLOR_DEFAULTS.categoryBg;
            const categoryBorder = getHex('categoryBorder') || COLOR_DEFAULTS.categoryBorder;
            const categoryText = getHex('categoryText') || COLOR_DEFAULTS.categoryText;
            const categoryS1 = getHex('categorySelected1') || COLOR_DEFAULTS.categorySelected1;
            const categoryS2 = getHex('categorySelected2') || COLOR_DEFAULTS.categorySelected2;
            const categoryS3 = getHex('categorySelected3') || COLOR_DEFAULTS.categorySelected3;
            const panelMode = getModeValue('panelColorMode', COLOR_DEFAULTS.panelColorMode);
            const panelC1 = getHex('panelColor1') || COLOR_DEFAULTS.panelColor1;
            const panelC2 = getHex('panelColor2') || COLOR_DEFAULTS.panelColor2;
            const panelC3 = getHex('panelColor3') || COLOR_DEFAULTS.panelColor3;
            const panelBorder = getHex('panelBorder') || COLOR_DEFAULTS.panelBorder;

            const gp = 'linear-gradient(135deg,' + p1 + ' 0%,' + p2 + ' 100%)';
            const gb = buildColorByMode(btnMode, b1, b2, b3);
            const gi = 'linear-gradient(135deg,' + ic1 + ' 0%,' + ic2 + ' 100%)';
            const gs = buildColorByMode(sectionMode, sectionC1, sectionC2, sectionC3);
            const gt = buildColorByMode(textMode, textC1, textC2, textC3);
            const gc = buildColorByMode(categoryMode, categoryS1, categoryS2, categoryS3);
            const gpanel = buildColorByMode(panelMode, panelC1, panelC2, panelC3);

            // Gradiente preview
            const gPrev = document.getElementById('gradientPreview');
            if (gPrev) gPrev.style.background = gp;
            const gText = document.getElementById('gradientPreviewText');
            if (gText) gText.style.color = useGrad ? '#fff' : logo;
            const previewTitle = document.querySelector('#tab-colores .products-header');
            if (previewTitle) previewTitle.style.background = gs;

            // Navbar preview
            const navPrev = document.getElementById('navbarPreview');
            if (navPrev) {
                navPrev.style.background = useGrad ? gp : nbg;
                navPrev.style.boxShadow = useGrad ? 'none' : '0 2px 8px rgba(0,0,0,0.1)';
            }
            const navLogoEl = document.getElementById('navLogoPreview');
            if (navLogoEl) navLogoEl.style.color = useGrad ? '#fff' : logo;
            ['navLinkPreview','navLinkPreview2'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.style.color = useGrad ? 'rgba(255,255,255,0.9)' : nl;
            });

            // Mostrar/ocultar campo de color sólido del navbar
            const nbgField = document.getElementById('navbarBgField');
            if (nbgField) nbgField.style.display = useGrad ? 'none' : '';

            // Botón preview
            const btn = document.getElementById('btnPreview');
            if (btn) { btn.style.background = gb; btn.style.color = bt; }
            if (gText) {
                gText.style.background = textMode === '1' ? 'none' : gt;
                gText.style.webkitBackgroundClip = textMode === '1' ? 'initial' : 'text';
                gText.style.backgroundClip = textMode === '1' ? 'initial' : 'text';
                gText.style.color = textMode === '1' ? textC1 : 'transparent';
            }

            // Ícono previews
            ['iconPreview1','iconPreview2','iconPreview3'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.style.background = gi;
