<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title><%= negocio && negocio.titulos_paginas && negocio.titulos_paginas.mis_pedidos ? negocio.titulos_paginas.mis_pedidos : 'Mis Pedidos - Tienda Elegante' %></title>
    <% if (negocio && negocio.icono_pagina && negocio.icono_pagina.imagen) { %>
        <link rel="icon" href="<%= negocio.icono_pagina.imagen %>" type="image/x-icon">
        <link rel="apple-touch-icon" href="<%= negocio.icono_pagina.imagen %>">
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <!-- ===== COLORES DINÁMICOS ADMIN ===== -->
    <% 
        const _c = (negocio && negocio.colores) ? negocio.colores : {};
        const _p1             = _c.primary          || '#667eea';
        const _p2             = _c.secondary        || '#764ba2';
        const _bodyBg         = _c.bodyBg           || '#f5f7fb';
        const _textColor      = _c.textColor        || '#2d3748';
        const _navbarBg       = _c.navbarBg         || '#ffffff';
        const _navGrad        = (_c.navbarUsesGradient === 'true');
        const _logoColor      = _c.logoTextColor    || '#667eea';
        const _navLinkColor   = _c.navLinkColor     || '#2d3748';
        const _navLinkHover   = _c.navLinkHover     || '#ffffff';
        const _btnBg1         = _c.btnBg1           || _p1;
        const _btnBg2         = _c.btnBg2           || _p2;
        const _btnBg3         = _c.btnBg3           || _p2;
        const _btnMode        = _c.btnColorMode     || '2';
        const _btnTextColor   = _c.btnTextColor     || '#ffffff';
        const _iconColor      = _c.iconColor        || _p1;
        const _iconColor2     = _c.iconColor2       || _p2;
        const _sectionMode    = _c.sectionColorMode || '2';
        const _sectionColor1  = _c.sectionColor1    || _p1;
        const _sectionColor2  = _c.sectionColor2    || _p2;
        const _sectionColor3  = _c.sectionColor3    || _p2;
        const _textMode       = _c.textColorMode    || '1';
        const _textColor1     = _c.textColor1       || _textColor;
        const _textColor2     = _c.textColor2       || _p1;
        const _textColor3     = _c.textColor3       || _p2;
        const _navBgFinal     = _navGrad
            ? `linear-gradient(135deg,${_p1} 0%,${_p2} 100%)`
            : _navbarBg;
        // Para links: si es gradiente, forzar blanco; si es sólido, usar color elegido
        const _navLinkFinal   = _navGrad ? 'rgba(255,255,255,0.92)' : _navLinkColor;
        // logoCustomized: true si el usuario cambió algo del navbar
        const _logoCustomized = _c.logoTextColor || _c.navbarUsesGradient;
        const buildDynColor = (mode, c1, c2, c3) => {
            if (mode === '1') return c1;
            if (mode === '3') return `linear-gradient(135deg, ${c1} 0%, ${c2} 50%, ${c3} 100%)`;
            return `linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`;
        };
        const _sectionBgFinal = buildDynColor(_sectionMode, _sectionColor1, _sectionColor2, _sectionColor3);
        const _btnBgFinal     = buildDynColor(_btnMode, _btnBg1, _btnBg2, _btnBg3);
        const _textAccentBg   = buildDynColor(_textMode, _textColor1, _textColor2, _textColor3);
        const _bannerTitle    = _c.bannerTitleColor    || '#ffffff';
        const _bannerSubtitle = _c.bannerSubtitleColor || '#ffffff';
    %>
    <style>
        :root {
            --dyn-p1:            <%= _p1 %>;
            --dyn-p2:            <%= _p2 %>;
            --dyn-body-bg:       <%= _bodyBg %>;
            --dyn-text:          <%= _textColor %>;
            --dyn-navbar-bg:     <%= _navBgFinal %>;
            --dyn-nav-link:      <%= _navLinkFinal %>;
            --dyn-nav-hover-bg:  linear-gradient(135deg, <%= _p1 %> 0%, <%= _p2 %> 100%);
            --dyn-nav-hover-text:<%= _navLinkHover %>;
            --dyn-btn1:          <%= _btnBg1 %>;
            --dyn-btn2:          <%= _btnBg2 %>;
            --dyn-btn-text:      <%= _btnTextColor %>;
            --dyn-icon1:         <%= _iconColor %>;
            --dyn-icon2:         <%= _iconColor2 %>;
            --dyn-gradient:      linear-gradient(135deg, var(--dyn-p1) 0%, var(--dyn-p2) 100%);
            --dyn-btn-gradient:  <%= _btnBgFinal %>;
            --dyn-icon-gradient: linear-gradient(135deg, var(--dyn-icon1) 0%, var(--dyn-icon2) 100%);
            --dyn-section-bg:    <%= _sectionBgFinal %>;
            --dyn-text-accent-bg:<%= _textAccentBg %>;
            /* vars nativas (mis-pedidos las usa directamente) */
            --primary:   var(--dyn-p1);
            --secondary: var(--dyn-p2);
            --gradient:  var(--dyn-gradient);
        }

        /* === BODY === */
        body { background: var(--dyn-body-bg) !important; color: var(--dyn-text) !important; }

        /* === NAVBAR FONDO === */
        .navbar { background: var(--dyn-navbar-bg) !important; }

        /* === LOGO: solo sobreescribir si el navbar usa gradiente === */
        <% if (_navGrad) { %>
        .navbar-brand,
        .navbar-brand span,
        .logo-container i {
            background: none !important;
            -webkit-background-clip: unset !important;
            background-clip: unset !important;
            color: #ffffff !important;
        }
        <% } else if (_c.logoTextColor) { %>
        /* Logo con color personalizado elegido por el admin */
        .navbar-brand,
        .navbar-brand span,
        .logo-container i {
            background: none !important;
            -webkit-background-clip: unset !important;
            background-clip: unset !important;
            color: <%= _logoColor %> !important;
        }
        <% } %>
        /* Si no se personalizó nada, el style.css maneja el logo (background-clip:text) */

        /* === LINKS DEL NAVBAR === */
        <% if (_c.navLinkColor || _navGrad) { %>
        .navbar-nav .nav-link {
            color: var(--dyn-nav-link) !important;
        }
        <% } %>
        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link:focus,
        .navbar-nav .nav-link.active {
            background: var(--dyn-nav-hover-bg) !important;
            color: var(--dyn-nav-hover-text) !important;
        }

        /* Toggler con gradiente */
        .navbar-toggler { background: var(--dyn-gradient) !important; border: none !important; }

        /* === HEADERS / HERO === */
        .hero-section,
        .cart-header,
        .products-header,
        .orders-header { background: var(--dyn-section-bg) !important; }

        /* === BOTONES PRIMARY === */
        .btn-primary {
            background: var(--dyn-btn-gradient) !important;
            border-color: var(--dyn-btn1) !important;
            color: var(--dyn-btn-text) !important;
        }
        .btn-primary:hover { opacity: 0.9; filter: brightness(1.05); color: var(--dyn-btn-text) !important; }

        /* Botón "Agregar al carrito" */
        form[action="/carrito/add"] button[type="submit"],
        .btn-add-to-cart,
        .producto-card .btn,
        .btn-gradient {
            background: var(--dyn-btn-gradient) !important;
            border: none !important;
            color: var(--dyn-btn-text) !important;
        }

        /* === ÍCONOS CIRCULARES === */
        .feature-icon-modern,
        .stats-icon-client,
        .icon-circle { background: var(--dyn-icon-gradient) !important; }

        /* === TEXTOS COLOREADOS === */
        .total-amount { color: var(--dyn-p1) !important; }
        .categoria-title { border-bottom-color: var(--dyn-p1) !important; }
        .categoria-title i { color: var(--dyn-p1) !important; }
    </style>
<style>
        :root {
            --primary: #667eea;
            --secondary: #764ba2;
            --success: #48bb78;
            --warning: #ed8936;
            --danger: #f56565;
            --dark: #2d3748;
            --gray: #718096;
            --light: #f7fafc;
            --gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --radius: 12px;
            --radius-lg: 20px;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
            --shadow-md: 0 4px 6px rgba(0,0,0,0.07);
            --shadow-lg: 0 20px 30px rgba(0,0,0,0.1);
            --transition: all 0.3s ease;
        }
        
        .orders-header {
            background: var(--gradient);
            border-radius: var(--radius-lg);
            padding: 50px 40px;
            margin-bottom: 40px;
            color: white;
            position: relative;
            overflow: hidden;
        }
        
        .orders-header::before {
            content: '';
            position: absolute;
            top: 0;
            right: -100px;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }
        
        .orders-header::after {
            content: '';
            position: absolute;
            bottom: -50px;
            left: -50px;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.03);
            border-radius: 50%;
        }
        
        .orders-header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            position: relative;
            z-index: 1;
            letter-spacing: -0.5px;
        }
        
        .orders-header p {
            font-size: 1rem;
            position: relative;
            z-index: 1;
            opacity: 0.95;
            font-weight: 500;
        }
        
        .stats-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 35px;
        }
        
        @media (max-width: 480px) {
            .stats-container {
                grid-template-columns: repeat(3, 1fr);
                gap: 10px;
            }
            .stat-card {
                padding: 14px 8px;
            }
            .stat-card h3 {
                font-size: 1.5rem;
            }
        }
        
        .stat-card {
            background: white;
            border-radius: var(--radius-lg);
            padding: 20px;
            text-align: center;
            box-shadow: var(--shadow-md);
            transition: var(--transition);
            border: 2px solid transparent;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary);
        }
        
        .stat-card h3 {
            color: var(--primary);
            font-size: 2rem;
            font-weight: 800;
            margin: 10px 0;
        }
        
        .stat-card small {
            color: var(--gray);
            font-weight: 600;
            font-size: 0.85rem;
        }
        
        .order-card {
            background: white;
            border-radius: var(--radius-lg);
            margin-bottom: 20px;
            overflow: hidden;
            transition: var(--transition);
            box-shadow: var(--shadow-md);
            border-left: 5px solid var(--primary);
        }
        
        .order-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-3px);
        }
        
        .order-card.entregado {
            border-left-color: var(--success);
        }
        
        .order-card.preparacion {
            border-left-color: var(--warning);
        }
        
        .order-card.pendiente {
            border-left-color: #4299e1;
        }
        
        .order-header {
            background: linear-gradient(to right, #f7fafc 0%, #edf2f7 100%);
            padding: 25px;
            cursor: pointer;
            user-select: none;
            transition: var(--transition);
            border-bottom: 1px solid #e2e8f0;
        }
        
        .order-header:hover {
            background: linear-gradient(to right, #edf2f7 0%, #e2e8f0 100%);
        }
        
        .order-number {
            font-size: 1rem;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 5px;
        }
        
        .order-number i {
            color: var(--primary);
            font-size: 1.1rem;
        }
        
        .order-date {
            font-size: 0.85rem;
            color: var(--gray);
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .order-status-badge {
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .order-status-badge.entregado {
            background: linear-gradient(135deg, rgba(72, 187, 120, 0.1) 0%, rgba(56, 161, 105, 0.1) 100%);
            color: var(--success);
            border: 1px solid var(--success);
        }
        
        .order-status-badge.preparacion {
            background: linear-gradient(135deg, rgba(237, 137, 54, 0.1) 0%, rgba(221, 107, 32, 0.1) 100%);
            color: var(--warning);
            border: 1px solid var(--warning);
        }
        
        .order-status-badge.pendiente {
            background: linear-gradient(135deg, rgba(66, 153, 225, 0.1) 0%, rgba(49, 130, 206, 0.1) 100%);
            color: #4299e1;
            border: 1px solid #4299e1;
        }
        
        .order-total {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--primary);
            text-align: right;
        }
        
        .order-header-icon {
            color: var(--gray);
            transition: var(--transition);
            font-size: 1.2rem;
        }
        
        .order-card.expanded .order-header-icon {
            transform: rotate(180deg);
            color: var(--primary);
        }
        
        .order-body {
            padding: 30px;
            background: #fafbfc;
        }
        
        .order-info-section {
            margin-bottom: 30px;
        }
        
        .order-info-section:last-child {
            margin-bottom: 0;
        }
        
        .info-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--gray);
            font-weight: 700;
            margin-bottom: 8px;
            display: block;
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }
        
        .info-item {
            padding: 15px;
            background: white;
            border-radius: var(--radius);
            border: 1px solid #e2e8f0;
            transition: var(--transition);
        }
        
        .info-item:hover {
            border-color: var(--primary);
            background: #f7faff;
        }
        
        .info-item small {
            color: var(--gray);
            font-weight: 600;
            display: block;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .info-item strong {
            color: var(--dark);
            font-size: 1rem;
            display: block;
            word-break: break-word;
        }
        
        .order-products-title {
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 15px;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .order-products-title i {
            color: var(--primary);
        }
        
        .products-table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .products-table thead th {
            background: white;
            border-bottom: 2px solid var(--primary);
            color: var(--dark);
            font-weight: 700;
            padding: 12px;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .products-table tbody tr {
            border-bottom: 1px solid #e2e8f0;
            transition: var(--transition);
        }
        
        .products-table tbody tr:hover {
            background: #f7fafc;
        }
        
        .products-table tbody tr:last-child {
            border-bottom: 2px solid var(--primary);
        }
        
        .products-table tbody td {
            padding: 15px 12px;
            color: var(--dark);
            font-size: 0.95rem;
        }
        
        .products-table tfoot tr {
            background: linear-gradient(to right, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
        }
        
        .products-table tfoot td {
            padding: 15px 12px;
            font-weight: 700;
            color: var(--primary);
            font-size: 1.1rem;
        }
        
        .product-name {
            color: var(--dark);
            font-weight: 600;
        }
        
        .quantity-badge {
            background: var(--light);
            color: var(--primary);
            padding: 4px 8px;
            border-radius: 6px;
            font-weight: 700;
            display: inline-block;
        }
        
        .price-text {
            color: var(--primary);
            font-weight: 700;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
        }
        
        .empty-state-icon {
            font-size: 80px;
            color: #cbd5e0;
            margin-bottom: 20px;
            opacity: 0.7;
        }
        
        .empty-state h3 {
            color: var(--dark);
            font-weight: 700;
            margin-bottom: 15px;
            font-size: 1.5rem;
        }
        
        .empty-state p {
            color: var(--gray);
            margin-bottom: 30px;
            font-size: 1rem;
        }
        
        .empty-state .btn-primary {
            background: var(--gradient);
            border: none;
            padding: 12px 30px;
            font-weight: 600;
            border-radius: var(--radius);
        }
        
        @media (max-width: 768px) {
            .orders-header {
                padding: 35px 20px;
            }
            
            .orders-header h1 {
                font-size: 2rem;
            }
            
            .order-header {
                padding: 15px;
            }
            
            .order-total {
                font-size: 1.4rem;
                margin-top: 10px;
            }
            
            .info-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }
            
            .products-table {
                font-size: 0.85rem;
            }
            
            .products-table td,
            .products-table th {
                padding: 10px 8px !important;
            }
            
            .stat-card h3 {
                font-size: 1.5rem;
            }
        }
        
        @media (max-width: 576px) {
            .orders-header h1 {
                font-size: 1.5rem;
            }
            
            .orders-header {
                padding: 25px 15px;
            }
            
            .order-body {
                padding: 15px;
            }
            
            .products-table thead {
                display: none;
            }
            
            .products-table tbody tr {
                display: block;
                margin-bottom: 15px;
                border: 1px solid #e2e8f0;
                border-radius: var(--radius);
                background: white;
            }
            
            .products-table tbody td {
                display: flex;
                justify-content: space-between;
                padding: 12px;
                border: none;
                border-bottom: 1px solid #e2e8f0;
            }
            
            .products-table tbody td:last-child {
                border-bottom: none;
            }
            
            .products-table tbody td::before {
                content: attr(data-label);
                font-weight: 700;
                color: var(--gray);
                min-width: 80px;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <div class="logo-container">
                    <% if (negocio.logoHeader && negocio.logoHeader.image && negocio.logoHeader.type !== 'text') { %>
                        <img src="<%= negocio.logoHeader.image %>" alt="<%= negocio.nombre %>" style="width: <%= negocio.logoHeader?.size || 150 %>px; max-width: 100%; object-fit: contain;">
                    <% } else { %>
                        <i class="fas fa-store"></i>
                        <span><%= negocio.logoHeader && negocio.logoHeader.text ? negocio.logoHeader.text : negocio.nombre %></span>
                    <% } %>
                </div>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/productos"><i class="fas fa-shopping-bag"></i> Productos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/carrito"><i class="fas fa-shopping-cart"></i> Carrito</a></li>
                    <% if (user) { %>
                        <li class="nav-item"><a class="nav-link active" href="/mis-pedidos"><i class="fas fa-truck"></i> Mis Pedidos</a></li>
                        <li class="nav-item"><a class="nav-link" href="/perfil"><i class="fas fa-user-circle"></i> <%= user.nombre %></a></li>
                        <% if (user.rol === 'admin') { %>
                            <li class="nav-item"><a class="nav-link" href="/admin"><i class="fas fa-chart-line"></i> Admin</a></li>
                        <% } %>
                        <li class="nav-item"><a class="nav-link" href="/logout"><i class="fas fa-sign-out-alt"></i> Salir</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/login"><i class="fas fa-key"></i> Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/register"><i class="fas fa-user-plus"></i> Registro</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5 pt-4">
        <div class="orders-header">
            <div>
                <h1 style="color: <%= _bannerTitle %>;"><i class="fas fa-box-open"></i> <%= textos.mis_pedidos?.titulo_seccion || 'Mis Pedidos' %></h1>
                <p class="mb-0" style="color: <%= _bannerSubtitle %>;"><%= textos.mis_pedidos?.subtitulo_seccion || 'Consulta el historial y estado de tus compras' %></p>
            </div>
        </div>
        
        <% if (!pedidos || pedidos.length === 0) { %>
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-inbox"></i>
                </div>
                <h3><%= textos.mis_pedidos?.mensaje_vacio || 'Sin pedidos aún' %></h3>
                <p><%= textos.mis_pedidos?.mensaje_vacio_desc || 'No tienes pedidos registrados. ¡Comienza a explorar nuestros productos!' %></p>
                <a href="/productos" class="btn btn-primary">
                    <i class="fas fa-shopping-bag"></i> Explorar Productos
                </a>
            </div>
        <% } else { %>
            <div class="stats-container">
                <div class="stat-card">
                    <div style="font-size: 1.8rem; color: var(--primary); margin-bottom: 8px;">
                        <i class="fas fa-boxes"></i>
                    </div>
                    <h3><%= pedidos.length %></h3>
                    <small>Pedidos Totales</small>
                </div>
                <div class="stat-card">
                    <div style="font-size: 1.8rem; color: var(--success); margin-bottom: 8px;">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h3><%= pedidos.filter(p => p.estado === 'entregado').length %></h3>
                    <small>Entregados</small>
                </div>
                <div class="stat-card">
                    <div style="font-size: 1.8rem; color: var(--warning); margin-bottom: 8px;">
                        <i class="fas fa-hourglass-half"></i>
                    </div>
                    <h3><%= pedidos.filter(p => p.estado !== 'entregado').length %></h3>
                    <small>En Proceso</small>
                </div>
            </div>
            
            <div>
                <% pedidos.forEach((pedido, index) => { 
                    const isEntregado = pedido.estado === 'entregado';
                    const isPendiente = pedido.estado === 'pendiente';
                    const estadoClass = isEntregado ? 'entregado' : (isPendiente ? 'pendiente' : 'preparacion');
                %>
                    <div class="order-card <%= estadoClass %>" id="pedido-<%= pedido.id %>">
                        <div class="order-header" data-bs-toggle="collapse" data-bs-target="#detalle<%= pedido.id %>" role="button" onclick="this.closest('.order-card').classList.toggle('expanded')">
                            <div class="row align-items-center g-2">
                                <div class="col-md-5 col-12">
                                    <div class="order-number">
                                        <i class="fas fa-receipt"></i>
                                        Pedido #<%= pedido.id %>
                                    </div>
                                    <div class="order-date">
                                        <i class="far fa-calendar"></i>
                                        <%= new Date(pedido.fecha).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                    </div>
                                </div>
                                
                                <div class="col-md-3 col-12">
                                    <span class="order-status-badge <%= estadoClass %>">
                                        <i class="fas <%= isEntregado ? 'fa-check-circle' : (isPendiente ? 'fa-clock' : 'fa-spinner fa-spin') %>"></i>
                                        <%= isEntregado ? (textos.mis_pedidos?.estado_entregado || 'Entregado') : (isPendiente ? (textos.mis_pedidos?.estado_pendiente || 'Pendiente') : (textos.mis_pedidos?.estado_preparacion || 'En Preparación')) %>
                                    </span>
                                </div>
                                
                                <div class="col-md-4 col-12 d-flex align-items-center justify-content-between">
                                    <div class="order-total">
                                        $<%= parseFloat(pedido.total).toFixed(2) %>
                                    </div>
                                    <div class="order-header-icon">
                                        <i class="fas fa-chevron-down"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="collapse" id="detalle<%= pedido.id %>">
                            <div class="order-body">
                                <div class="info-grid">
                                    <div class="info-item">
                                        <span class="info-label">
                                            <i class="fas fa-map-marker-alt"></i> <%= textos.mis_pedidos?.info_direccion || 'Dirección de Entrega' %>
                                        </span>
                                        <strong><%= pedido.direccion %></strong>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">
                                            <i class="fas fa-credit-card"></i> <%= textos.mis_pedidos?.info_pago || 'Método de Pago' %>
                                        </span>
                                        <strong>
                                            <% if (pedido.forma_pago === 'efectivo') { %>
                                                <i class="fas fa-money-bill-wave"></i> Efectivo
                                            <% } else { %>
                                                <i class="fas fa-bank"></i> Transferencia Bancaria
                                            <% } %>
                                        </strong>
                                    </div>
                                </div>
                                
                                <div class="order-info-section">
                                    <div class="order-products-title">
                                        <i class="fas fa-list"></i> <%= textos.mis_pedidos?.productos_titulo || 'Productos del Pedido' %>
                                    </div>
                                    
                                    <table class="products-table">
                                        <thead>
                                            <tr>
                                                <th>Producto</th>
                                                <th class="text-center">Cantidad</th>
                                                <th class="text-end">Precio Unitario</th>
                                                <th class="text-end">Subtotal</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (pedido.detalles && pedido.detalles.length > 0) { %>
                                                <% pedido.detalles.forEach(det => { 
                                                    const subtotal = det.cantidad * det.precio_unitario;
                                                %>
                                                    <tr>
                                                        <td class="product-name"><%= det.nombre %></td>
                                                        <td class="text-center">
                                                            <span class="quantity-badge">x<%= det.cantidad %></span>
                                                        </td>
                                                        <td class="text-end">$<%= parseFloat(det.precio_unitario).toFixed(2) %></td>
                                                        <td class="text-end price-text">$<%= subtotal.toFixed(2) %></td>
                                                    </tr>
                                                <% }) %>
                                            <% } %>
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <td colspan="3" class="text-end">
                                                    <strong><%= textos.mis_pedidos?.total_label || 'Total del Pedido:' %></strong>
                                                </td>
                                                <td class="text-end">
                                                    <strong>$<%= parseFloat(pedido.total).toFixed(2) %></strong>
                                                </td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
    
    <%- include('./footer') %>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelectorAll('.order-header').forEach(header => {
            header.addEventListener('click', function() {
                const card = this.closest('.order-card');
                const collapseId = this.getAttribute('data-bs-target');
                const collapseElement = document.querySelector(collapseId);
                
                if (collapseElement.classList.contains('show')) {
                    card.classList.remove('expanded');
                } else {
                    card.classList.add('expanded');
                }
            });
        });
    </script>
</body>
</html>