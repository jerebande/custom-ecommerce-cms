<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= negocio && negocio.titulos_paginas && negocio.titulos_paginas.pedido_confirmado ? negocio.titulos_paginas.pedido_confirmado : 'Pedido Confirmado' %></title>
    <% if (negocio && negocio.icono_pagina && negocio.icono_pagina.imagen) { %>
        <link rel="icon" href="<%= negocio.icono_pagina.imagen %>" type="image/x-icon">
        <link rel="apple-touch-icon" href="<%= negocio.icono_pagina.imagen %>">
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg,#f5f7fb,#f0f2f8); min-height: 100vh; }
        .confirm-card {
            background: white; border-radius: 28px;
            padding: 48px 40px;
            box-shadow: 0 24px 48px rgba(0,0,0,0.10);
            max-width: 600px; margin: 100px auto 60px;
        }
        .success-circle {
            width: 96px; height: 96px;
            background: linear-gradient(135deg,#22c55e,#16a34a);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px;
            box-shadow: 0 8px 24px rgba(34,197,94,.35);
            animation: popIn 0.5s cubic-bezier(.175,.885,.32,1.275);
        }
        .success-circle i { color: white; font-size: 2.8rem; }
        @keyframes popIn {
            from { transform: scale(0.4); opacity: 0; }
            to   { transform: scale(1);   opacity: 1; }
        }
        .pedido-num  { font-size: 1rem; color: #64748b; margin-bottom: 4px; }
        .pedido-title { font-size: 1.9rem; font-weight: 800; color: #1e293b; margin-bottom: 6px; }
        .bloque-comprobante {
            background: linear-gradient(135deg,#f0fdf4,#dcfce7);
            border: 2px solid #86efac; border-radius: 18px;
            padding: 22px; margin: 24px 0;
        }
        .bloque-comprobante h6 { color: #166534; font-weight: 700; margin-bottom: 12px; }
        .comp-img {
            width: 100%; max-height: 280px; object-fit: contain;
            border-radius: 12px; border: 2px solid #bbf7d0; background: white;
        }
        .bloque-pendiente {
            background: linear-gradient(135deg,#fefce8,#fef9c3);
            border: 2px solid #fde047; border-radius: 18px;
            padding: 22px; margin: 24px 0;
        }
        .bloque-pendiente h6 { color: #854d0e; font-weight: 700; margin-bottom: 8px; }
        .bloque-pendiente p  { color: #92400e; font-size: 0.92rem; margin: 0; }
        .btn-wa {
            background: linear-gradient(135deg,#25d366,#128c7e);
            color: white; border: none; padding: 14px 28px; border-radius: 50px;
            font-weight: 700; font-size: 1rem; text-decoration: none;
            display: inline-flex; align-items: center; gap: 8px;
            transition: transform .2s, box-shadow .2s;
        }
        .btn-wa:hover { color: white; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(37,211,102,.35); }
        .btn-sec {
            background: white; color: #667eea; border: 2px solid #667eea;
            padding: 12px 24px; border-radius: 50px; font-weight: 600;
            font-size: 0.95rem; text-decoration: none;
            display: inline-flex; align-items: center; gap: 8px; transition: all .2s;
        }
        .btn-sec:hover { background: #667eea; color: white; }
        .info-row {
            display: flex; align-items: center; gap: 10px;
            background: #f8fafc; border-radius: 12px;
            padding: 12px 16px; margin-bottom: 10px;
            font-size: 0.9rem; color: #475569;
        }
        .info-row i { color: #667eea; width: 18px; text-align: center; }
        .info-row strong { color: #1e293b; }
        @media(max-width:576px){ .confirm-card{ padding: 28px 18px; margin-top: 80px; } }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <div class="logo-container">
                    <% if (typeof negocio !== 'undefined' && negocio && negocio.logoHeader && negocio.logoHeader.type === 'image' && negocio.logoHeader.image) { %>
                        <img src="<%= negocio.logoHeader.image %>" alt="logo"
                             style="width:<%= negocio.logoHeader.size||150 %>px;max-width:100%;object-fit:contain;">
                    <% } else { %>
                        <i class="fas fa-store"></i>
                        <span><%= (typeof negocio !== 'undefined' && negocio && negocio.nombre) ? negocio.nombre : 'Tienda' %></span>
                    <% } %>
                </div>
            </a>
        </div>
    </nav>

    <div class="container">
        <div class="confirm-card text-center">

            <div class="success-circle"><i class="fas fa-check"></i></div>

            <p class="pedido-num">Pedido #<%= pedidoId %></p>
            <h1 class="pedido-title">¡Pedido confirmado!</h1>
            <p class="text-muted mb-4">Tu pedido fue registrado correctamente.</p>

            <!-- Info rápida -->
            <div class="text-start mb-2">
                <div class="info-row">
                    <i class="fas fa-<%= modo_entrega === 'retiro' ? 'store' : 'motorcycle' %>"></i>
                    <span>Entrega:
                        <strong><%= modo_entrega === 'retiro' ? 'Retiro en local' : 'Delivery a domicilio' %></strong>
                    </span>
                </div>
                <div class="info-row">
                    <i class="fas fa-dollar-sign"></i>
                    <span>Total: <strong>$<%= parseFloat(total).toFixed(2) %></strong></span>
                </div>
                <div class="info-row">
                    <i class="fas fa-<%= momento_pago === 'ahora' ? 'check-circle' : 'clock' %>"
                       style="color:<%= momento_pago === 'ahora' ? '#22c55e' : '#f59e0b' %>;"></i>
                    <span>Pago:
                        <strong>
                            <% if (momento_pago === 'ahora') { %>
                                Transferencia realizada ✅
                            <% } else if (modo_entrega === 'retiro') { %>
                                Pagás en el local
                            <% } else { %>
                                Pagás al recibir el delivery
                            <% } %>
                        </strong>
                    </span>
                </div>
            </div>

            <!-- Comprobante o mensaje de pago pendiente -->
            <% if (momento_pago === 'ahora' && comprobante_url) { %>
            <div class="bloque-comprobante text-start">
                <h6><i class="fas fa-image me-2"></i>Comprobante de pago</h6>
                <p style="font-size:0.85rem;color:#166534;margin-bottom:14px;">
                    Recibimos tu comprobante. Se enviará junto con el pedido por WhatsApp.
                </p>
                <img src="<%= comprobante_url %>" alt="Comprobante de pago" class="comp-img">
            </div>

            <% } else if (momento_pago === 'ahora') { %>
            <div class="bloque-comprobante text-start">
                <h6><i class="fas fa-check-circle me-2"></i>Pago por transferencia registrado</h6>
                <p style="font-size:0.85rem;color:#166534;margin-bottom:0;">
                    El local verificará tu pago a la brevedad.
                </p>
            </div>

            <% } else { %>
            <div class="bloque-pendiente text-start">
                <h6>
                    <i class="fas fa-clock me-2"></i>
                    <% if (modo_entrega === 'retiro') { %>Recordá el pago al retirar<% } else { %>Pago al recibir el pedido<% } %>
                </h6>
                <p>
                    <% if (modo_entrega === 'retiro') { %>
                        Tené el efectivo listo cuando pases a buscar tu pedido al local.
                    <% } else { %>
                        Tené el efectivo listo cuando el repartidor llegue a tu domicilio.
                    <% } %>
                </p>
            </div>
            <% } %>

            <!-- Botones de acción -->
            <div class="d-flex flex-wrap gap-3 justify-content-center mt-4">
                <a href="<%= whatsappUrl %>" target="_blank" class="btn-wa">
                    <i class="fab fa-whatsapp" style="font-size:1.2rem;"></i>
                    Enviar pedido por WhatsApp
                </a>
                <a href="/mis-pedidos" class="btn-sec">
                    <i class="fas fa-list"></i> Mis pedidos
                </a>                                            
                <a href="/" class="btn-sec">
                    <i class="fas fa-home"></i> Inicio
                </a>
            </div>

        </div>
    </div>

    <%- include('./footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>