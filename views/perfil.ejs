    <!-- Input oculto para seleccionar archivo -->
    <input type="file" id="fotoInput" accept="image/jpeg,image/png,image/gif,image/webp" style="display: none;">
    
    <!-- Progress overlay -->
    <div class="upload-progress" id="uploadProgress">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2 mb-0">Subiendo foto...</p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
 <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
<script>
    // ==================== MANEJO DE MENSAJES DE URL ====================
    const urlParams = new URLSearchParams(window.location.search);
    const successMsg = urlParams.get('success');
    const errorMsg = urlParams.get('error');
    
    if (successMsg) {
        showSuccess(decodeURIComponent(successMsg));
        window.history.replaceState({}, document.title, window.location.pathname);
    }
    
    if (errorMsg) {
        showError(decodeURIComponent(errorMsg));
        window.history.replaceState({}, document.title, window.location.pathname);
    }
    
    // ==================== MANEJO DE FOTO DE PERFIL ====================
    const avatarContainer = document.getElementById('avatarContainer');
    const fotoInput = document.getElementById('fotoInput');
    const uploadProgress = document.getElementById('uploadProgress');

    if (avatarContainer) {
        avatarContainer.addEventListener('click', function(e) {
            console.log("Click en avatar");
            fotoInput.click();
        });
    }

    fotoInput.addEventListener('change', async function(e) {
        const file = e.target.files[0];
        console.log("Archivo seleccionado:", file);
        
        if (!file) return;
        
        const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
        if (!allowedTypes.includes(file.type)) {
            showError('Solo se permiten imágenes (JPEG, PNG, GIF, WEBP)');
            return;
        }
        
        if (file.size > 5 * 1024 * 1024) {
            showError('La imagen no puede superar los 5MB');
            return;
        }
        
        const formData = new FormData();
        formData.append('foto_perfil', file);
        
        uploadProgress.style.display = 'block';
        
        try {
            const response = await fetch('/perfil/foto', {
                method: 'POST',
                body: formData
            });
            
            const result = await response.json();
            console.log("Respuesta del servidor:", result);
            
            uploadProgress.style.display = 'none';
            
            if (result.success) {
                // Actualizar la imagen en el banner
                const bannerAvatar = document.querySelector('.profile-banner-avatar');
                if (bannerAvatar) {
                    if (result.fotoUrl) {
                        bannerAvatar.innerHTML = `<img src="${result.fotoUrl}" alt="Foto de perfil">`;
                    } else {
                        bannerAvatar.innerHTML = `<div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#f5f7fb; color:#667eea;">
                            <i class="fas fa-user-circle" style="font-size:50px;"></i>
                        </div>`;
                    }
                }
                
                // Actualizar el avatar del formulario
                const avatarContainerDiv = document.getElementById('avatarContainer');
                if (avatarContainerDiv) {
                    if (result.fotoUrl) {
                        avatarContainerDiv.innerHTML = `
                            <img src="${result.fotoUrl}" alt="Foto de perfil" id="avatarImg" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                            <div class="avatar-overlay">
                                <i class="fas fa-camera"></i>
                                <span>Cambiar foto</span>
                            </div>
                        `;
                    } else {
                        avatarContainerDiv.innerHTML = `
                            <i class="fas fa-user-circle" id="avatarIcon"></i>
                            <div class="avatar-overlay">
                                <i class="fas fa-camera"></i>
                                <span>Cambiar foto</span>
                            </div>
                        `;
                    }
                }
                
                showSuccess('Foto de perfil actualizada correctamente');
            } else {
                showError(result.error || 'Error al subir la foto');
            }
        } catch (error) {
            uploadProgress.style.display = 'none';
            console.error('Error:', error);
            showError('Error al subir la foto. Intenta nuevamente.');
        }
        
        fotoInput.value = '';
    });
    
    // ==================== FORMULARIO PERFIL (versión JSON) ====================
    const profileForm = document.getElementById('profileForm');
    if (profileForm) {
        profileForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            console.log("=== Enviando formulario de perfil ===");
            
            const nombre = document.getElementById('nombre').value;
            const telefono = document.getElementById('telefono').value;
            const direccion = document.getElementById('direccion').value;
            
            console.log("Datos a enviar:", { nombre, telefono, direccion });
            
            if (!nombre || nombre.trim() === '') {
                showError('El nombre es obligatorio');
                return;
            }
            
            const btn = document.getElementById('updateBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="loading"></span> Guardando...';
            btn.disabled = true;
            
            try {
                // Enviar como JSON
                const data = {
                    nombre: nombre.trim(),
                    telefono: telefono || '',
                    direccion: direccion || ''
                };
                
                const response = await fetch('/perfil', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(data)
                });
                
                console.log("Respuesta status:", response.status);
                
                let result;
                const textResponse = await response.text();
                console.log("Respuesta texto:", textResponse);
                
                try {
                    result = JSON.parse(textResponse);
                } catch (e) {
                    console.error("Error parsing JSON:", e);
                    throw new Error('Respuesta inválida del servidor');
                }
                
                if (result.success) {
                    showSuccess('Perfil actualizado correctamente');
                    
                    // Actualizar el nombre en el navbar
                    document.querySelectorAll('.nav-link').forEach(link => {
                        if (link.href && link.href.includes('/perfil')) {
                            link.innerHTML = `<i class="fas fa-user-circle"></i> ${result.nombre}`;
                        }
                    });
                    
                    // Actualizar el nombre en el banner
                    document.querySelectorAll('.profile-name').forEach(el => {
                        el.innerHTML = `<i class="fas fa-user-circle"></i> ${result.nombre}`;
                    });
                    
                    // Actualizar el nombre en la información rápida
                    const infoValues = document.querySelectorAll('.info-value');
                    infoValues.forEach(el => {
                        const label = el.previousElementSibling;
                        if (label && label.textContent.trim().includes('Nombre completo')) {
                            el.textContent = result.nombre;
                        }
                    });
                } else {
                    showError(result.error || 'Error al actualizar el perfil');
                }
            } catch (error) {
                console.error('Error:', error);
                showError('Error al actualizar el perfil. Intenta nuevamente.');
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });
    }
    
    // ==================== FORMULARIO CONTRASEÑA (versión JSON) ====================
    const passwordFormEl = document.getElementById('passwordForm');
    if (passwordFormEl) {
        passwordFormEl.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            console.log("=== Enviando formulario de contraseña ===");
            
            const currentPwd = document.getElementById('current_password').value;
            const newPwd = document.getElementById('new_password').value;
            const confirmPwd = document.getElementById('confirm_password').value;
            
            if (!currentPwd || !newPwd || !confirmPwd) {
                showError('Por favor complete todos los campos');
                return;
            }
            
            if (newPwd !== confirmPwd) {
                showError('Las contraseñas no coinciden');
                return;
            }
            
            if (newPwd.length < 6) {
                showError('La contraseña debe tener al menos 6 caracteres');
                return;
            }
            
            const btn = document.getElementById('passwordBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="loading"></span> Cambiando...';
            btn.disabled = true;
            
            try {
                const data = {
                    current_password: currentPwd,
                    new_password: newPwd,
                    confirm_password: confirmPwd
                };
                
                const response = await fetch('/cambiar-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(data)
                });
                
                console.log("Respuesta status:", response.status);
                
                let result;
                const textResponse = await response.text();
                console.log("Respuesta texto:", textResponse);
                
                try {
                    result = JSON.parse(textResponse);
                } catch (e) {
                    console.error("Error parsing JSON:", e);
                    throw new Error('Respuesta inválida del servidor');
                }
                
                if (result.success) {
                    showSuccess('Contraseña cambiada correctamente');
                    document.getElementById('current_password').value = '';
                    document.getElementById('new_password').value = '';
                    document.getElementById('confirm_password').value = '';
                    document.getElementById('passwordStrength').innerHTML = '';
                    document.getElementById('confirmMatch').innerHTML = '';
                } else {
                    showError(result.error || 'Error al cambiar la contraseña');
                }
            } catch (error) {
                console.error('Error:', error);
                showError('Error al cambiar la contraseña: ' + (error.message || 'Intenta nuevamente.'));
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });
    }
    
    // ==================== VALIDACIÓN DE CONTRASEÑA ====================
    function checkPasswordStrength(password) {
        let strength = 0;
        if (password.length >= 6) strength++;
        if (password.length >= 8) strength++;
        if (/[A-Z]/.test(password)) strength++;
        if (/[0-9]/.test(password)) strength++;
        if (/[^A-Za-z0-9]/.test(password)) strength++;
        
        if (strength <= 2) return { text: 'Débil', class: 'strength-weak' };
        if (strength <= 4) return { text: 'Media', class: 'strength-medium' };
        return { text: 'Fuerte', class: 'strength-strong' };
    }
    
    const newPasswordInput = document.getElementById('new_password');
    const passwordStrengthDiv = document.getElementById('passwordStrength');
    
    if (newPasswordInput) {
        newPasswordInput.addEventListener('input', function() {
            const strength = checkPasswordStrength(this.value);
            passwordStrengthDiv.innerHTML = `Fortaleza: <span class="${strength.class}">${strength.text}</span>`;
        });
    }
    
    const confirmPasswordInput = document.getElementById('confirm_password');
    const confirmMatchDiv = document.getElementById('confirmMatch');
    
    function checkPasswordMatch() {
        const newPassword = newPasswordInput ? newPasswordInput.value : '';
        const confirmPassword = confirmPasswordInput ? confirmPasswordInput.value : '';
        
        if (confirmPassword === '') {
            confirmMatchDiv.innerHTML = '';
        } else if (newPassword === confirmPassword) {
            confirmMatchDiv.innerHTML = '<span class="strength-strong">✓ Las contraseñas coinciden</span>';
        } else {
            confirmMatchDiv.innerHTML = '<span class="strength-weak">✗ Las contraseñas no coinciden</span>';
        }
    }
    
    if (confirmPasswordInput) {
        confirmPasswordInput.addEventListener('input', checkPasswordMatch);
    }
    if (newPasswordInput) {
        newPasswordInput.addEventListener('input', checkPasswordMatch);
    }
    
    // ==================== FUNCIONES DE ALERTA ====================
    function showError(message) {
        const alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-danger-custom alert-custom alert-dismissible fade show';
        alertDiv.innerHTML = `
            <i class="fas fa-exclamation-circle"></i> ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        
        const container = document.querySelector('.col-lg-8');
        if (container) {
            const firstCard = container.querySelector('.card-modern');
            if (firstCard) {
                container.insertBefore(alertDiv, firstCard);
            } else {
                container.insertBefore(alertDiv, container.firstChild);
            }
        }
        
        setTimeout(() => {
            if (alertDiv.parentNode) alertDiv.remove();
        }, 5000);
    }
    
    function showSuccess(message) {
        const alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-success-custom alert-custom alert-dismissible fade show';
        alertDiv.innerHTML = `
            <i class="fas fa-check-circle"></i> ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        
        const container = document.querySelector('.col-lg-8');
        if (container) {
            const firstCard = container.querySelector('.card-modern');
            if (firstCard) {
                container.insertBefore(alertDiv, firstCard);
            } else {
                container.insertBefore(alertDiv, container.firstChild);
            }
        }
        
        setTimeout(() => {
            if (alertDiv.parentNode) alertDiv.remove();
        }, 5000);
    }
    
    // ==================== FUNCIONES PARA LOGOS ====================
    function handleLogoFileChange(event, type) {
        const input = event.target;
        const previewImg = document.getElementById(`logo${type}PreviewImg`);
        const previewContainer = document.getElementById(`logo${type}PreviewContainer`);
        const hiddenImage = document.getElementById(`logo${type}Image`);
        const sizeValue = document.getElementById(`logo${type}SizeSlider`)?.value || (type === 'Header' ? 150 : 120);

        if (!input.files || !input.files[0]) {
            return;
        }

        const file = input.files[0];
        if (!file.type.startsWith('image/')) {
            showError('Selecciona un archivo de imagen válido');
            return;
        }

        const reader = new FileReader();
        reader.onload = function(e) {
            previewImg.src = e.target.result;
            previewImg.style.display = 'block';
            previewImg.style.width = `${sizeValue}px`;
            previewContainer.style.display = 'block';
            if (hiddenImage) {
                hiddenImage.value = '';
            }
        };
        reader.readAsDataURL(file);
    }

    function updateLogoSize(type, value) {
        const previewImg = document.getElementById(`logo${type}PreviewImg`);
        const hiddenSize = document.getElementById(`logo${type}Size`);
        const label = document.getElementById(`logo${type}SizeLabel`);

        if (previewImg) {
            previewImg.style.width = `${value}px`;
            previewImg.style.display = 'block';
        }
        if (hiddenSize) {
            hiddenSize.value = value;
        }
        if (label) {
            label.textContent = `${value} px`;
        }
    }
    
    // ==================== LOGO TYPE TOGGLE ====================
    function toggleLogoFields() {
        // Header logo
        const headerTextRadios = document.querySelectorAll('input[name="logoHeaderType"]');
        const headerTextGroup = document.getElementById('logoHeaderTextGroup');
        const headerImageGroup = document.getElementById('logoHeaderImageGroup');
        
        if (headerTextRadios.length > 0) {
            headerTextRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'text') {
                        if (headerTextGroup) headerTextGroup.style.display = 'block';
                        if (headerImageGroup) headerImageGroup.style.display = 'none';
                    } else {
                        if (headerTextGroup) headerTextGroup.style.display = 'none';
                        if (headerImageGroup) headerImageGroup.style.display = 'block';
                    }
                });
            });
        }
        
        // Footer logo
        const footerTextRadios = document.querySelectorAll('input[name="logoFooterType"]');
        const footerTextGroup = document.getElementById('logoFooterTextGroup');
        const footerImageGroup = document.getElementById('logoFooterImageGroup');
        
        if (footerTextRadios.length > 0) {
            footerTextRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'text') {
                        if (footerTextGroup) footerTextGroup.style.display = 'block';
                        if (footerImageGroup) footerImageGroup.style.display = 'none';
                    } else {
                        if (footerTextGroup) footerTextGroup.style.display = 'none';
                        if (footerImageGroup) footerImageGroup.style.display = 'block';
                    }
                });
            });
        }
    }
    
    // ==================== VALIDACIÓN FORMULARIO CONFIGURACIÓN ====================
    const configForm = document.getElementById('configForm');
    if (configForm) {
        configForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const whatsappAdmin = document.getElementById('whatsappAdmin')?.value || '';
            
            if (!whatsappAdmin) {
                showError('El número de WhatsApp es obligatorio');
                return false;
            }
            
            if (!/^\d+$/.test(whatsappAdmin)) {
                showError('El número de WhatsApp debe contener solo números');
                return false;
            }
            
            const btn = document.getElementById('configBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="loading"></span> Guardando...';
            btn.disabled = true;
            
            try {
                const formData = new FormData(this);
                formData.append('isAjax', 'true');
                
                const response = await fetch('/perfil/config', {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    },
                    body: formData
                });
                
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }
                
                const result = await response.json();
                
                if (result.success) {
                    showSuccess('Configuración guardada correctamente');
                    
                    if (result.negocio?.logoHeader) {
                        const navbarBrand = document.querySelector('.navbar-brand .logo-container');
                        if (navbarBrand) {
                            if (result.negocio.logoHeader.image && result.negocio.logoHeader.type !== 'text') {
                                navbarBrand.innerHTML = `<img src="${result.negocio.logoHeader.image}?t=${Date.now()}" alt="${result.negocio.nombre}" style="width: 150px; max-width: 100%; object-fit: contain;">`;
                            } else {
                                navbarBrand.innerHTML = `<i class="fas fa-store"></i><span>${result.negocio.logoHeader.text || result.negocio.nombre}</span>`;
                            }
                        }
                    }
                    
                    if (result.negocio?.nombre) {
                        document.title = `Mi Perfil - ${result.negocio.nombre}`;
                    }
                    
                } else {
                    showError(result.error || 'Error al guardar la configuración');
                }
                
            } catch (error) {
                console.error('Error:', error);
                showError('Error al guardar la configuración. Intenta nuevamente.');
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
            
            return false;
        });
    }
    
    // ==================== ANIMACIONES ====================
    document.addEventListener('DOMContentLoaded', function() {
        // Inicializar toggle de logos
        toggleLogoFields();
        
        // Animar tarjetas
        const cards = document.querySelectorAll('.card-modern');
        cards.forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            setTimeout(() => {
                card.style.transition = 'all 0.5s ease';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 100);
        });
    });
    
    // Inicializar tooltips
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
</script>
</body>
</html>