<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Mi Perfil - Tienda Elegante</title>
    <% if (negocio && negocio.icono_pagina && negocio.icono_pagina.imagen) { %>
        <link rel="icon" href="<%= negocio.icono_pagina.imagen %>" type="image/x-icon">
        <link rel="apple-touch-icon" href="<%= negocio.icono_pagina.imagen %>">
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <% 
        const _c = (negocio && negocio.colores) ? negocio.colores : {};
        const _p1             = _c.primary          || '#667eea';
        const _p2             = _c.secondary        || '#764ba2';
        const _bodyBg         = _c.bodyBg           || '#f5f7fb';
        const _textColor      = _c.textColor        || '#2d3748';
        const _navbarBg       = _c.navbarBg         || '#ffffff';
        const _navGrad        = (_c.navbarUsesGradient === 'true');
        const _logoColor      = _c.logoTextColor    || '#667eea';
        const _navLinkColor   = _c.navLinkColor     || '#2d3748';
        const _navLinkHover   = _c.navLinkHover     || '#ffffff';
        const _btnBg1         = _c.btnBg1           || _p1;
        const _btnBg2         = _c.btnBg2           || _p2;
        const _btnBg3         = _c.btnBg3           || _p2;
        const _btnMode        = _c.btnColorMode     || '2';
        const _btnTextColor   = _c.btnTextColor     || '#ffffff';
        const _sectionMode    = _c.sectionColorMode || '2';
        const _sectionColor1  = _c.sectionColor1    || _p1;
        const _sectionColor2  = _c.sectionColor2    || _p2;
        const _sectionColor3  = _c.sectionColor3    || _p2;
        const buildDynColor = (mode, c1, c2, c3) => {
            if (mode === '1') return c1;
            if (mode === '3') return `linear-gradient(135deg,${c1} 0%,${c2} 50%,${c3} 100%)`;
            return `linear-gradient(135deg,${c1} 0%,${c2} 100%)`;
        };
        const _navBgFinal     = _navGrad
            ? `linear-gradient(135deg,${_p1} 0%,${_p2} 100%)`
            : _navbarBg;
        const _navLinkFinal   = _navGrad ? 'rgba(255,255,255,0.92)' : _navLinkColor;
        const _sectionBgFinal = buildDynColor(_sectionMode, _sectionColor1, _sectionColor2, _sectionColor3);
        const _btnBgFinal     = buildDynColor(_btnMode, _btnBg1, _btnBg2, _btnBg3);
    %>
    <style>
        :root {
            --dyn-body-bg:       <%= _bodyBg %>;
            --dyn-text:          <%= _textColor %>;
            --dyn-navbar-bg:     <%= _navBgFinal %>;
            --dyn-nav-link:      <%= _navLinkFinal %>;
            --dyn-nav-hover-bg:  linear-gradient(135deg, <%= _p1 %> 0%, <%= _p2 %> 100%);
            --dyn-nav-hover-text:<%= _navLinkHover %>;
            --dyn-btn-gradient:  <%= _btnBgFinal %>;
            --dyn-btn-text:      <%= _btnTextColor %>;
            --dyn-section-bg:    <%= _sectionBgFinal %>;
        }
        body { background: var(--dyn-body-bg) !important; color: var(--dyn-text) !important; }
        .navbar { background: var(--dyn-navbar-bg) !important; }
        <% if (_navGrad) { %>
        .navbar-brand, .navbar-brand span, .logo-container i { color:#ffffff !important; background:none !important; }
        <% } else if (_c.logoTextColor) { %>
        .navbar-brand, .navbar-brand span, .logo-container i { color:<%= _logoColor %> !important; background:none !important; }
        <% } %>
        .navbar-nav .nav-link { color: var(--dyn-nav-link) !important; }
        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link:focus,
        .navbar-nav .nav-link.active {
            background: var(--dyn-nav-hover-bg) !important;
            color: var(--dyn-nav-hover-text) !important;
        }
        .profile-banner { background: var(--dyn-section-bg) !important; }
        .btn-primary, .btn-save-config, .btn-save-profile {
            background: var(--dyn-btn-gradient) !important;
            color: var(--dyn-btn-text) !important;
            border: none !important;
        }
    </style>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f5f7fb;
            padding-top: 76px;
        }
        
        .profile-banner {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 40px 0 30px;
            margin-bottom: 40px;
            border-radius: 0 0 30px 30px;
            color: white;
            position: relative;
            overflow: hidden;
        }
        
        .profile-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }
        
        .profile-avatar {
            width: 120px;
            height: 120px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 60px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            background: linear-gradient(135deg, #fff 0%, #f0f0f0 100%);
            position: relative;
            cursor: pointer;
            overflow: hidden;
            transition: transform 0.3s ease;
        }
        
        .profile-avatar:hover {
            transform: scale(1.05);
        }
        
        .profile-avatar:hover .avatar-overlay {
            opacity: 1;
        }
        
        .avatar-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
            color: white;
            font-size: 12px;
            cursor: pointer;
        }
        
        .avatar-overlay i {
            font-size: 24px;
            margin-bottom: 5px;
        }
        
        .profile-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-banner-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            overflow: hidden;
            border: 5px solid rgba(255,255,255,0.9);
            margin: 0 auto 20px;
            background: white;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        .profile-banner-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-name {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 10px;
        }
        
        .profile-email {
            font-size: 1rem;
            opacity: 0.95;
        }
        
        .profile-stats {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        
        .stat-badge {
            background: rgba(255,255,255,0.2);
            padding: 10px 20px;
            border-radius: 50px;
            backdrop-filter: blur(10px);
        }
        
        .card-modern {
            background: white;
            border-radius: 20px;
            border: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.07);
            margin-bottom: 25px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        .card-modern:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.12);
        }
        
        .card-header-modern {
            background: white;
            border-bottom: 2px solid #667eea;
            padding: 20px 25px;
            font-weight: 700;
            font-size: 1.1rem;
        }
        
        .card-header-modern i {
            color: #667eea;
            margin-right: 10px;
        }
        
        .info-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
        }
        
        .info-item {
            padding: 12px 0;
            border-bottom: 1px solid rgba(0,0,0,0.08);
        }
        
        .info-item:last-child {
            border-bottom: none;
        }
        
        .info-label {
            font-size: 0.8rem;
            color: #718096;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }
        
        .info-value {
            font-size: 1rem;
            font-weight: 600;
            color: #2d3748;
            margin: 0;
            word-break: break-word;
        }
        
        .form-group-modern {
            margin-bottom: 20px;
        }
        
        .form-group-modern label {
            font-weight: 600;
            margin-bottom: 8px;
            color: #2d3748;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .form-control-modern {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 12px 16px;
            transition: all 0.3s ease;
            width: 100%;
        }
        
        .form-control-modern:focus {
            border-color: #667eea;
            outline: none;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
        }
        
        textarea.form-control-modern {
            resize: vertical;
            min-height: 100px;
        }
        
        .btn-update {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
            width: 100%;
        }
        
        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(102,126,234,0.3);
        }
        
        .btn-password {
            background: linear-gradient(135deg, #ed8936 0%, #dd6b20 100%);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 12px;
            font-weight: 600;
            width: 100%;
        }
        
        .btn-password:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(237,137,54,0.3);
        }
        
        .alert-custom {
            border-radius: 12px;
            border: none;
            padding: 15px 20px;
            margin-bottom: 20px;
        }
        
        .alert-success-custom {
            background: linear-gradient(135deg, #d4fcda 0%, #c3e6cb 100%);
            color: #155724;
        }
        
        .alert-danger-custom {
            background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
            color: #721c24;
        }
        
        .upload-progress {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            z-index: 10000;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }
        
        .spinner-border {
            width: 40px;
            height: 40px;
        }
        
        .password-strength {
            margin-top: 5px;
            font-size: 0.8rem;
        }
        
        .strength-weak { color: #dc3545; }
        .strength-medium { color: #ffc107; }
        .strength-strong { color: #28a745; }
        
        @media (max-width: 768px) {
            body {
                padding-top: 60px;
            }

            .profile-banner {
                margin-top: 0;
                border-radius: 0 0 20px 20px;
            }

            .profile-header {
                padding: 30px 0 20px;
            }
            
            .profile-avatar {
                width: 90px;
                height: 90px;
                font-size: 45px;
            }
            
            .profile-name {
                font-size: 1.5rem;
            }
            
            .profile-stats {
                gap: 15px;
            }
            
            .stat-badge {
                padding: 6px 15px;
                font-size: 0.85rem;
            }
            
            .card-header-modern {
                padding: 15px 20px;
            }
            
            .info-card {
                margin-bottom: 15px;
            }
        }
        
        @media (max-width: 576px) {
            .profile-stats {
                flex-direction: column;
                align-items: center;
                gap: 10px;
            }
            
            .stat-badge {
                width: 80%;
                text-align: center;
            }
            
            .btn-update, .btn-password {
                padding: 10px 20px;
                font-size: 0.9rem;
            }
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .card-modern {
            animation: fadeInUp 0.5s ease forwards;
        }
        
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 0.6s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        .dropdown-user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 8px;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <div class="logo-container">
                    <% if (negocio.logoHeader && negocio.logoHeader.image && negocio.logoHeader.type !== 'text') { %>
                        <img src="<%= negocio.logoHeader.image %>" alt="<%= negocio.nombre %>" style="width: <%= negocio.logoHeader?.size || 150 %>px; max-width: 100%; object-fit: contain;">
                    <% } else { %>
                        <i class="fas fa-store"></i>
                        <span><%= negocio.logoHeader && negocio.logoHeader.text ? negocio.logoHeader.text : negocio.nombre %></span>
                    <% } %>
                </div>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/productos"><i class="fas fa-shopping-bag"></i> Productos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/carrito"><i class="fas fa-shopping-cart"></i> Carrito</a></li>
                    <% if (user) { %>
                        <li class="nav-item"><a class="nav-link" href="/mis-pedidos"><i class="fas fa-truck"></i> Mis Pedidos</a></li>
                        <li class="nav-item"><a class="nav-link" href="/perfil"><i class="fas fa-user-circle"></i> <%= user.nombre %></a></li>
                        <% if (user.rol === 'admin') { %>
                            <li class="nav-item"><a class="nav-link" href="/admin"><i class="fas fa-chart-line"></i> Admin</a></li>
                        <% } %>
                        <li class="nav-item"><a class="nav-link" href="/logout"><i class="fas fa-sign-out-alt"></i> Salir</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/login"><i class="fas fa-key"></i> Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/register"><i class="fas fa-user-plus"></i> Registro</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Header del perfil -->
    <div class="profile-banner">
        <div class="container">
            <div class="text-center">
                <div class="profile-banner-avatar">
                    <% if (user.foto_perfil) { %>
                        <img src="<%= user.foto_perfil %>" alt="Foto de perfil">
                    <% } else { %>
                        <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#f5f7fb; color:#667eea;">
                            <i class="fas fa-user-circle" style="font-size:50px;"></i>
                        </div>
                    <% } %>
                </div>
                <h1 class="profile-name"><i class="fas fa-user-circle"></i> <%= user.nombre %></h1>
                <p class="profile-email" style="margin: 10px 0 0;"><i class="fas fa-envelope"></i> <%= user.email %></p>
                <div class="profile-stats">
                    <div class="stat-badge">
                        <i class="fas fa-tag"></i> <strong><%= user.rol === 'admin' ? 'Administrador' : 'Cliente' %></strong>
                    </div>
                    <div class="stat-badge">
                        <i class="fas fa-check-circle"></i> <strong class="text-success">Activo</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container mb-5">
        <div class="row">
            <!-- Columna izquierda - Información rápida -->
            <div class="col-lg-4 mb-4">
                <div class="card-modern">
                    <div class="card-header-modern">
                        <i class="fas fa-info-circle"></i> Información Rápida
                    </div>
                    <div class="p-4">
                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-user"></i> Nombre completo
                            </div>
                            <div class="info-value"><%= user.nombre %></div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-envelope"></i> Correo electrónico
                            </div>
                            <div class="info-value"><%= user.email %></div>
                        </div>
                        <% if (user.telefono) { %>
                            <div class="info-item">
                                <div class="info-label">
                                    <i class="fas fa-phone"></i> Teléfono
                                </div>
                                <div class="info-value"><%= user.telefono %></div>
                            </div>
                        <% } %>
                        <% if (user.direccion) { %>
                            <div class="info-item">
                                <div class="info-label">
                                    <i class="fas fa-map-marker-alt"></i> Dirección
                                </div>
                                <div class="info-value"><%= user.direccion %></div>
                            </div>
                        <% } %>
                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-id-badge"></i> Rol
                            </div>
                            <div class="info-value">
                                <span class="badge bg-primary"><%= user.rol === 'admin' ? 'Administrador' : 'Cliente' %></span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Tarjeta de estadísticas -->
                <div class="info-card text-center">
                    <i class="fas fa-shopping-bag" style="font-size: 40px; margin-bottom: 15px;"></i>
                    <h3 class="mb-2">¡Bienvenido!</h3>
                    <p class="mb-0">Mantén tu información actualizada para recibir mejores ofertas</p>
                </div>
            </div>
            
            <!-- Columna derecha - Formularios de edición -->
            <div class="col-lg-8">
                <!-- Formulario de editar perfil -->
                <div class="card-modern">
                    <div class="card-header-modern">
                        <i class="fas fa-camera"></i> Foto de Perfil
                    </div>
                    <div class="p-4">
                        <div class="text-center">
                            <div class="profile-avatar" id="avatarContainer" style="margin: 0 auto 20px;">
                                <% if (user.foto_perfil) { %>
                                    <img src="<%= user.foto_perfil %>" alt="Foto de perfil" id="avatarImg">
                                <% } else { %>
                                    <i class="fas fa-user-circle" id="avatarIcon"></i>
                                <% } %>
                                <div class="avatar-overlay" id="avatarOverlay">
                                    <i class="fas fa-camera"></i>
                                    <span>Cambiar foto</span>
                                </div>
                            </div>
                            <p class="text-muted">Haz clic en tu foto para cambiarla</p>
                        </div>
                    </div>
                </div>
                
                <div class="card-modern">
                    <div class="card-header-modern">
                        <i class="fas fa-edit"></i> Editar Perfil
                    </div>
                    <div class="p-4">
                        <form id="profileForm">
                            <div class="form-group-modern">
                                <label for="nombre">
                                    <i class="fas fa-user text-primary"></i> Nombre completo *
                                </label>
                                <input type="text" class="form-control-modern" id="nombre" name="nombre" 
                                       value="<%= user.nombre %>" required>
                            </div>
                            
                            <div class="form-group-modern">
                                <label for="email">
                                    <i class="fas fa-envelope text-primary"></i> Correo electrónico
                                </label>
                                <input type="email" class="form-control-modern" id="email" 
                                       value="<%= user.email %>" disabled>
                                <small class="text-muted">El correo electrónico no puede ser modificado</small>
                            </div>
                            
                            <div class="form-group-modern">
                                <label for="telefono">
                                    <i class="fas fa-phone text-primary"></i> Teléfono
                                </label>
                                <input type="tel" class="form-control-modern" id="telefono" name="telefono" 
                                       value="<%= user.telefono || '' %>" placeholder="+54 11 1234-5678">
                            </div>
                            
                            <div class="form-group-modern">
                                <label for="direccion">
                                    <i class="fas fa-map-marker-alt text-primary"></i> Dirección
                                </label>
                                <textarea class="form-control-modern" id="direccion" name="direccion" 
                                          rows="3" placeholder="Calle, número, ciudad, código postal"><%= user.direccion || '' %></textarea>
                            </div>
                            
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn-update" id="updateBtn">
                                    <i class="fas fa-save"></i> Actualizar Perfil
                                </button>
                                <a href="/" class="btn btn-secondary" style="border-radius: 12px; padding: 12px 30px;">
                                    <i class="fas fa-times"></i> Cancelar
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
                
                <!-- Formulario de cambiar contraseña -->
                <div class="card-modern">
                    <div class="card-header-modern">
                        <i class="fas fa-key"></i> Cambiar Contraseña
                    </div>
                    <div class="p-4">
                        <form id="passwordForm">
                            <div class="form-group-modern">
                                <label for="current_password">
                                    <i class="fas fa-lock text-primary"></i> Contraseña actual *
                                </label>
                                <input type="password" class="form-control-modern" id="current_password" 
                                       name="current_password" required>
                            </div>
                            
                            <div class="form-group-modern">
                                <label for="new_password">
                                    <i class="fas fa-key text-primary"></i> Nueva contraseña *
                                </label>
                                <input type="password" class="form-control-modern" id="new_password" 
                                       name="new_password" required>
                                <small class="text-muted">Mínimo 6 caracteres</small>
                                <div id="passwordStrength" class="password-strength"></div>
                            </div>
                            
                            <div class="form-group-modern">
                                <label for="confirm_password">
                                    <i class="fas fa-check-circle text-primary"></i> Confirmar nueva contraseña *
                                </label>
                                <input type="password" class="form-control-modern" id="confirm_password" 
