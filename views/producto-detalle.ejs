<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= producto.nombre %> - <%= (negocio && negocio.titulos_paginas && negocio.titulos_paginas.producto_detalle ? negocio.titulos_paginas.producto_detalle : 'Producto') %></title>
    <% if (negocio && negocio.icono_pagina && negocio.icono_pagina.imagen) { %>
        <link rel="icon" href="<%= negocio.icono_pagina.imagen %>" type="image/x-icon">
        <link rel="apple-touch-icon" href="<%= negocio.icono_pagina.imagen %>">
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">
                <% if (negocio.logoHeader && negocio.logoHeader.type === 'image' && negocio.logoHeader.image) { %>
                    <img src="<%= negocio.logoHeader.image %>" alt="<%= negocio.nombre %>" style="width: <%= negocio.logoHeader?.size || 150 %>px; max-width: 100%; object-fit: contain;">
                <% } else { %>
                    <%= negocio.logoHeader && negocio.logoHeader.text ? negocio.logoHeader.text : negocio.nombre %>
                <% } %>
            </a>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-6">
                <img src="<%= producto.imagen || '/images/producto-default.jpg' %>" class="img-fluid rounded" alt="<%= producto.nombre %>">
            </div>
            <div class="col-md-6">
                <h1><%= producto.nombre %></h1>
                <p class="text-muted">Categoría: <%= producto.categoria %></p>
                <p><%= producto.descripcion %></p>
                <% const enOferta = producto.precio_oferta && parseFloat(producto.precio_oferta) > 0 && parseFloat(producto.precio_oferta) < parseFloat(producto.precio); %>
                <h2 class="text-success">
                    <% if (enOferta) { %>
                        <span class="text-decoration-line-through text-muted me-2">$<%= parseFloat(producto.precio).toFixed(2) %></span>
                        $<%= parseFloat(producto.precio_oferta).toFixed(2) %>
                    <% } else { %>
                        $<%= producto.precio %>
                    <% } %>
                </h2>
                <p class="text-muted">Stock: <%= producto.stock %> unidades</p>
                
                <form action="/carrito/add" method="POST">
                    <input type="hidden" name="id" value="<%= producto.id %>">
                    <input type="hidden" name="nombre" value="<%= producto.nombre %>">
                    <input type="hidden" name="precio" value="<%= enOferta ? producto.precio_oferta : producto.precio %>">
                    <input type="hidden" name="imagen" value="<%= producto.imagen %>">
                    <button type="submit" class="btn btn-primary btn-lg">Agregar al Carrito</button>
                    <a href="/productos" class="btn btn-secondary btn-lg">Volver</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>