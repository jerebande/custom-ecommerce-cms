<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title><%= negocio && negocio.titulos_paginas && negocio.titulos_paginas.indice ? negocio.titulos_paginas.indice : (negocio.nombre + ' - Tu tienda online') %></title>
    <% if (negocio && negocio.icono_pagina && negocio.icono_pagina.imagen) { %>
        <link rel="icon" href="<%= negocio.icono_pagina.imagen %>" type="image/x-icon">
        <link rel="apple-touch-icon" href="<%= negocio.icono_pagina.imagen %>">
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <!-- ===== COLORES DINÁMICOS ADMIN ===== -->
    <% 
        const _c = (negocio && negocio.colores) ? negocio.colores : {};
        const _p1             = _c.primary          || '#667eea';
        const _p2             = _c.secondary        || '#764ba2';
        const _bodyBg         = _c.bodyBg           || '#f5f7fb';
        const _textColor      = _c.textColor        || '#2d3748';
        const _navbarBg       = _c.navbarBg         || '#ffffff';
        const _navGrad        = (_c.navbarUsesGradient === 'true');
        const _logoColor      = _c.logoTextColor    || '#667eea';
        const _navLinkColor   = _c.navLinkColor     || '#2d3748';
        const _navLinkHover   = _c.navLinkHover     || '#ffffff';
        const _btnBg1         = _c.btnBg1           || _p1;
        const _btnBg2         = _c.btnBg2           || _p2;
        const _btnBg3         = _c.btnBg3           || _p2;
        const _btnMode        = _c.btnColorMode     || '2';
        const _btnTextColor   = _c.btnTextColor     || '#ffffff';
        const _iconColor      = _c.iconColor        || _p1;
        const _iconColor2     = _c.iconColor2       || _p2;
        const _sectionMode    = _c.sectionColorMode || '2';
        const _sectionColor1  = _c.sectionColor1    || _p1;
        const _sectionColor2  = _c.sectionColor2    || _p2;
        const _sectionColor3  = _c.sectionColor3    || _p2;
        const _textMode       = _c.textColorMode    || '1';
        const _textColor1     = _c.textColor1       || _textColor;
        const _textColor2     = _c.textColor2       || _p1;
        const _textColor3     = _c.textColor3       || _p2;
        const _navBgFinal     = _navGrad
            ? `linear-gradient(135deg,${_p1} 0%,${_p2} 100%)`
            : _navbarBg;
        const _navLinkFinal   = _navGrad ? 'rgba(255,255,255,0.92)' : _navLinkColor;
        const buildDynColor = (mode, c1, c2, c3) => {
            if (mode === '1') return c1;
            if (mode === '3') return `linear-gradient(135deg, ${c1} 0%, ${c2} 50%, ${c3} 100%)`;
            return `linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`;
        };
        const _sectionBgFinal = buildDynColor(_sectionMode, _sectionColor1, _sectionColor2, _sectionColor3);
        const _btnBgFinal     = buildDynColor(_btnMode, _btnBg1, _btnBg2, _btnBg3);
        const _textAccentBg   = buildDynColor(_textMode, _textColor1, _textColor2, _textColor3);
    %>
    <style>
        :root {
            --dyn-p1:            <%= _p1 %>;
            --dyn-p2:            <%= _p2 %>;
            --dyn-body-bg:       <%= _bodyBg %>;
            --dyn-text:          <%= _textColor %>;
            --dyn-navbar-bg:     <%= _navBgFinal %>;
            --dyn-nav-link:      <%= _navLinkFinal %>;
            --dyn-nav-hover-bg:  linear-gradient(135deg, <%= _p1 %> 0%, <%= _p2 %> 100%);
            --dyn-nav-hover-text:<%= _navLinkHover %>;
            --dyn-btn1:          <%= _btnBg1 %>;
            --dyn-btn2:          <%= _btnBg2 %>;
            --dyn-btn-text:      <%= _btnTextColor %>;
            --dyn-icon1:         <%= _iconColor %>;
            --dyn-icon2:         <%= _iconColor2 %>;
            --dyn-gradient:      linear-gradient(135deg, var(--dyn-p1) 0%, var(--dyn-p2) 100%);
            --dyn-btn-gradient:  <%= _btnBgFinal %>;
            --dyn-icon-gradient: linear-gradient(135deg, var(--dyn-icon1) 0%, var(--dyn-icon2) 100%);
            --dyn-section-bg:    <%= _sectionBgFinal %>;
            --dyn-text-accent-bg:<%= _textAccentBg %>;
            --primary:   var(--dyn-p1);
            --secondary: var(--dyn-p2);
            --gradient:  var(--dyn-gradient);
        }

        body { background: var(--dyn-body-bg) !important; color: var(--dyn-text) !important; }
        .navbar { background: var(--dyn-navbar-bg) !important; }

        <% if (_navGrad) { %>
        .navbar-brand,
        .navbar-brand span,
        .logo-container i {
            background: none !important;
            -webkit-background-clip: unset !important;
            background-clip: unset !important;
            color: #ffffff !important;
        }
        <% } else if (_c.logoTextColor) { %>
        .navbar-brand,
        .navbar-brand span,
        .logo-container i {
            background: none !important;
            -webkit-background-clip: unset !important;
            background-clip: unset !important;
            color: <%= _logoColor %> !important;
        }
        <% } %>

        <% if (_c.navLinkColor || _navGrad) { %>
        .navbar-nav .nav-link {
            color: var(--dyn-nav-link) !important;
        }
        <% } %>
        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link:focus,
        .navbar-nav .nav-link.active {
            background: var(--dyn-nav-hover-bg) !important;
            color: var(--dyn-nav-hover-text) !important;
        }

        .navbar-toggler { background: var(--dyn-gradient) !important; border: none !important; }
        .hero-section,
        .cart-header,
        .products-header,
        .orders-header { background: var(--dyn-section-bg) !important; }
        .btn-primary {
            background: var(--dyn-btn-gradient) !important;
            border-color: var(--dyn-btn1) !important;
            color: var(--dyn-btn-text) !important;
        }
        .btn-primary:hover { opacity: 0.9; filter: brightness(1.05); color: var(--dyn-btn-text) !important; }
        form[action="/carrito/add"] button[type="submit"],
        .btn-add-to-cart,
        .producto-card .btn,
        .btn-gradient {
            background: var(--dyn-btn-gradient) !important;
            border: none !important;
            color: var(--dyn-btn-text) !important;
        }
        .feature-icon-modern,
        .stats-icon-client,
        .icon-circle { background: var(--dyn-icon-gradient) !important; }
        .total-amount { color: var(--dyn-p1) !important; }
        .categoria-title { border-bottom-color: var(--dyn-p1) !important; }
        .categoria-title i { color: var(--dyn-p1) !important; }
        .text-accent-gradient {
            background: var(--dyn-text-accent-bg);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
    </style>
    <style>
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 80vh;
            display: flex;
            align-items: center;
            margin-top: -70px;
            padding-top: 70px;
        }
        
        .hero-title {
            font-size: 4rem;
            font-weight: 800;
            margin-bottom: 20px;
        }
        
        .feature-card-modern {
            background: white;
            border-radius: 20px;
            padding: 35px;
            text-align: center;
            transition: all 0.3s ease;
            height: 100%;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        
        .feature-card-modern:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 30px rgba(0,0,0,0.15);
        }
        
        .feature-icon-modern {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            font-size: 35px;
            color: white;
        }
        
        @media (max-width: 768px) {
            .hero-title {
                font-size: 2rem;
            }
            
            .hero-section {
                min-height: 60vh;
            }
            
            .feature-card-modern {
                padding: 25px;
                margin-bottom: 20px;
            }
            
            .feature-icon-modern {
                width: 60px;
                height: 60px;
                font-size: 25px;
            }
        }
    </style>
</head>
<body>
    <!-- Navbar con menú hamburguesa -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <div class="logo-container">
                    <% if (negocio.logoHeader && negocio.logoHeader.image && negocio.logoHeader.type !== 'text') { %>
                        <img src="<%= negocio.logoHeader.image %>" alt="<%= negocio.nombre %>" style="width: <%= negocio.logoHeader?.size || 150 %>px; max-width: 100%; object-fit: contain;">
                    <% } else { %>
                        <i class="fas fa-store"></i>
                        <span><%= negocio.logoHeader && negocio.logoHeader.text ? negocio.logoHeader.text : negocio.nombre %></span>
                    <% } %>
                </div>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/productos"><i class="fas fa-shopping-bag"></i> Productos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/carrito"><i class="fas fa-shopping-cart"></i> Carrito</a></li>
                    <% if (user) { %>
                        <li class="nav-item"><a class="nav-link" href="/mis-pedidos"><i class="fas fa-truck"></i> Mis Pedidos</a></li>
                        <li class="nav-item"><a class="nav-link" href="/perfil"><i class="fas fa-user-circle"></i> <%= user.nombre %></a></li>
                        <% if (user.rol === 'admin') { %>
                            <li class="nav-item"><a class="nav-link" href="/admin"><i class="fas fa-chart-line"></i> Admin</a></li>
                        <% } %>
                        <li class="nav-item"><a class="nav-link" href="/logout"><i class="fas fa-sign-out-alt"></i> Salir</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/login"><i class="fas fa-key"></i> Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/register"><i class="fas fa-user-plus"></i> Registro</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="text-center text-white">
                <h1 class="hero-title"><%= negocio.home?.hero?.titulo || 'Bienvenido a Tienda Elegante' %></h1>
                <p class="lead mb-4"><%= negocio.home?.hero?.descripcion || 'Descubre productos de alta calidad con los mejores precios' %></p>
                <a href="<%= negocio.home?.hero?.boton_url || '/productos' %>" class="btn btn-light btn-lg">
                    <i class="fas fa-arrow-right"></i> <%= negocio.home?.hero?.boton_texto || 'Explorar Productos' %>
                </a>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <div class="container mt-5 pt-4">
        <div class="row g-4">
            <% const features = negocio.home?.features || []; %>
            <% if (features.length > 0) { %>
                <% features.forEach(feature => { %>
                    <div class="col-md-4 col-sm-6 col-12">
                        <div class="feature-card-modern">
                            <div class="feature-icon-modern">
                                <i class="<%= feature.icono || 'fas fa-gem' %>"></i>
                            </div>
                            <h3><%= feature.titulo || 'Característica' %></h3>
                            <p class="text-muted"><%= feature.descripcion || '' %></p>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-md-4 col-sm-6 col-12">
                    <div class="feature-card-modern">
                        <div class="feature-icon-modern">
                            <i class="fas fa-gem"></i>
                        </div>
                        <h3>Productos Premium</h3>
                        <p class="text-muted">Los mejores productos seleccionados para ti</p>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6 col-12">
                    <div class="feature-card-modern">
                        <div class="feature-icon-modern">
                            <i class="fas fa-rocket"></i>
                        </div>
                        <h3>Envío Rápido</h3>
                        <p class="text-muted">Entregas en tiempo récord</p>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6 col-12">
                    <div class="feature-card-modern">
                        <div class="feature-icon-modern">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <h3>Pago Seguro</h3>
                        <p class="text-muted">Múltiples métodos de pago</p>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Call to Action para usuarios no logueados -->
    <div class="container mt-5 mb-5">
        <% if (!user) { %>
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card text-center border-0 shadow-lg">
                        <div class="card-body p-5">
                            <h3>¿Listo para comenzar?</h3>
                            <p class="text-muted">Únete a nuestra comunidad y disfruta de los mejores productos</p>
                            <div>
                                <a href="/login" class="btn btn-primary me-2">Iniciar Sesión</a>
                                <a href="/register" class="btn btn-success">Registrarse</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    
    <%- include('./footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>