    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        let productoAEliminar = null;
        let selectedCategoriaAdd = '';
        let selectedCategoriaEdit = '';
        
        const productosData = <%- JSON.stringify(productos) %>;
        
        function checkCarouselNeedsScroll(carouselElement, prevBtn, nextBtn) {
            if (!carouselElement) return;
            
            const needsScroll = carouselElement.scrollWidth > carouselElement.clientWidth;
            const productCards = carouselElement.querySelectorAll('.product-card-modern');
            const isMobile = window.innerWidth <= 768;
            
            if (prevBtn && nextBtn) {
                if (needsScroll) {
                    prevBtn.classList.remove('hidden');
                    nextBtn.classList.remove('hidden');
                    carouselElement.classList.remove('center-items');
                    carouselElement.classList.add('no-scroll-left');
                } else {
                    prevBtn.classList.add('hidden');
                    nextBtn.classList.add('hidden');
                    
                    if (isMobile && productCards.length === 1) {
                        carouselElement.classList.add('center-items');
                        carouselElement.classList.remove('no-scroll-left');
                    } else {
                        carouselElement.classList.remove('center-items');
                        carouselElement.classList.add('no-scroll-left');
                    }
                }
            }
        }
        
        function scrollCarousel(button, direction) {
            const carousel = button.parentElement.querySelector('.productos-carousel');
            if (!carousel) return;
            
            const scrollAmount = carousel.clientWidth * 0.8;
            
            if (direction === 'next') {
                carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
            } else {
                carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
            }
        }
        
        function initAllCarousels() {
            document.querySelectorAll('.categoria-carousel-container').forEach(container => {
                const carousel = container.querySelector('.productos-carousel');
                const prevBtn = container.querySelector('.carousel-nav-prev');
                const nextBtn = container.querySelector('.carousel-nav-next');
                
                if (carousel) {
                    checkCarouselNeedsScroll(carousel, prevBtn, nextBtn);
                    
                    window.addEventListener('resize', () => {
                        checkCarouselNeedsScroll(carousel, prevBtn, nextBtn);
                    });
                    
                    const images = carousel.querySelectorAll('img');
                    let imagesLoaded = 0;
                    if (images.length > 0) {
                        images.forEach(img => {
                            if (img.complete) {
                                imagesLoaded++;
                                if (imagesLoaded === images.length) {
                                    checkCarouselNeedsScroll(carousel, prevBtn, nextBtn);
                                }
                            } else {
                                img.addEventListener('load', () => {
                                    imagesLoaded++;
                                    if (imagesLoaded === images.length) {
                                        checkCarouselNeedsScroll(carousel, prevBtn, nextBtn);
                                    }
                                });
                            }
                        });
                    } else {
                        checkCarouselNeedsScroll(carousel, prevBtn, nextBtn);
                    }
                }
            });
        }
        
        document.addEventListener('DOMContentLoaded', () => {
            initAllCarousels();
        });
        
        document.querySelectorAll('.categoria-filter-badge').forEach(badge => {
            badge.addEventListener('click', function(e) {
                if (e.target.closest('.delete-categoria-btn')) return;
                const categoria = this.getAttribute('data-categoria');
                const categoriaInput = document.getElementById('categoriaInput');
                const filterForm = document.getElementById('filterForm');
                if (categoriaInput) categoriaInput.value = categoria;
                if (filterForm) filterForm.submit();
            });
        });
        
        function deleteCategoria(categoria) {
            if (confirm(`¿Eliminar la categoría "${categoria}"?\nLos productos en esta categoría pasarán a "Otros".`)) {
                fetch('/admin/categorias/delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ categoria: categoria })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Categoría eliminada correctamente');
                        location.reload();
                    } else {
                        alert('Error al eliminar la categoría: ' + data.error);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error al eliminar la categoría');
                });
            }
        }
        
        function openAddProductModal() {
            resetAddForm();
            const addProductModal = document.getElementById('addProductModal');
            if (addProductModal) {
                const modal = new bootstrap.Modal(addProductModal);
                modal.show();
            }
        }
        
        function resetAddForm() {
            const addNombre = document.getElementById('add_nombre');
            const addDescripcion = document.getElementById('add_descripcion');
            const addPrecio = document.getElementById('add_precio');
            const addStock = document.getElementById('add_stock');
            const addCategoria = document.getElementById('add_categoria');
            const addImagenFile = document.getElementById('add_imagenFile');
            const addImagePreview = document.getElementById('add_imagePreview');
            
            if (addNombre) addNombre.value = '';
            if (addDescripcion) addDescripcion.value = '';
            if (addPrecio) addPrecio.value = '';
            const addPrecioOferta = document.getElementById('add_precio_oferta');
            if (addPrecioOferta) addPrecioOferta.value = '';
            if (addStock) addStock.value = '';
            if (addCategoria) addCategoria.value = '';
            if (addImagenFile) addImagenFile.value = '';
            if (addImagePreview) addImagePreview.style.display = 'none';
            
            document.querySelectorAll('#add_categoriaGroup .categoria-badge').forEach(badge => {
                badge.classList.remove('selected');
            });
            selectedCategoriaAdd = '';
        }
        
        function previewAddImage(input) {
            const preview = document.getElementById('add_imagePreview');
            if (preview && input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
        
        document.querySelectorAll('#add_categoriaGroup .categoria-badge').forEach(badge => {
            badge.addEventListener('click', function() {
                const categoria = this.getAttribute('data-categoria');
                document.querySelectorAll('#add_categoriaGroup .categoria-badge').forEach(b => {
                    b.classList.remove('selected');
                });
                this.classList.add('selected');
                const addCategoria = document.getElementById('add_categoria');
                if (addCategoria) addCategoria.value = categoria;
                selectedCategoriaAdd = categoria;
            });
        });
        
        const addCategoriaInput = document.getElementById('add_categoria');
        if (addCategoriaInput) {
            addCategoriaInput.addEventListener('input', function() {
                if (this.value) {
                    document.querySelectorAll('#add_categoriaGroup .categoria-badge').forEach(b => {
                        b.classList.remove('selected');
                    });
                    selectedCategoriaAdd = this.value;
                }
            });
        }
        
        function validateAddForm() {
            const nombre = document.getElementById('add_nombre')?.value || '';
            const precio = document.getElementById('add_precio')?.value || '';
            const stock = document.getElementById('add_stock')?.value || '';
            const categoria = document.getElementById('add_categoria')?.value || '';
            const imagenFile = document.getElementById('add_imagenFile')?.files?.[0];
            
            if (!nombre.trim()) { alert('Ingresa el nombre del producto'); return false; }
            if (!precio || parseFloat(precio) <= 0) { alert('Ingresa un precio válido'); return false; }
            if (!stock || parseInt(stock) < 0) { alert('Ingresa un stock válido'); return false; }
            if (!categoria) { alert('Selecciona una categoría'); return false; }
            if (!imagenFile) { alert('Selecciona una imagen'); return false; }
            if (imagenFile && imagenFile.size > 5 * 1024 * 1024) { alert('La imagen no puede superar los 5MB'); return false; }
            return true;
        }
        
        function openEditProductModal(productoId) {
            const producto = productosData.find(p => p.id == productoId);
            if (!producto) {
                console.error("Producto no encontrado:", productoId);
                alert("Error: Producto no encontrado");
                return;
            }
            
            const editId = document.getElementById('edit_id');
            const editNombre = document.getElementById('edit_nombre');
            const editDescripcion = document.getElementById('edit_descripcion');
            const editPrecio = document.getElementById('edit_precio');
            const editStock = document.getElementById('edit_stock');
            const editCategoria = document.getElementById('edit_categoria');
            const editImagen = document.getElementById('edit_imagen');
            const editCurrentImage = document.getElementById('edit_currentImage');
            const editImagePreview = document.getElementById('edit_imagePreview');
            const editImagenFile = document.getElementById('edit_imagenFile');
            
            if (editId) editId.value = producto.id;
            if (editNombre) editNombre.value = producto.nombre;
            if (editDescripcion) editDescripcion.value = producto.descripcion || '';
            if (editPrecio) editPrecio.value = producto.precio;
            const editPrecioOferta = document.getElementById('edit_precio_oferta');
            if (editPrecioOferta) editPrecioOferta.value = producto.precio_oferta || '';
            if (editStock) editStock.value = producto.stock;
            if (editCategoria) editCategoria.value = producto.categoria;
            if (editImagen) editImagen.value = producto.imagen || '';
            if (editCurrentImage) editCurrentImage.src = producto.imagen || '/images/producto-default.jpg';
            if (editImagePreview) editImagePreview.style.display = 'none';
            if (editImagenFile) editImagenFile.value = '';
            
            document.querySelectorAll('#edit_categoriaGroup .categoria-badge').forEach(badge => {
                badge.classList.remove('selected');
                if (badge.getAttribute('data-categoria') === producto.categoria) {
                    badge.classList.add('selected');
                }
            });
            selectedCategoriaEdit = producto.categoria;
            
            const editProductModal = document.getElementById('editProductModal');
            if (editProductModal) {
                const modal = new bootstrap.Modal(editProductModal);
                modal.show();
            }
        }
        
        function previewEditImage(input) {
            const preview = document.getElementById('edit_imagePreview');
            if (preview && input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
        
        document.querySelectorAll('#edit_categoriaGroup .categoria-badge').forEach(badge => {
            badge.addEventListener('click', function() {
                const categoria = this.getAttribute('data-categoria');
                document.querySelectorAll('#edit_categoriaGroup .categoria-badge').forEach(b => {
                    b.classList.remove('selected');
                });
                this.classList.add('selected');
                const editCategoria = document.getElementById('edit_categoria');
                if (editCategoria) editCategoria.value = categoria;
                selectedCategoriaEdit = categoria;
            });
        });
        
        const editCategoriaInput = document.getElementById('edit_categoria');
        if (editCategoriaInput) {
            editCategoriaInput.addEventListener('input', function() {
                if (this.value) {
                    document.querySelectorAll('#edit_categoriaGroup .categoria-badge').forEach(b => {
                        b.classList.remove('selected');
                    });
                    selectedCategoriaEdit = this.value;
                }
            });
        }
        
        function validateEditForm() {
            const nombre = document.getElementById('edit_nombre')?.value || '';
            const precio = document.getElementById('edit_precio')?.value || '';
            const stock = document.getElementById('edit_stock')?.value || '';
            const categoria = document.getElementById('edit_categoria')?.value || '';
            
            if (!nombre.trim()) { alert('Ingresa el nombre del producto'); return false; }
            if (!precio || parseFloat(precio) <= 0) { alert('Ingresa un precio válido'); return false; }
            if (!stock || parseInt(stock) < 0) { alert('Ingresa un stock válido'); return false; }
            if (!categoria) { alert('Selecciona una categoría'); return false; }
            return true;
        }
        
        function confirmDeleteProduct(productoId) {
            productoAEliminar = productoId;
            const deleteConfirmModal = document.getElementById('deleteConfirmModal');
            if (deleteConfirmModal) {
                const modal = new bootstrap.Modal(deleteConfirmModal);
                modal.show();
            }
        }
        
        const confirmDeleteBtn = document.getElementById('confirmDeleteBtn');
        if (confirmDeleteBtn) {
            confirmDeleteBtn.addEventListener('click', function() {
                if (productoAEliminar) {
                    window.location.href = `/admin/productos/delete/${productoAEliminar}`;
                }
            });
        }
    </script>
</body>
</html>