<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Finalizar Compra</title>
    <% if (negocio && negocio.icono_pagina && negocio.icono_pagina.imagen) { %>
        <link rel="icon" href="<%= negocio.icono_pagina.imagen %>" type="image/x-icon">
        <link rel="apple-touch-icon" href="<%= negocio.icono_pagina.imagen %>">
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <!-- ===== COLORES DINÁMICOS ADMIN ===== -->
    <% 
        const _c = (negocio && negocio.colores) ? negocio.colores : {};
        const _p1             = _c.primary          || '#667eea';
        const _p2             = _c.secondary        || '#764ba2';
        const _bodyBg         = _c.bodyBg           || '#f5f7fb';
        const _textColor      = _c.textColor        || '#2d3748';
        const _navbarBg       = _c.navbarBg         || '#ffffff';
        const _navGrad        = (_c.navbarUsesGradient === 'true');
        const _logoColor      = _c.logoTextColor    || '#667eea';
        const _navLinkColor   = _c.navLinkColor     || '#2d3748';
        const _navLinkHover   = _c.navLinkHover     || '#ffffff';
        const _btnBg1         = _c.btnBg1           || _p1;
        const _btnBg2         = _c.btnBg2           || _p2;
        const _btnBg3         = _c.btnBg3           || _p2;
        const _btnMode        = _c.btnColorMode     || '2';
        const _btnTextColor   = _c.btnTextColor     || '#ffffff';
        const _iconColor      = _c.iconColor        || _p1;
        const _iconColor2     = _c.iconColor2       || _p2;
        const _navBgFinal     = _navGrad
            ? `linear-gradient(135deg,${_p1} 0%,${_p2} 100%)`
            : _navbarBg;
        const _navLinkFinal   = _navGrad ? 'rgba(255,255,255,0.92)' : _navLinkColor;
        const buildDynColor = (mode, c1, c2, c3) => {
            if (mode === '1') return c1;
            if (mode === '3') return `linear-gradient(135deg, ${c1} 0%, ${c2} 50%, ${c3} 100%)`;
            return `linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`;
        };
        const _btnBgFinal     = buildDynColor(_btnMode, _btnBg1, _btnBg2, _btnBg3);
    %>
    <style>
        :root {
            --dyn-p1:            <%= _p1 %>;
            --dyn-p2:            <%= _p2 %>;
            --dyn-body-bg:       <%= _bodyBg %>;
            --dyn-text:          <%= _textColor %>;
            --dyn-navbar-bg:     <%= _navBgFinal %>;
            --dyn-nav-link:      <%= _navLinkFinal %>;
            --dyn-nav-hover-bg:  linear-gradient(135deg, <%= _p1 %> 0%, <%= _p2 %> 100%);
            --dyn-nav-hover-text:<%= _navLinkHover %>;
            --dyn-btn1:          <%= _btnBg1 %>;
            --dyn-btn2:          <%= _btnBg2 %>;
            --dyn-btn-text:      <%= _btnTextColor %>;
            --dyn-icon1:         <%= _iconColor %>;
            --dyn-icon2:         <%= _iconColor2 %>;
            --dyn-gradient:      linear-gradient(135deg, var(--dyn-p1) 0%, var(--dyn-p2) 100%);
            --dyn-btn-gradient:  <%= _btnBgFinal %>;
            --dyn-icon-gradient: linear-gradient(135deg, var(--dyn-icon1) 0%, var(--dyn-icon2) 100%);
            --primary:   var(--dyn-p1);
            --secondary: var(--dyn-p2);
            --gradient:  var(--dyn-gradient);
        }

        body { background: var(--dyn-body-bg) !important; color: var(--dyn-text) !important; }
        .navbar { background: var(--dyn-navbar-bg) !important; }

        <% if (_navGrad) { %>
        .navbar-brand,
        .navbar-brand span,
        .logo-container i {
            background: none !important;
            -webkit-background-clip: unset !important;
            background-clip: unset !important;
            color: #ffffff !important;
        }
        <% } else if (_c.logoTextColor) { %>
        .navbar-brand,
        .navbar-brand span,
        .logo-container i {
            background: none !important;
            -webkit-background-clip: unset !important;
            background-clip: unset !important;
            color: <%= _logoColor %> !important;
        }
        <% } %>

        <% if (_c.navLinkColor || _navGrad) { %>
        .navbar-nav .nav-link {
            color: var(--dyn-nav-link) !important;
        }
        <% } %>
        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link:focus,
        .navbar-nav .nav-link.active {
            background: var(--dyn-nav-hover-bg) !important;
            color: var(--dyn-nav-hover-text) !important;
        }

        .navbar-toggler { background: var(--dyn-gradient) !important; border: none !important; }
        
        .btn-primary {
            background: var(--dyn-btn-gradient) !important;
            border-color: var(--dyn-btn1) !important;
            color: var(--dyn-btn-text) !important;
        }
        .btn-primary:hover { opacity: 0.9; filter: brightness(1.05); color: var(--dyn-btn-text) !important; }

        .btn-confirm {
            background: var(--dyn-btn-gradient) !important;
            border: none !important;
            color: var(--dyn-btn-text) !important;
        }

        .feature-icon-modern,
        .stats-icon-client,
        .icon-circle { background: var(--dyn-icon-gradient) !important; }
        
        .entrega-opt.active {
            border-color: var(--dyn-p1) !important;
            background: linear-gradient(135deg, rgba(var(--dyn-p1),0.08), rgba(var(--dyn-p2),0.08)) !important;
        }
        .entrega-opt i { color: var(--dyn-p1) !important; }
        .badge-modo { border-color: var(--dyn-p1) !important; color: var(--dyn-p1) !important; }
        
        .form-control:focus, .form-select:focus {
            border-color: var(--dyn-p1) !important;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.12) !important;
        }
    </style>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .checkout-card {
            background: white;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.12);
            margin-top: 90px;
            margin-bottom: 40px;
        }
        .form-section {
            background: #f8fafc;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 20px;
            border: 1px solid #e2e8f0;
        }
        .form-section h5 { font-weight: 700; margin-bottom: 16px; color: #1e293b; }
        .order-summary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 20px;
            padding: 28px;
            position: sticky;
            top: 100px;
        }
        .order-summary h4 { font-weight: 700; margin-bottom: 20px; }
        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            opacity: 0.92;
            font-size: 0.95rem;
        }
        .summary-row.tarifa-row { font-size: 0.9rem; opacity: 0.85; }
        .summary-row.incluido-row { font-size: 0.8rem; opacity: 0.7; font-style: italic; }
        .summary-total {
            display: flex;
            justify-content: space-between;
            font-size: 1.2rem;
            font-weight: 700;
            padding-top: 12px;
        }
        .summary-divider { border-color: rgba(255,255,255,0.3); margin: 12px 0; }
        .entrega-opts { display: flex; gap: 12px; margin-bottom: 4px; flex-wrap: wrap; }
        .entrega-opt {
            flex: 1; min-width: 120px;
            border: 2px solid #e2e8f0;
            border-radius: 14px;
            padding: 16px 14px;
            cursor: pointer;
            text-align: center;
            transition: all 0.25s;
            background: white;
        }
        .entrega-opt:hover { border-color: #667eea; }
        .entrega-opt i { font-size: 1.5rem; display: block; margin-bottom: 6px; color: #667eea; }
        .entrega-opt span { font-weight: 600; font-size: 0.9rem; color: #1e293b; }
        .entrega-opt small { display: block; color: #64748b; font-size: 0.75rem; margin-top: 2px; }
        .info-retiro {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 12px;
            padding: 14px 18px;
            margin-top: 14px;
            font-size: 0.88rem;
            color: #166534;
        }
        .badge-modo {
            display: inline-block;
            background: linear-gradient(135deg,rgba(102,126,234,0.12),rgba(118,75,162,0.12));
            border: 1.5px solid #667eea;
            color: #4c51bf;
            border-radius: 30px;
            padding: 6px 18px;
            font-size: 0.88rem;
            font-weight: 600;
        }
        .nota-gratis { font-size: 0.78rem; opacity: 0.78; margin-top: 3px; text-align: right; }
        .form-control, .form-select {
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 10px 14px;
        }
        .form-control:focus, .form-select:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.12);
        }
        .btn-confirm {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none; color: white;
            padding: 14px;
            border-radius: 14px;
            font-weight: 700; font-size: 1rem;
            width: 100%;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .btn-confirm:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(102,126,234,0.35); }
        @media (max-width: 768px) {
            .checkout-card { padding: 20px; margin-top: 70px; }
            .order-summary { margin-top: 20px; position: static; }
            .form-section { padding: 16px; }
        }
    </style>
</head>
<body>

    <!-- Navbar - MISMO QUE INDEX.EJS -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <div class="logo-container">
                    <% if (negocio.logoHeader && negocio.logoHeader.type === 'image' && negocio.logoHeader.image) { %>
                        <img src="<%= negocio.logoHeader.image %>" alt="<%= negocio.nombre %>"
                             style="width:<%= negocio.logoHeader?.size||150 %>px;max-width:100%;object-fit:contain;">
                    <% } else if (negocio.logoHeader && negocio.logoHeader.type === 'image' && negocio.logoHeader.image) { %>
                        <img src="<%= negocio.logoHeader.image %>" alt="<%= negocio.nombre %>"
                             style="width:<%= negocio.logoHeader?.size||150 %>px;max-width:100%;object-fit:contain;">
                    <% } else if (negocio.logoHeader && negocio.logoHeader.image && negocio.logoHeader.type !== 'text') { %>
                        <img src="<%= negocio.logoHeader.image %>" alt="<%= negocio.nombre %>" style="width: <%= negocio.logoHeader?.size || 150 %>px; max-width: 100%; object-fit: contain;">
                    <% } else { %>
                        <i class="fas fa-store"></i>
                        <span><%= negocio.logoHeader && negocio.logoHeader.text ? negocio.logoHeader.text : (negocio.nombre || 'Tienda Elegante') %></span>
                    <% } %>
                </div>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/productos"><i class="fas fa-shopping-bag"></i> Productos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/carrito"><i class="fas fa-shopping-cart"></i> Carrito</a></li>
                    <% if (user) { %>
                        <li class="nav-item"><a class="nav-link" href="/mis-pedidos"><i class="fas fa-truck"></i> Mis Pedidos</a></li>
                        <li class="nav-item"><a class="nav-link" href="/perfil"><i class="fas fa-user-circle"></i> <%= user.nombre %></a></li>
                        <% if (user.rol === 'admin') { %>
                            <li class="nav-item"><a class="nav-link" href="/admin"><i class="fas fa-chart-line"></i> Admin</a></li>
                        <% } %>
                        <li class="nav-item"><a class="nav-link" href="/logout"><i class="fas fa-sign-out-alt"></i> Salir</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/login"><i class="fas fa-key"></i> Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/register"><i class="fas fa-user-plus"></i> Registro</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTINÚA EL RESTO DEL CONTENIDO DEL CHECKOUT ORIGINAL -->
    <div class="container">
        <div class="checkout-card">
            <div class="text-center mb-4">
                <h2 style="font-weight:800;">
                    <i class="fas fa-clipboard-list" style="color:#667eea;"></i> Finalizar Pedido
                </h2>
                <p class="text-muted">Completá tus datos para confirmar la compra</p>
            </div>

            <% if (error) { %>
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-2"></i><%= error %>
            </div>
            <% } %>

            <div class="row g-4">
                <div class="col-lg-7">
                    <form action="/checkout" method="POST" id="checkoutForm" enctype="multipart/form-data">
                        <%
                            const cfg = (typeof pedidosConfig !== 'undefined' && pedidosConfig) ? pedidosConfig : {};
                            const modoOp = cfg.modoOperacion || 'hibrido';
                            const tarifas = cfg.tarifas || {};
                            const envioConf = tarifas.envio || {};
                            const impConf = tarifas.impuesto || {};
                            const extraConf = tarifas.extra || {};
                            const modoInicialDisplay = (modoOp === 'retiro') ? 'retiro' : 'delivery';
                            const sub = parseFloat(subtotal) || 0;
                        %>
                        <input type="hidden" name="modo_entrega" id="modoEntregaInput" value="<%= modoInicialDisplay %>">

                        <% if (modoOp === 'hibrido') { %>
                        <div class="form-section">
                            <h5><i class="fas fa-route"></i> ¿Cómo recibís tu pedido?</h5>
                            <div class="entrega-opts">
                                <div class="entrega-opt active" id="opt-delivery" onclick="selectEntrega('delivery')">
                                    <i class="fas fa-motorcycle"></i>
                                    <span>Delivery</span>
                                    <small>Lo recibís en tu domicilio</small>
                                </div>
                                <div class="entrega-opt" id="opt-retiro" onclick="selectEntrega('retiro')">
                                    <i class="fas fa-store"></i>
                                    <span>Retiro en local</span>
                                    <small>Pasás a buscarlo vos</small>
                                </div>
                            </div>
                        </div>
                        <% } else if (modoOp === 'retiro') { %>
                        <div class="form-section">
                            <h5><i class="fas fa-store"></i> Retiro en local</h5>
                            <p class="text-muted mb-2" style="font-size:0.9rem;">Tu pedido estará listo para retirar en nuestro local.</p>
                            <span class="badge-modo"><i class="fas fa-check-circle me-1"></i>Solo retiro en local</span>
                        </div>
                        <% } else { %>
                        <div class="form-section">
                            <h5><i class="fas fa-motorcycle"></i> Delivery a domicilio</h5>
                            <p class="text-muted mb-2" style="font-size:0.9rem;">Tu pedido se enviará a la dirección que indiques.</p>
                            <span class="badge-modo"><i class="fas fa-check-circle me-1"></i>Solo delivery</span>
                        </div>
                        <% } %>

                        <div class="form-section" id="seccionDireccion"
                             style="<%= modoOp === 'retiro' ? 'display:none;' : '' %>">
                            <h5><i class="fas fa-map-marker-alt"></i> Dirección de entrega</h5>
                            <textarea name="direccion" id="campoDireccion" class="form-control" rows="2"
                                placeholder="Dirección completa: calle, número, piso, departamento..."
                                <%= modoOp !== 'retiro' ? 'required' : '' %>><%= user.direccion || '' %></textarea>
                        </div>

                        <% if (modoOp !== 'delivery') { %>
                        <div class="info-retiro" id="infoRetiro"
                             style="<%= modoOp === 'retiro' ? '' : 'display:none;' %>margin-bottom:20px;">
                            <strong><i class="fas fa-info-circle me-1"></i> Datos del local</strong>
                            <% if (cfg.direccionLocal) { %><div class="mt-1"><i class="fas fa-map-marker-alt me-1"></i> <%= cfg.direccionLocal %></div><% } %>
                            <% if (cfg.horarioLocal) { %><div><i class="fas fa-clock me-1"></i> <%= cfg.horarioLocal %></div><% } %>
                            <% if (cfg.indicacionesLocal) { %><div><i class="fas fa-comment me-1"></i> <%= cfg.indicacionesLocal %></div><% } %>
                            <% if (!cfg.direccionLocal && !cfg.horarioLocal && !cfg.indicacionesLocal) { %>
                            <div class="mt-1">El local te contactará para coordinar el retiro.</div>
                            <% } %>
                        </div>
                        <% } %>

                        <div class="form-section">
                            <h5><i class="fas fa-credit-card"></i> Cuándo y cómo pagás</h5>
                            <input type="hidden" name="momento_pago" id="momentoPagoInput" value="">
                            <input type="hidden" name="forma_pago" id="formaPagoInput" value="">

                            <div class="entrega-opts mb-3" id="opcionesPago">
                                <div class="entrega-opt" id="opt-pagar-ahora" onclick="selectPago('ahora')">
                                    <i class="fas fa-bolt"></i>
                                    <span id="labelPagarAhora">Pagar ahora</span>
                                    <small>Transferencia bancaria</small>
                                </div>
                                <div class="entrega-opt" id="opt-pagar-despues" onclick="selectPago('despues')">
                                    <i class="fas fa-clock"></i>
                                    <span id="labelPagarDespues">Pagar al recibir</span>
                                    <small id="subLabelPagarDespues">Efectivo o transferencia al momento de entrega</small>
                                </div>
                            </div>

                            <div id="bloqueComprobante" style="display:none;">
                                <div style="background:#f0fdf4;border:1.5px solid #86efac;border-radius:12px;padding:16px;margin-bottom:12px;">
                                    <p class="mb-2" style="font-size:0.9rem;color:#166534;font-weight:600;">
                                        <i class="fas fa-info-circle me-1"></i>
                                        Realizá la transferencia bancaria y adjuntá el comprobante.
                                    </p>
                                    <% if (cfg.datosBancarios) { %>
                                    <div style="font-size:0.85rem;color:#166534;white-space:pre-line;"><%= cfg.datosBancarios %></div>
                                    <% } %>
                                </div>
                                <label style="font-weight:600;font-size:0.9rem;margin-bottom:6px;display:block;">
                                    <i class="fas fa-image me-1" style="color:#667eea;"></i>
                                    Foto del comprobante <span style="color:#ef4444;">*</span>
                                </label>
                                <input type="file" name="comprobante" id="campoComprobante"
                                    accept="image/*" class="form-control"
                                    onchange="previewComprobante(this)">
                                <div id="previewComprobanteWrap" style="display:none;margin-top:10px;">
                                    <img id="previewComprobanteImg" src="" alt="Vista previa"
                                        style="max-width:100%;max-height:220px;border-radius:10px;border:2px solid #e2e8f0;">
                                </div>
                            </div>

                            <div id="bloquePagarDespues" style="display:none;">
                                <div style="background:#fefce8;border:1.5px solid #fde047;border-radius:12px;padding:14px;margin-top:8px;">
                                    <p class="mb-0" style="font-size:0.88rem;color:#854d0e;">
                                        <i class="fas fa-handshake me-1"></i>
                                        <span id="msgPagarDespues"></span>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h5><i class="fas fa-sticky-note"></i> Notas adicionales</h5>
                            <textarea name="notas" class="form-control" rows="2"
                                placeholder="Aclaraciones, preferencias de entrega, etc."></textarea>
                        </div>

                        <button type="submit" class="btn-confirm" id="btnConfirmar" onclick="return validarPago()">
                            <i class="fas fa-check-circle me-2"></i> Confirmar Pedido
                        </button>
                    </form>
                </div>

                <div class="col-lg-5">
                    <div class="order-summary">
                        <h4><i class="fas fa-receipt me-2"></i>Resumen</h4>

                        <% carrito.forEach(item => { %>
                        <div class="summary-row">
                            <span><%= item.cantidad %>× <%= item.nombre %></span>
                            <strong>$<%= (parseFloat(item.precio) * item.cantidad).toFixed(2) %></strong>
                        </div>
                        <% }) %>

                        <hr class="summary-divider">

                        <div class="summary-row">
                            <span>Subtotal</span>
                            <span>$<%= sub.toFixed(2) %></span>
                        </div>

                        <% if (envioConf.activo === true) { %>
                        <div class="summary-row tarifa-row" id="rowEnvio"
                             style="<%= modoInicialDisplay === 'retiro' ? 'display:none;' : '' %>">
                            <span><%= envioConf.label || 'Envío' %></span>
                            <span id="montoEnvio"></span>
                        </div>
                        <% if (envioConf.tipo === 'gratis_desde' && parseFloat(envioConf.gratisDesde) > 0) { %>
                        <div class="nota-gratis" id="notaEnvio"></div>
                        <% } %>
                        <% } %>

                        <% if (impConf.activo === true) { %>
                            <% if (!impConf.incluido) { %>
                            <div class="summary-row tarifa-row" id="rowImpuesto">
                                <span><%= impConf.label || 'IVA' %> (<%= parseFloat(impConf.porcentaje)||0 %>%)</span>
                                <span id="montoImpuesto">$0.00</span>
                            </div>
                            <% } else { %>
                            <div class="summary-row incluido-row">
                                <span><%= impConf.label || 'IVA' %> (<%= parseFloat(impConf.porcentaje)||0 %>%) — incluido</span>
                                <span>—</span>
                            </div>
                            <% } %>
                        <% } %>

                        <% if (extraConf.activo === true) { %>
                        <div class="summary-row tarifa-row" id="rowExtra">
                            <span><%= extraConf.nombre || 'Cargo extra' %></span>
                            <span id="montoExtra">$0.00</span>
                        </div>
                        <% } %>

                        <hr class="summary-divider">

                        <div class="summary-total">
                            <span>Total</span>
                            <strong id="totalFinal">$0.00</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('./footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const subtotal  = parseFloat(<%= sub %>) || 0;
        const modoOp    = '<%= modoOp %>';
        const envioConf = <%- JSON.stringify(envioConf || {}) %>;
        const impConf   = <%- JSON.stringify(impConf || {}) %>;
        const extraConf = <%- JSON.stringify(extraConf || {}) %>;

        function calcEnvio(modo) {
            if (!envioConf.activo || modo === 'retiro') return { monto: 0, gratis: false };
            const tipo  = envioConf.tipo || 'fijo';
            const valor = parseFloat(envioConf.valor) || 0;
            if (tipo === 'gratis_desde') {
                const limite = parseFloat(envioConf.gratisDesde) || 0;
                return subtotal >= limite ? { monto: 0, gratis: true } : { monto: valor, gratis: false };
            }
            if (tipo === 'porcentaje') return { monto: subtotal * valor / 100, gratis: false };
            return { monto: valor, gratis: false };
        }

        function calcImpuesto() {
            if (!impConf.activo || impConf.incluido) return 0;
            return subtotal * (parseFloat(impConf.porcentaje) || 0) / 100;
        }

        function calcExtra() {
            if (!extraConf.activo) return 0;
            const valor = parseFloat(extraConf.valor) || 0;
            return extraConf.tipo === 'porcentaje' ? subtotal * valor / 100 : valor;
        }

        function updateSummary(modo) {
            const envio    = calcEnvio(modo);
            const impMonto = calcImpuesto();
            const exMonto  = calcExtra();
            const total    = subtotal + envio.monto + impMonto + exMonto;

            const rowEnvio   = document.getElementById('rowEnvio');
            const montoEnvio = document.getElementById('montoEnvio');
            const notaEnvio  = document.getElementById('notaEnvio');
            if (rowEnvio) {
                rowEnvio.style.display = modo === 'retiro' ? 'none' : 'flex';
                if (modo !== 'retiro' && montoEnvio) {
                    montoEnvio.textContent = envio.gratis ? '¡Gratis! 🎉' : '$' + envio.monto.toFixed(2);
                }
                if (notaEnvio && envioConf.tipo === 'gratis_desde') {
                    const lim = parseFloat(envioConf.gratisDesde) || 0;
                    notaEnvio.textContent = envio.gratis ? '' : 'Envío gratis desde $' + lim.toFixed(0);
                }
            }

            const montoImp = document.getElementById('montoImpuesto');
            if (montoImp) montoImp.textContent = '$' + impMonto.toFixed(2);

            const montoEx = document.getElementById('montoExtra');
            if (montoEx) montoEx.textContent = '$' + exMonto.toFixed(2);

            const totalEl = document.getElementById('totalFinal');
            if (totalEl) totalEl.textContent = '$' + total.toFixed(2);
        }

        function selectEntrega(modo) {
            document.getElementById('modoEntregaInput').value = modo;
            document.querySelectorAll('.entrega-opt').forEach(el => el.classList.remove('active'));
            const btn = document.getElementById('opt-' + modo);
            if (btn) btn.classList.add('active');

            const secDir     = document.getElementById('seccionDireccion');
            const infoRetiro = document.getElementById('infoRetiro');
            const dirField   = document.getElementById('campoDireccion');

            if (modo === 'delivery') {
                if (secDir)     secDir.style.display     = '';
                if (infoRetiro) infoRetiro.style.display = 'none';
                if (dirField) {
                    dirField.required = true;
                    if (dirField.value === 'Retiro en local') dirField.value = dirField.dataset.orig || '';
                }
            } else {
                if (secDir)     secDir.style.display     = 'none';
                if (infoRetiro) infoRetiro.style.display = '';
                if (dirField) {
                    if (dirField.value !== 'Retiro en local') dirField.dataset.orig = dirField.value;
                    dirField.required = false;
                    dirField.value    = 'Retiro en local';
                }
            }
            updateSummary(modo);
            actualizarLabelsPago(modo);
            if (typeof modoPagoActual !== 'undefined' && modoPagoActual) selectPago(modoPagoActual);
        }

        var modoPagoActual = null;

        function initPago(modoEntrega) {
            actualizarLabelsPago(modoEntrega);
            selectPago('ahora');
        }

        function actualizarLabelsPago(modoEntrega) {
            const lDespues = document.getElementById('labelPagarDespues');
            const subDespues = document.getElementById('subLabelPagarDespues');
            const msgDespues = document.getElementById('msgPagarDespues');
            if (modoEntrega === 'retiro') {
                if (lDespues) lDespues.textContent = 'Pagar en el local';
                if (subDespues) subDespues.textContent = 'Efectivo o transferencia al retirar';
                if (msgDespues) msgDespues.textContent = 'Podés pagar en efectivo o por transferencia cuando pases a retirar tu pedido al local.';
            } else {
                if (lDespues) lDespues.textContent = 'Pagar al recibir';
                if (subDespues) subDespues.textContent = 'Efectivo o transferencia en la entrega';
                if (msgDespues) msgDespues.textContent = 'Podés pagar en efectivo o por transferencia cuando el delivery llegue a tu domicilio.';
            }
        }

        function selectPago(tipo) {
            modoPagoActual = tipo;
            document.getElementById('momentoPagoInput').value = tipo;
            const modoEntrega = document.getElementById('modoEntregaInput').value;

            document.querySelectorAll('#opcionesPago .entrega-opt').forEach(el => el.classList.remove('active'));
            document.getElementById('opt-pagar-' + tipo)?.classList.add('active');

            const bloqueComp = document.getElementById('bloqueComprobante');
            const bloqueDespues = document.getElementById('bloquePagarDespues');
            const campo = document.getElementById('campoComprobante');
            const formaPago = document.getElementById('formaPagoInput');

            if (tipo === 'ahora') {
                bloqueComp.style.display = '';
                bloqueDespues.style.display = 'none';
                if (campo) campo.required = true;
                if (formaPago) formaPago.value = 'transferencia';
            } else {
                bloqueComp.style.display = 'none';
                bloqueDespues.style.display = '';
                if (campo) { campo.required = false; campo.value = ''; }
                document.getElementById('previewComprobanteWrap').style.display = 'none';
                if (formaPago) formaPago.value = 'efectivo';
                actualizarLabelsPago(modoEntrega);
            }
        }

        function previewComprobante(input) {
            const wrap = document.getElementById('previewComprobanteWrap');
            const img  = document.getElementById('previewComprobanteImg');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { img.src = e.target.result; wrap.style.display = ''; };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function validarPago() {
            if (!modoPagoActual) {
                alert('Por favor seleccioná una forma de pago.');
                return false;
            }
            if (modoPagoActual === 'ahora') {
                const campo = document.getElementById('campoComprobante');
                if (!campo || !campo.files || campo.files.length === 0) {
                    alert('Por favor adjuntá el comprobante de pago.');
                    campo?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return false;
                }
            }
            return true;
        }

        (function() {
            const modoInicial = (modoOp === 'retiro') ? 'retiro' : 'delivery';
            if (modoOp === 'retiro') {
                const d = document.getElementById('campoDireccion');
                if (d) { d.required = false; d.value = 'Retiro en local'; }
            }
            updateSummary(modoInicial);
            initPago(modoInicial);
        })();
    </script>
</body>
</html>