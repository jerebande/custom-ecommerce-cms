<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>Editar Textos - Admin</title>
    <% if (negocio && negocio.icono_pagina && negocio.icono_pagina.imagen) { %>
        <link rel="icon" href="<%= negocio.icono_pagina.imagen %>" type="image/x-icon">
        <link rel="apple-touch-icon" href="<%= negocio.icono_pagina.imagen %>">
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-light: #7f9cf5;
            --secondary: #764ba2;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --info: #3b82f6;
            --dark: #1e293b;
            --gray: #64748b;
            --gray-light: #94a3b8;
            --light: #f8fafc;
            --white: #ffffff;
            --gradient: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
            --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
            --radius: 12px;
            --radius-lg: 20px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(135deg, #f5f7fb 0%, #f0f2f8 100%);
            color: var(--dark);
            min-height: 100vh;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            background: var(--white);
            height: 100vh;
            position: fixed;
            left: 0; top: 0;
            width: 280px;
            z-index: 500;
            overflow-y: auto;
            box-shadow: var(--shadow-xl);
            border-right: 1px solid rgba(0,0,0,0.05);
            transition: transform 0.3s ease;
        }
        .sidebar::-webkit-scrollbar { width: 5px; }
        .sidebar::-webkit-scrollbar-track { background: var(--light); }
        .sidebar::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 10px; }

        .sidebar-header {
            padding: 30px 24px;
            text-align: center;
            border-bottom: 1px solid rgba(0,0,0,0.08);
            background: var(--gradient);
            position: relative;
            overflow: hidden;
        }
        .sidebar-header::before {
            content: '';
            position: absolute;
            top: -50%; right: -50%;
            width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            animation: pulse 4s ease-in-out infinite;
        }
        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }
        .sidebar-header h4 { font-weight: 800; margin-bottom: 8px; color: var(--white); position: relative; z-index: 1; font-size: 1.5rem; }
        .sidebar-header h4 i { margin-right: 8px; }
        .sidebar-header small { opacity: 0.9; color: rgba(255,255,255,0.9); position: relative; z-index: 1; font-size: 0.85rem; }

        .nav-menu { padding: 20px 16px; }
        .nav-section { margin-bottom: 24px; }
        .nav-section-title { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; color: var(--gray-light); padding: 0 16px; margin-bottom: 12px; }

        .nav-link-custom {
            color: var(--gray);
            text-decoration: none;
            padding: 12px 16px;
            display: flex; align-items: center; gap: 12px;
            transition: var(--transition);
            border-radius: var(--radius);
            margin-bottom: 4px;
            font-weight: 500;
            position: relative;
            overflow: hidden;
        }
        .nav-link-custom::before {
            content: '';
            position: absolute; left: 0; top: 0;
            width: 0; height: 100%;
            background: var(--gradient);
            transition: var(--transition);
            z-index: -1; opacity: 0;
        }
        .nav-link-custom:hover::before { width: 100%; opacity: 0.1; }
        .nav-link-custom i { width: 24px; font-size: 1.2rem; }
        .nav-link-custom:hover { color: var(--primary); transform: translateX(4px); }
        .nav-link-custom.active { background: var(--gradient); color: var(--white); box-shadow: var(--shadow-md); }
        .nav-link-custom.active i { color: var(--white); }

        /* ===== MAIN CONTENT ===== */
        .main-content {
            margin-left: 280px;
            padding: 32px 40px;
            min-height: 100vh;
        }

        /* ===== PAGE HEADER ===== */
        .page-header {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 28px 32px;
            margin-bottom: 32px;
            box-shadow: var(--shadow-md);
            border: 1px solid rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-header-left { display: flex; align-items: center; gap: 18px; }
        .page-header-icon {
            width: 56px; height: 56px;
            background: var(--gradient);
            border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; color: white;
            box-shadow: var(--shadow-md);
            flex-shrink: 0;
        }
        .page-header-text h1 {
            font-size: 1.6rem;
            font-weight: 800;
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 4px;
            line-height: 1.2;
        }
        .page-header-text p { color: var(--gray); margin: 0; font-size: 0.9rem; }

        .user-badge {
            display: flex; align-items: center; gap: 10px;
            background: var(--light);
            padding: 10px 20px;
            border-radius: 50px;
            border: 1px solid rgba(0,0,0,0.06);
        }
        .user-badge i { font-size: 1.4rem; color: var(--primary); }
        .user-badge span { font-weight: 600; color: var(--dark); font-size: 0.9rem; }

        /* ===== SECTION LABEL ===== */
        .section-label {
            display: flex; align-items: center; gap: 10px;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 700;
            color: var(--gray-light);
            margin-bottom: 16px;
            margin-top: 8px;
        }
        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(0,0,0,0.07);
        }

        /* ===== CONFIG CARDS ===== */
        .config-card {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 28px 32px;
            margin-bottom: 24px;
            box-shadow: var(--shadow-md);
            border: 1px solid rgba(0,0,0,0.05);
            transition: var(--transition);
        }
        .config-card:hover { box-shadow: var(--shadow-xl); transform: translateY(-1px); }

        .config-card-header {
            display: flex; align-items: center;
            gap: 12px;
            margin-bottom: 20px;
        }
        .config-card-title-icon {
            width: 38px; height: 38px;
            background: rgba(102, 126, 234, 0.1);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            color: var(--primary);
            font-size: 1rem;
            flex-shrink: 0;
        }
        .config-card-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--dark);
            display: flex; align-items: center; gap: 12px;
        }
        .card-divider { border: none; border-top: 2px solid var(--light); margin: 0 0 24px 0; }

        /* ===== TABS ===== */
        .custom-tabs {
            display: flex;
            gap: 8px;
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 8px;
            box-shadow: var(--shadow-md);
            border: 1px solid rgba(0,0,0,0.05);
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .custom-tab-btn {
            flex: 1;
            min-width: 120px;
            padding: 12px 20px;
            border: none;
            border-radius: var(--radius);
            background: transparent;
            color: var(--gray);
            font-weight: 600;
            font-size: 0.875rem;
            cursor: pointer;
            transition: var(--transition);
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .custom-tab-btn:hover { background: var(--light); color: var(--primary); }
        .custom-tab-btn.active { background: var(--gradient); color: white; box-shadow: var(--shadow-md); }

        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        /* ===== FORM ELEMENTS ===== */
        .form-label { font-weight: 600; color: var(--dark); margin-bottom: 8px; font-size: 0.875rem; }
        .form-control, .form-select {
            border: 2px solid #e2e8f0;
            border-radius: var(--radius);
            padding: 10px 15px;
            font-size: 0.9rem;
            transition: var(--transition);
            background: var(--white);
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.12);
            outline: none;
        }

        /* ===== PREVIEW BOX ===== */
        .preview-box {
            background: var(--light);
            border-radius: var(--radius);
            padding: 10px 14px;
            margin-top: 8px;
            border-left: 3px solid var(--primary);
        }
        .preview-box small { color: var(--gray); font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .preview-text { color: var(--dark); padding: 4px 0 0; background: transparent; font-size: 14px; }

        /* ===== CARD PREVIEW DEMO ===== */
        .card-preview {
            background: var(--white);
            border-radius: var(--radius);
            padding: 20px;
            border: 2px solid #e2e8f0;
            margin-top: 24px;
        }
        .card-preview-title { font-size: 0.8rem; font-weight: 700; margin-bottom: 12px; color: var(--gray); text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 6px; }
        .card-preview-title i { color: var(--primary); }
        .card-preview-demo { background: var(--light); border-radius: var(--radius); padding: 15px; }

        /* ===== SUBSECTION HEADER ===== */
        .subsection-header {
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            color: var(--gray);
            margin: 24px 0 16px;
            display: flex; align-items: center; gap: 8px;
        }
        .subsection-header::before { content: ''; width: 3px; height: 14px; background: var(--gradient); border-radius: 2px; }

        /* ===== BUTTONS ===== */
        .btn-primary-custom {
            background: var(--gradient);
            color: var(--white);
            border: none;
            padding: 13px 32px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.95rem;
            transition: var(--transition);
            cursor: pointer;
            display: inline-flex; align-items: center; gap: 8px;
            letter-spacing: 0.3px;
        }
        .btn-primary-custom:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
        .btn-primary-custom:active { transform: translateY(0); }

        /* ===== SAVE BAR ===== */
        .save-bar {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 24px 32px;
            margin-top: 8px;
            box-shadow: var(--shadow-md);
            border: 1px solid rgba(0,0,0,0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
        }
        .save-bar-hint { color: var(--gray); font-size: 0.875rem; }

        /* ===== ALERT ===== */
        .alert { border-radius: var(--radius); border: none; }

        /* ===== SAVE BAR RESPONSIVE ===== */
        @media (max-width: 576px) {
            .save-bar { flex-direction: column; text-align: center; padding: 20px; gap: 12px; }
            .btn-primary-custom { width: 100%; justify-content: center; }
            .save-bar-hint { font-size: 0.8rem; }
        }

        /* ===== MOBILE ===== */
        .mobile-menu-btn {
            display: none;
            position: fixed; top: 15px; right: 15px;
            z-index: 700;
            background: var(--gradient);
            border: none;
            width: 48px; height: 48px;
            border-radius: 50%;
            color: var(--white);
            font-size: 1.2rem;
            box-shadow: var(--shadow-xl);
            cursor: pointer;
            align-items: center; justify-content: center;
        }
        .overlay {
            display: none;
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 600;
        }
        .overlay.active { display: block; }

        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); position: fixed; z-index: 650; }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 16px; padding-top: 76px; }
            .mobile-menu-btn { display: flex; }
            .page-header { padding: 20px; flex-direction: column; align-items: flex-start; }
            .page-header-text h1 { font-size: 1.25rem; }
            .user-badge { align-self: flex-start; }
            .config-card { padding: 20px; }
            .custom-tab-btn { font-size: 0.8rem; padding: 10px 14px; }
        }
    </style>
</head>
<body>
    <button class="mobile-menu-btn" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
    <div class="overlay" id="overlay"></div>

    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h4><i class="fas fa-chart-line"></i> Panel Admin</h4>
            <small><%= user ? user.nombre : 'Administrador' %></small>
        </div>
        <div class="nav-menu">
            <div class="nav-section">
                <div class="nav-section-title">Principal</div>
                <a href="/admin" class="nav-link-custom"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a href="/admin#productos" class="nav-link-custom"><i class="fas fa-box"></i> Productos</a>
                <a href="/admin#pedidos" class="nav-link-custom"><i class="fas fa-shopping-cart"></i> Pedidos</a>
            </div>
            <div class="nav-section">
                <div class="nav-section-title">Gestión</div>
                <a href="/admin#usuarios" class="nav-link-custom"><i class="fas fa-users"></i> Usuarios</a>
                <a href="/admin#ventas" class="nav-link-custom"><i class="fas fa-chart-line"></i> Ventas</a>
            </div>
            <div class="nav-section">
                <div class="nav-section-title">Configuración</div>
                <a href="/admin/home-config" class="nav-link-custom"><i class="fas fa-home"></i> Configurar Home</a>
                <a href="/admin/textos-config" class="nav-link-custom active"><i class="fas fa-edit"></i> Editar Textos</a>
                <a href="/admin#colores" class="nav-link-custom"><i class="fas fa-palette"></i> Colores del Sitio</a>
                <a href="/admin#pedidos-config" class="nav-link-custom"><i class="fas fa-cog"></i> Config. Pedidos</a>
            </div>
            <div class="nav-section">
                <div class="nav-section-title">Sistema</div>
                <a href="/" class="nav-link-custom"><i class="fas fa-store"></i> Ver tienda</a>
                <a href="/logout" class="nav-link-custom"><i class="fas fa-sign-out-alt"></i> Cerrar sesión</a>
            </div>
        </div>
    </div>

    <div class="main-content">

        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left">
                <div class="page-header-text" style="display: flex; align-items: center; gap: 18px;">
                    <% if (negocio && negocio.icono_pagina && negocio.icono_pagina.imagen) { %>
                        <div style="width: 56px; height: 56px; flex-shrink: 0; background: #eef2ff; border-radius: 16px; display: flex; align-items: center; justify-content: center; padding: 4px;">
                            <img src="<%= negocio.icono_pagina.imagen %>" alt="Icono" style="width: 100%; height: 100%; object-fit: contain;">
                        </div>
                    <% } %>
                    <div>
                        <h1>Editar Textos de la Tienda</h1>
                        <p>Personaliza los textos que aparecen en cada sección</p>
                    </div>
                </div>
            </div>
            <div class="user-badge">
                <i class="fas fa-user-circle"></i>
                <span><%= user ? user.nombre : 'Administrador' %></span>
            </div>
        </div>

        <div id="alertContainer"></div>

        <!-- CUSTOM TABS -->
        <div class="section-label"><i class="fas fa-layer-group" style="color:var(--primary)"></i> Secciones de la tienda</div>
        <div class="custom-tabs" id="tabsContainer">
            <button class="custom-tab-btn active" data-tab="productos" onclick="switchTab('productos', this)">
                <i class="fas fa-box"></i> Productos
            </button>
            <button class="custom-tab-btn" data-tab="carrito" onclick="switchTab('carrito', this)">
                <i class="fas fa-shopping-cart"></i> Carrito
            </button>
            <button class="custom-tab-btn" data-tab="pedidos" onclick="switchTab('pedidos', this)">
                <i class="fas fa-truck"></i> Mis Pedidos
            </button>
        </div>

        <!-- TAB: PRODUCTOS -->
        <div class="tab-panel active" id="tab-productos">
            <div class="section-label"><i class="fas fa-box" style="color:var(--primary)"></i> Textos de Productos</div>
            <div class="config-card">
                <div class="config-card-header">
                    <div class="config-card-title">
                        <div class="config-card-title-icon"><i class="fas fa-box"></i></div>
                        Sección Productos
                    </div>
                </div>
                <hr class="card-divider">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Título de la sección</label>
                        <input type="text" class="form-control" id="productos_titulo_seccion" placeholder="Ej: Nuestros Productos">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Subtítulo de la sección</label>
                        <input type="text" class="form-control" id="productos_subtitulo_seccion" placeholder="Ej: Descubre nuestra selección...">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Botón "Agregar"</label>
                        <input type="text" class="form-control" id="productos_boton_agregar" placeholder="Ej: Agregar">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Mensaje "Sin stock"</label>
                        <input type="text" class="form-control" id="productos_mensaje_sin_stock" placeholder="Ej: Sin stock">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Mensaje sin productos</label>
                        <input type="text" class="form-control" id="productos_mensaje_sin_productos" placeholder="Ej: No hay productos disponibles">
                    </div>
                </div>


            </div>
        </div>

        <!-- TAB: CARRITO -->
        <div class="tab-panel" id="tab-carrito">
            <div class="section-label"><i class="fas fa-shopping-cart" style="color:var(--primary)"></i> Textos del Carrito</div>
            <div class="config-card">
                <div class="config-card-header">
                    <div class="config-card-title">
                        <div class="config-card-title-icon"><i class="fas fa-shopping-cart"></i></div>
                        Sección Carrito
                    </div>
                </div>
                <hr class="card-divider">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Título de la sección</label>
                        <input type="text" class="form-control" id="carrito_titulo_seccion" placeholder="Ej: Mi Carrito">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Subtítulo de la sección</label>
                        <input type="text" class="form-control" id="carrito_subtitulo_seccion" placeholder="Ej: Revisa tus productos...">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mensaje carrito vacío</label>
                        <input type="text" class="form-control" id="carrito_mensaje_vacio" placeholder="Ej: Tu carrito está vacío">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Descripción carrito vacío</label>
                        <input type="text" class="form-control" id="carrito_mensaje_vacio_desc" placeholder="Ej: ¡Explora nuestros productos!">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Botón "Vaciar Carrito"</label>
                        <input type="text" class="form-control" id="carrito_boton_vaciar" placeholder="Ej: Vaciar Carrito">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Botón "Ver Productos"</label>
                        <input type="text" class="form-control" id="carrito_boton_ver_productos" placeholder="Ej: Ver Productos">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Botón "Proceder al pago"</label>
                        <input type="text" class="form-control" id="carrito_boton_comprar" placeholder="Ej: Proceder al pago">
                    </div>
                </div>

                <div class="subsection-header">Resumen del pedido</div>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Título resumen</label>
                        <input type="text" class="form-control" id="carrito_resumen_titulo" placeholder="Ej: Resumen del Pedido">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Subtotal</label>
                        <input type="text" class="form-control" id="carrito_subtotal_label" placeholder="Ej: Subtotal:">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Envío</label>
                        <input type="text" class="form-control" id="carrito_envio_label" placeholder="Ej: Envío:">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Total</label>
                        <input type="text" class="form-control" id="carrito_total_label" placeholder="Ej: Total:">
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: MIS PEDIDOS -->
        <div class="tab-panel" id="tab-pedidos">
            <div class="section-label"><i class="fas fa-truck" style="color:var(--primary)"></i> Textos de Mis Pedidos</div>
            <div class="config-card">
                <div class="config-card-header">
                    <div class="config-card-title">
                        <div class="config-card-title-icon"><i class="fas fa-truck"></i></div>
                        Sección Mis Pedidos
                    </div>
                </div>
                <hr class="card-divider">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Título de la sección</label>
                        <input type="text" class="form-control" id="pedidos_titulo_seccion" placeholder="Ej: Mis Pedidos">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Subtítulo de la sección</label>
                        <input type="text" class="form-control" id="pedidos_subtitulo_seccion" placeholder="Ej: Consulta el historial...">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mensaje sin pedidos</label>
                        <input type="text" class="form-control" id="pedidos_mensaje_vacio" placeholder="Ej: Sin pedidos aún">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Descripción sin pedidos</label>
                        <input type="text" class="form-control" id="pedidos_mensaje_vacio_desc" placeholder="Ej: No tienes pedidos registrados...">
                    </div>
                </div>

                <div class="subsection-header">Estados de pedido</div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Estado "Entregado"</label>
                        <input type="text" class="form-control" id="pedidos_estado_entregado" placeholder="Ej: Entregado">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Estado "En Preparación"</label>
                        <input type="text" class="form-control" id="pedidos_estado_preparacion" placeholder="Ej: En Preparación">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Estado "Pendiente"</label>
                        <input type="text" class="form-control" id="pedidos_estado_pendiente" placeholder="Ej: Pendiente">
                    </div>
                </div>

                <div class="subsection-header">Etiquetas de información</div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Info Dirección</label>
                        <input type="text" class="form-control" id="pedidos_info_direccion" placeholder="Ej: Dirección de Entrega">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Info Pago</label>
                        <input type="text" class="form-control" id="pedidos_info_pago" placeholder="Ej: Método de Pago">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Título Productos</label>
                        <input type="text" class="form-control" id="pedidos_productos_titulo" placeholder="Ej: Productos del Pedido">
                    </div>
                </div>
            </div>
        </div>

        <!-- SAVE BAR -->
        <div class="save-bar">
            <span class="save-bar-hint"><i class="fas fa-info-circle me-1"></i> Los cambios se aplicarán en la tienda al guardar</span>
            <button class="btn-primary-custom" onclick="saveTextos()">
                <i class="fas fa-save"></i> Guardar Todos los Cambios
            </button>
        </div>

    </div><!-- end main-content -->

    <script>
        let textosConfig = {};

        function switchTab(tabId, btn) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.custom-tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + tabId).classList.add('active');
            btn.classList.add('active');
        }

        function loadTextos() {
            fetch('/admin/api/textos-config')
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.textos) {
                        textosConfig = data.textos;

                        // Productos
                        document.getElementById('productos_titulo_seccion').value = textosConfig.productos?.titulo_seccion || '';
                        document.getElementById('productos_subtitulo_seccion').value = textosConfig.productos?.subtitulo_seccion || '';
                        document.getElementById('productos_boton_agregar').value = textosConfig.productos?.boton_agregar || '';
                        document.getElementById('productos_mensaje_sin_stock').value = textosConfig.productos?.mensaje_sin_stock || '';
                        document.getElementById('productos_mensaje_sin_productos').value = textosConfig.productos?.mensaje_sin_productos || '';

                        // Carrito
                        document.getElementById('carrito_titulo_seccion').value = textosConfig.carrito?.titulo_seccion || '';
                        document.getElementById('carrito_subtitulo_seccion').value = textosConfig.carrito?.subtitulo_seccion || '';
                        document.getElementById('carrito_mensaje_vacio').value = textosConfig.carrito?.mensaje_vacio || '';
                        document.getElementById('carrito_mensaje_vacio_desc').value = textosConfig.carrito?.mensaje_vacio_desc || '';
                        document.getElementById('carrito_boton_vaciar').value = textosConfig.carrito?.boton_vaciar || '';
                        document.getElementById('carrito_boton_ver_productos').value = textosConfig.carrito?.boton_ver_productos || '';
                        document.getElementById('carrito_boton_comprar').value = textosConfig.carrito?.boton_comprar || '';
                        document.getElementById('carrito_resumen_titulo').value = textosConfig.carrito?.resumen_titulo || '';
                        document.getElementById('carrito_subtotal_label').value = textosConfig.carrito?.subtotal_label || '';
                        document.getElementById('carrito_envio_label').value = textosConfig.carrito?.envio_label || '';
                        document.getElementById('carrito_total_label').value = textosConfig.carrito?.total_label || '';

                        // Mis Pedidos
                        document.getElementById('pedidos_titulo_seccion').value = textosConfig.mis_pedidos?.titulo_seccion || '';
                        document.getElementById('pedidos_subtitulo_seccion').value = textosConfig.mis_pedidos?.subtitulo_seccion || '';
                        document.getElementById('pedidos_mensaje_vacio').value = textosConfig.mis_pedidos?.mensaje_vacio || '';
                        document.getElementById('pedidos_mensaje_vacio_desc').value = textosConfig.mis_pedidos?.mensaje_vacio_desc || '';
                        document.getElementById('pedidos_estado_entregado').value = textosConfig.mis_pedidos?.estado_entregado || '';
                        document.getElementById('pedidos_estado_preparacion').value = textosConfig.mis_pedidos?.estado_preparacion || '';
                        document.getElementById('pedidos_estado_pendiente').value = textosConfig.mis_pedidos?.estado_pendiente || '';
                        document.getElementById('pedidos_info_direccion').value = textosConfig.mis_pedidos?.info_direccion || '';
                        document.getElementById('pedidos_info_pago').value = textosConfig.mis_pedidos?.info_pago || '';
                        document.getElementById('pedidos_productos_titulo').value = textosConfig.mis_pedidos?.productos_titulo || '';

                        updatePreviews();
                    }
                })
                .catch(error => console.error('Error:', error));
        }

        function updatePreviews() {
            // Vistas previas eliminadas
        }

        function showAlert(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show`;
            alertDiv.innerHTML = `${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
            const container = document.getElementById('alertContainer');
            container.innerHTML = '';
            container.appendChild(alertDiv);
            setTimeout(() => alertDiv.remove(), 5000);
        }

        function saveTextos() {
            const config = {
                productos: {
                    titulo_seccion: document.getElementById('productos_titulo_seccion').value,
                    subtitulo_seccion: document.getElementById('productos_subtitulo_seccion').value,
                    boton_agregar: document.getElementById('productos_boton_agregar').value,
                    mensaje_sin_stock: document.getElementById('productos_mensaje_sin_stock').value,
                    mensaje_sin_productos: document.getElementById('productos_mensaje_sin_productos').value,
                    card_descripcion_limit: 80
                },
                carrito: {
                    titulo_seccion: document.getElementById('carrito_titulo_seccion').value,
                    subtitulo_seccion: document.getElementById('carrito_subtitulo_seccion').value,
                    mensaje_vacio: document.getElementById('carrito_mensaje_vacio').value,
                    mensaje_vacio_desc: document.getElementById('carrito_mensaje_vacio_desc').value,
                    boton_vaciar: document.getElementById('carrito_boton_vaciar').value,
                    boton_ver_productos: document.getElementById('carrito_boton_ver_productos').value,
                    boton_comprar: document.getElementById('carrito_boton_comprar').value,
                    resumen_titulo: document.getElementById('carrito_resumen_titulo').value,
                    subtotal_label: document.getElementById('carrito_subtotal_label').value,
                    envio_label: document.getElementById('carrito_envio_label').value,
                    envio_texto: "Gratis",
                    total_label: document.getElementById('carrito_total_label').value
                },
                mis_pedidos: {
                    titulo_seccion: document.getElementById('pedidos_titulo_seccion').value,
                    subtitulo_seccion: document.getElementById('pedidos_subtitulo_seccion').value,
                    mensaje_vacio: document.getElementById('pedidos_mensaje_vacio').value,
                    mensaje_vacio_desc: document.getElementById('pedidos_mensaje_vacio_desc').value,
                    estado_entregado: document.getElementById('pedidos_estado_entregado').value,
                    estado_preparacion: document.getElementById('pedidos_estado_preparacion').value,
                    estado_pendiente: document.getElementById('pedidos_estado_pendiente').value,
                    info_direccion: document.getElementById('pedidos_info_direccion').value,
                    info_pago: document.getElementById('pedidos_info_pago').value,
                    productos_titulo: document.getElementById('pedidos_productos_titulo').value,
                    total_label: "Total del Pedido:"
                }
            };

            fetch('/admin/api/textos-config', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(config)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showAlert('✓ Textos guardados correctamente', 'success');
                } else {
                    showAlert('Error: ' + (data.error || 'Error desconocido'), 'danger');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showAlert('Error al guardar los textos', 'danger');
            });
        }

        document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('overlay').classList.toggle('active');
        });
        document.getElementById('overlay')?.addEventListener('click', () => {
            document.getElementById('sidebar').classList.remove('active');
            document.getElementById('overlay').classList.remove('active');
        });

        loadTextos();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>