<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title><%= negocio && negocio.titulos_paginas && negocio.titulos_paginas.carrito ? negocio.titulos_paginas.carrito : 'Mi Carrito - Tienda Elegante' %></title>
    <% if (negocio && negocio.icono_pagina && negocio.icono_pagina.imagen) { %>
        <link rel="icon" href="<%= negocio.icono_pagina.imagen %>" type="image/x-icon">
        <link rel="apple-touch-icon" href="<%= negocio.icono_pagina.imagen %>">
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <!-- ===== COLORES DINÁMICOS ADMIN ===== -->
    <% 
        const _c = (negocio && negocio.colores) ? negocio.colores : {};
        const _p1             = _c.primary          || '#667eea';
        const _p2             = _c.secondary        || '#764ba2';
        const _bodyBg         = _c.bodyBg           || '#f5f7fb';
        const _textColor      = _c.textColor        || '#2d3748';
        const _navbarBg       = _c.navbarBg         || '#ffffff';
        const _navGrad        = (_c.navbarUsesGradient === 'true');
        const _logoColor      = _c.logoTextColor    || '#667eea';
        const _navLinkColor   = _c.navLinkColor     || '#2d3748';
        const _navLinkHover   = _c.navLinkHover     || '#ffffff';
        const _btnBg1         = _c.btnBg1           || _p1;
        const _btnBg2         = _c.btnBg2           || _p2;
        const _btnBg3         = _c.btnBg3           || _p2;
        const _btnMode        = _c.btnColorMode     || '2';
        const _btnTextColor   = _c.btnTextColor     || '#ffffff';
        const _iconColor      = _c.iconColor        || _p1;
        const _iconColor2     = _c.iconColor2       || _p2;
        const _sectionMode    = _c.sectionColorMode || '2';
        const _sectionColor1  = _c.sectionColor1    || _p1;
        const _sectionColor2  = _c.sectionColor2    || _p2;
        const _sectionColor3  = _c.sectionColor3    || _p2;
        const _textMode       = _c.textColorMode    || '1';
        const _textColor1     = _c.textColor1       || _textColor;
        const _textColor2     = _c.textColor2       || _p1;
        const _textColor3     = _c.textColor3       || _p2;
        const _navBgFinal     = _navGrad
            ? `linear-gradient(135deg,${_p1} 0%,${_p2} 100%)`
            : _navbarBg;
        // Para links: si es gradiente, forzar blanco; si es sólido, usar color elegido
        const _navLinkFinal   = _navGrad ? 'rgba(255,255,255,0.92)' : _navLinkColor;
        // logoCustomized: true si el usuario cambió algo del navbar
        const _logoCustomized = _c.logoTextColor || _c.navbarUsesGradient;
        const buildDynColor = (mode, c1, c2, c3) => {
            if (mode === '1') return c1;
            if (mode === '3') return `linear-gradient(135deg, ${c1} 0%, ${c2} 50%, ${c3} 100%)`;
            return `linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`;
        };
        const _sectionBgFinal = buildDynColor(_sectionMode, _sectionColor1, _sectionColor2, _sectionColor3);
        const _btnBgFinal     = buildDynColor(_btnMode, _btnBg1, _btnBg2, _btnBg3);
        const _textAccentBg   = buildDynColor(_textMode, _textColor1, _textColor2, _textColor3);
        const _bannerTitle    = _c.bannerTitleColor    || '#ffffff';
        const _bannerSubtitle = _c.bannerSubtitleColor || '#ffffff';
    %>
    <style>
        :root {
            --dyn-p1:            <%= _p1 %>;
            --dyn-p2:            <%= _p2 %>;
            --dyn-body-bg:       <%= _bodyBg %>;
            --dyn-text:          <%= _textColor %>;
            --dyn-navbar-bg:     <%= _navBgFinal %>;
            --dyn-nav-link:      <%= _navLinkFinal %>;
            --dyn-nav-hover-bg:  linear-gradient(135deg, <%= _p1 %> 0%, <%= _p2 %> 100%);
            --dyn-nav-hover-text:<%= _navLinkHover %>;
            --dyn-btn1:          <%= _btnBg1 %>;
            --dyn-btn2:          <%= _btnBg2 %>;
            --dyn-btn-text:      <%= _btnTextColor %>;
            --dyn-icon1:         <%= _iconColor %>;
            --dyn-icon2:         <%= _iconColor2 %>;
            --dyn-gradient:      linear-gradient(135deg, var(--dyn-p1) 0%, var(--dyn-p2) 100%);
            --dyn-btn-gradient:  <%= _btnBgFinal %>;
            --dyn-icon-gradient: linear-gradient(135deg, var(--dyn-icon1) 0%, var(--dyn-icon2) 100%);
            --dyn-section-bg:    <%= _sectionBgFinal %>;
            --dyn-text-accent-bg:<%= _textAccentBg %>;
            /* vars nativas (mis-pedidos las usa directamente) */
            --primary:   var(--dyn-p1);
            --secondary: var(--dyn-p2);
            --gradient:  var(--dyn-gradient);
        }

        /* === BODY === */
        body { background: var(--dyn-body-bg) !important; color: var(--dyn-text) !important; }

        /* === NAVBAR FONDO === */
        .navbar { background: var(--dyn-navbar-bg) !important; }

        /* === LOGO: solo sobreescribir si el navbar usa gradiente === */
        <% if (_navGrad) { %>
        .navbar-brand,
        .navbar-brand span,
        .logo-container i {
            background: none !important;
            -webkit-background-clip: unset !important;
            background-clip: unset !important;
            color: #ffffff !important;
        }
        <% } else if (_c.logoTextColor) { %>
        /* Logo con color personalizado elegido por el admin */
        .navbar-brand,
        .navbar-brand span,
        .logo-container i {
            background: none !important;
            -webkit-background-clip: unset !important;
            background-clip: unset !important;
            color: <%= _logoColor %> !important;
        }
        <% } %>
        /* Si no se personalizó nada, el style.css maneja el logo (background-clip:text) */

        /* === LINKS DEL NAVBAR === */
        <% if (_c.navLinkColor || _navGrad) { %>
        .navbar-nav .nav-link {
            color: var(--dyn-nav-link) !important;
        }
        <% } %>
        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link:focus,
        .navbar-nav .nav-link.active {
            background: var(--dyn-nav-hover-bg) !important;
            color: var(--dyn-nav-hover-text) !important;
        }

        /* Toggler con gradiente */
        .navbar-toggler { background: var(--dyn-gradient) !important; border: none !important; }

        /* === HEADERS / HERO === */
        .hero-section,
        .cart-header,
        .products-header,
        .orders-header { background: var(--dyn-section-bg) !important; }

        /* === BOTONES PRIMARY === */
        .btn-primary {
            background: var(--dyn-btn-gradient) !important;
            border-color: var(--dyn-btn1) !important;
            color: var(--dyn-btn-text) !important;
        }
        .btn-primary:hover { opacity: 0.9; filter: brightness(1.05); color: var(--dyn-btn-text) !important; }

        /* Botón "Agregar al carrito" */
        form[action="/carrito/add"] button[type="submit"],
        .btn-add-to-cart,
        .producto-card .btn,
        .btn-gradient {
            background: var(--dyn-btn-gradient) !important;
            border: none !important;
            color: var(--dyn-btn-text) !important;
        }

        /* === ÍCONOS CIRCULARES === */
        .feature-icon-modern,
        .stats-icon-client,
        .icon-circle { background: var(--dyn-icon-gradient) !important; }

        /* === TEXTOS COLOREADOS === */
        .total-amount { color: var(--dyn-p1) !important; }
        .categoria-title { border-bottom-color: var(--dyn-p1) !important; }
        .categoria-title i { color: var(--dyn-p1) !important; }
    </style>
<style>
        .cart-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 20px;
            padding: 40px;
            margin-bottom: 40px;
            color: white;
        }
        
        .cart-item-modern {
            background: white;
            border-radius: 16px;
            margin-bottom: 20px;
            padding: 25px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0,0,0,0.07);
        }
        
        .cart-item-modern:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.12);
        }
        
        .cart-img-modern {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 12px;
        }
        
        .summary-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            position: sticky;
            top: 100px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }
        
        .total-amount {
            font-size: 2rem;
            font-weight: 800;
            color: #667eea;
        }
        
        .empty-cart {
            background: white;
            border-radius: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.07);
        }
        
        /* ── ITEM: layout general ── */
        .cart-item-inner {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .cart-img-modern {
            width: 90px;
            height: 90px;
            object-fit: cover;
            border-radius: 12px;
            flex-shrink: 0;
        }

        /* Zona derecha de la imagen: ocupa todo el ancho restante */
        .cart-item-body {
            flex: 1;
            min-width: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        /* Nombre + precio unitario */
        .cart-item-info {
            min-width: 0;
            flex: 1;
        }

        .cart-item-info h5 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .cart-item-info .unit-price {
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--dyn-p1);
            margin: 0;
        }

        /* Controles: cantidad + subtotal + borrar */
        .cart-item-actions {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-shrink: 0;
        }

        .quantity-control {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .quantity-control label {
            font-size: 0.82rem;
            color: #718096;
            white-space: nowrap;
        }

        .quantity-input {
            width: 64px;
            text-align: center;
            border-radius: 10px;
            border: 2px solid #e2e8f0;
            padding: 6px 4px;
            font-size: 0.9rem;
        }
        /* Ocultar flechas nativas para centrar el número perfectamente */
        .quantity-input::-webkit-outer-spin-button,
        .quantity-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .quantity-input[type=number] {
            -moz-appearance: textfield;
        }

        .cart-item-subtotal {
            font-size: 1rem;
            font-weight: 800;
            color: var(--dyn-p1);
            white-space: nowrap;
        }

        .btn-remove-item {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            padding: 0;
            flex-shrink: 0;
        }

        /* ── MOBILE ── */
        @media (max-width: 640px) {
            .cart-header { padding: 24px 16px; }
            .cart-header h1 { font-size: 1.4rem; }
            .cart-item-modern { padding: 14px; }
            .cart-img-modern { width: 72px; height: 72px; }

            /* En mobile: info y controles se apilan verticalmente */
            .cart-item-body { flex-direction: column; align-items: flex-start; gap: 10px; }
            .cart-item-actions { width: 100%; justify-content: space-between; }
            .cart-item-info h5 { font-size: 0.95rem; white-space: normal; }

            .summary-card { margin-top: 20px; position: static; }
            .total-amount { font-size: 1.5rem; }
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <div class="logo-container">
                    <% if (negocio.logoHeader && negocio.logoHeader.image && negocio.logoHeader.type !== 'text') { %>
                        <img src="<%= negocio.logoHeader.image %>" alt="<%= negocio.nombre %>" style="width: <%= negocio.logoHeader?.size || 150 %>px; max-width: 100%; object-fit: contain;">
                    <% } else { %>
                        <i class="fas fa-store"></i>
                        <span><%= negocio.logoHeader && negocio.logoHeader.text ? negocio.logoHeader.text : negocio.nombre %></span>
                    <% } %>
                </div>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/productos"><i class="fas fa-shopping-bag"></i> Productos</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/carrito"><i class="fas fa-shopping-cart"></i> Carrito</a></li>
                    <% if (user) { %>
                        <li class="nav-item"><a class="nav-link" href="/mis-pedidos"><i class="fas fa-truck"></i> Mis Pedidos</a></li>
                        <li class="nav-item"><a class="nav-link" href="/perfil"><i class="fas fa-user-circle"></i> <%= user.nombre %></a></li>
                        <% if (user.rol === 'admin') { %>
                            <li class="nav-item"><a class="nav-link" href="/admin"><i class="fas fa-chart-line"></i> Admin</a></li>
                        <% } %>
                        <li class="nav-item"><a class="nav-link" href="/logout"><i class="fas fa-sign-out-alt"></i> Salir</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/login"><i class="fas fa-key"></i> Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/register"><i class="fas fa-user-plus"></i> Registro</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5 pt-4">
        <div class="cart-header">
            <h1 style="color: <%= _bannerTitle %>;"><i class="fas fa-shopping-cart"></i> <%= textos.carrito?.titulo_seccion || 'Mi Carrito' %></h1>
            <p class="mb-0" style="color: <%= _bannerSubtitle %>;"><%= textos.carrito?.subtitulo_seccion || 'Revisa tus productos antes de finalizar la compra' %></p>
        </div>
        
        <% if (!carrito || carrito.length === 0) { %>
            <div class="empty-cart text-center p-5">
                <i class="fas fa-shopping-basket" style="font-size: 80px; color: #cbd5e0;"></i>
                <h3 class="mt-3"><%= textos.carrito?.mensaje_vacio || 'Tu carrito está vacío' %></h3>
                <p class="text-muted"><%= textos.carrito?.mensaje_vacio_desc || '¡Explora nuestros productos y encuentra lo que te gusta!' %></p>
                <a href="/productos" class="btn btn-primary btn-lg mt-3" style="display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
                    <i class="fas fa-arrow-right"></i> <%= textos.carrito?.boton_ver_productos || 'Ver Productos' %>
                </a>
            </div>
        <% } else { %>
            <div class="row">
                <div class="col-lg-8">
                    <% carrito.forEach(item => { %>
                        <div class="cart-item-modern">
                            <div class="cart-item-inner">
                                <!-- Imagen -->
                                <img src="<%= item.imagen || '/images/producto-default.jpg' %>" class="cart-img-modern" alt="<%= item.nombre %>">

                                <!-- Cuerpo: nombre+precio a la izq, controles a la der -->
                                <div class="cart-item-body">
                                    <div class="cart-item-info">
                                        <h5><%= item.nombre %></h5>
                                        <p class="unit-price">$<%= parseFloat(item.precio).toFixed(2) %></p>
                                    </div>

                                    <div class="cart-item-actions">
                                        <!-- Cantidad -->
                                        <form action="/carrito/update" method="POST" class="quantity-control">
                                            <input type="hidden" name="id" value="<%= item.producto_id %>">
                                            <label class="mb-0">Cant:</label>
                                            <input type="number" name="cantidad" value="<%= parseInt(item.cantidad) %>" min="1"
                                                   class="quantity-input" onchange="this.form.submit()">
                                        </form>

                                        <!-- Subtotal -->
                                        <span class="cart-item-subtotal">
                                            $<%= (parseFloat(item.precio) * item.cantidad).toFixed(2) %>
                                        </span>

                                        <!-- Eliminar -->
                                        <a href="/carrito/remove/<%= item.producto_id || item.id %>"
                                           class="btn btn-danger btn-sm btn-remove-item"
                                           onclick="return confirm('¿Eliminar producto?')">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                    
                    <div class="mt-4">
                        <a href="/carrito/clear" class="btn btn-outline-danger" onclick="return confirm('¿Vaciar carrito?')" style="display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
                            <i class="fas fa-trash"></i> <%= textos.carrito?.boton_vaciar || 'Vaciar Carrito' %>
                        </a>
                    </div>
                </div>
                
                <div class="col-lg-4">
                    <%
                        // Leer pedidosConfig pasado por el controller (mismo objeto que usa checkout)
                        const _cfg       = (typeof pedidosConfig !== 'undefined' && pedidosConfig) ? pedidosConfig : {};
                        const _modoOp    = _cfg.modoOperacion || 'hibrido';
                        const _tarifas   = _cfg.tarifas    || {};
                        const _envioC    = _tarifas.envio     || {};
                        const _impC      = _tarifas.impuesto  || {};
                        const _extraC    = _tarifas.extra     || {};
                        const _sub       = parseFloat(total) || 0;

                        // Envío: no aplicar en modo retiro
                        let _envioMonto  = 0;
                        let _envioGratis = false;
                        let _envioLabel  = _envioC.label || 'Envío';
                        if (_envioC.activo === true && _modoOp !== 'retiro') {
                            const _tipo  = _envioC.tipo || 'fijo';
                            const _val   = parseFloat(_envioC.valor) || 0;
                            if (_tipo === 'gratis_desde') {
                                const _lim = parseFloat(_envioC.gratisDesde) || 0;
                                if (_sub >= _lim) { _envioGratis = true; }
                                else              { _envioMonto = _val; }
                            } else if (_tipo === 'porcentaje') {
                                _envioMonto = _sub * _val / 100;
                            } else {
                                _envioMonto = _val;
                            }
                        }

                        // IVA
                        const _ivaActivo   = _impC.activo === true;
                        const _ivaIncluido = _impC.incluido === true;
                        const _ivaMonto    = (_ivaActivo && !_ivaIncluido)
                            ? _sub * (parseFloat(_impC.porcentaje) || 0) / 100 : 0;

                        // Cargo extra
                        const _extraActivo = _extraC.activo === true;
                        let   _extraMonto  = 0;
                        if (_extraActivo) {
                            const _ev = parseFloat(_extraC.valor) || 0;
                            _extraMonto = _extraC.tipo === 'porcentaje' ? _sub * _ev / 100 : _ev;
                        }

                        const _totalFinal = _sub + _envioMonto + _ivaMonto + _extraMonto;
                    %>
                    <div class="summary-card">
                        <h4 class="fw-bold mb-4"><%= textos.carrito?.resumen_titulo || 'Resumen del Pedido' %></h4>
                        <hr>

                        <!-- Subtotal -->
                        <div class="d-flex justify-content-between mb-3">
                            <span><%= textos.carrito?.subtotal_label || 'Subtotal:' %></span>
                            <strong>$<%= _sub.toFixed(2) %></strong>
                        </div>

                        <!-- Envío: solo si está activo en config -->
                        <% if (_envioC.activo === true && _modoOp !== 'retiro') { %>
                        <div class="d-flex justify-content-between mb-1">
                            <span><%= _envioLabel %>:</span>
                            <% if (_envioGratis) { %>
                                <strong class="text-success">¡Gratis! 🎉</strong>
                            <% } else { %>
                                <strong>$<%= _envioMonto.toFixed(2) %></strong>
                            <% } %>
                        </div>
                        <% if (_envioC.tipo === 'gratis_desde' && parseFloat(_envioC.gratisDesde) > 0 && !_envioGratis) { %>
                        <div class="text-muted mb-3" style="font-size:0.78rem;text-align:right;">
                            Envío gratis desde $<%= parseFloat(_envioC.gratisDesde).toFixed(0) %>
                        </div>
                        <% } else { %>
                        <div class="mb-3"></div>
                        <% } %>
                        <% } %>

                        <!-- IVA: solo si activo y no incluido -->
                        <% if (_ivaActivo && !_ivaIncluido) { %>
                        <div class="d-flex justify-content-between mb-3">
                            <span><%= _impC.label || 'IVA' %> (<%= parseFloat(_impC.porcentaje)||0 %>%):</span>
                            <strong>$<%= _ivaMonto.toFixed(2) %></strong>
                        </div>
                        <% } else if (_ivaActivo && _ivaIncluido) { %>
                        <div class="d-flex justify-content-between mb-3 text-muted" style="font-size:0.82rem;">
                            <span><%= _impC.label || 'IVA' %> (<%= parseFloat(_impC.porcentaje)||0 %>%) incluido</span>
                            <span>—</span>
                        </div>
                        <% } %>

                        <!-- Cargo extra: solo si activo -->
                        <% if (_extraActivo) { %>
                        <div class="d-flex justify-content-between mb-3">
                            <span><%= _extraC.nombre || 'Cargo extra' %>:</span>
                            <strong>$<%= _extraMonto.toFixed(2) %></strong>
                        </div>
                        <% } %>

                        <hr>

                        <!-- Total final -->
                        <div class="d-flex justify-content-between mb-4">
                            <span class="h5"><%= textos.carrito?.total_label || 'Total:' %></span>
                            <span class="total-amount">$<%= _totalFinal.toFixed(2) %></span>
                        </div>
                        <a href="/checkout" class="btn btn-primary w-100 py-3" style="display: flex; align-items: center; justify-content: center; gap: 8px;">
                            <i class="fas fa-credit-card"></i> <%= textos.carrito?.boton_comprar || 'Proceder al pago' %>
                        </a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
    
    <!-- Footer -->
    <%- include('./footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>